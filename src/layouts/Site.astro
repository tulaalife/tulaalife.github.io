---
import FooterCard from "../components/FooterCard.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
    title: string;
    description?: string;
    canonicalPath?: string;
    ogImage?: string;
    hideFooter?: boolean;
    hasTranslation?: boolean;
    isLandingPage?: boolean;
}

const {
    title,
    description = "Your private sanctuary for holistic wellness. Yoga, meditation, and tracking—offline and free.",
    canonicalPath = "/",
    ogImage = "https://images.tulaa.life/logo.webp",
    hideFooter = false,
    hasTranslation = true,
    isLandingPage = false,
} = Astro.props;

const site = "https://tulaalife.com";
const currentLang = Astro.currentLocale || "en";
const currentPath = Astro.url.pathname;
const basePath = canonicalPath.startsWith("/")
    ? canonicalPath
    : `/${canonicalPath}`;
const enUrl = new URL(basePath, site).toString();
const hiUrl = new URL(
    basePath === "/" ? "/hi" : `/hi${basePath}`,
    site,
).toString();
const currentUrl = new URL(currentPath, site).toString();
const socialImage = ogImage.startsWith("http")
    ? ogImage
    : new URL(ogImage, site).toString();

const ui = {
    en: { privacy: "Privacy", terms: "Terms", contact: "Contact" },
    hi: { privacy: "गोपनीयता", terms: "शर्तें", contact: "संपर्क" },
};
const t = ui[currentLang as keyof typeof ui] || ui.en;
const getLink = (path: string) =>
    currentLang === "en" ? path : path === "/" ? "/hi" : `/hi${path}`;

let targetUrl = "/";
const cleanPath = currentPath.replace(/\/$/, "") || "/";
if (currentLang === "en") {
    const pathWithoutEn = cleanPath.replace(/^\/en(\/|$)/, "/");
    targetUrl = pathWithoutEn === "/" ? "/hi" : `/hi${pathWithoutEn}`;
} else {
    targetUrl = cleanPath.replace(/^\/hi(\/|$)/, "/") || "/";
}
targetUrl = targetUrl.replace(/\/+/g, "/");
---

<!doctype html>
<html
    lang={currentLang}
    data-theme="light"
    class={isLandingPage ? "is-landing" : ""}
>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="light dark" />
        <meta name="theme-color" content="#ffffff" id="theme-color-meta" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={currentUrl} />
        <meta name="robots" content="index,follow" />

        {
            hasTranslation && (
                <>
                    <link rel="alternate" hreflang="en" href={enUrl} />
                    <link rel="alternate" hreflang="hi" href={hiUrl} />
                    <link rel="alternate" hreflang="x-default" href={enUrl} />
                </>
            )
        }

        <meta property="og:type" content="website" />
        <meta property="og:url" content={currentUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImage} />

        <link rel="icon" type="image/webp" href="/assets/icons/logo_64.webp" />
        <ClientRouter />

        <!-- Google Fonts for Hindi (Noto Sans Devanagari) -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <script is:inline>
            (() => {
                const root = document.documentElement;
                const metaColor = document.getElementById("theme-color-meta");
                const bgColors = { light: "#ffffff", dark: "#18181b" };

                function getSystemTheme() {
                    return window.matchMedia("(prefers-color-scheme: dark)")
                        .matches
                        ? "dark"
                        : "light";
                }

                function setTheme(theme) {
                    root.dataset.theme = theme;
                    root.style.colorScheme = theme;
                    if (metaColor)
                        metaColor.setAttribute("content", bgColors[theme]);
                }

                function init() {
                    const hasBeenRedirected = localStorage.getItem(
                        "tulaa-lang-detected",
                    );
                    const isHomePage =
                        window.location.pathname === "/" ||
                        window.location.pathname === "";
                    if (!hasBeenRedirected && isHomePage) {
                        const userLang =
                            navigator.language || navigator.userLanguage;
                        if (userLang.startsWith("hi")) {
                            localStorage.setItem("tulaa-lang-detected", "true");
                            window.location.href = "/hi";
                            return;
                        }
                        localStorage.setItem("tulaa-lang-detected", "true");
                    }
                    const savedTheme = localStorage.getItem("tulaa-theme");
                    setTheme(savedTheme || getSystemTheme());
                }

                window
                    .matchMedia("(prefers-color-scheme: dark)")
                    .addEventListener("change", (e) => {
                        if (!localStorage.getItem("tulaa-theme"))
                            setTheme(e.matches ? "dark" : "light");
                    });
                init();
                document.addEventListener("astro:page-load", init);

                window.toggleTheme = function () {
                    const next =
                        root.dataset.theme === "dark" ? "light" : "dark";
                    setTheme(next);
                    localStorage.setItem("tulaa-theme", next);
                };
            })();
        </script>

        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href="/fonts/InterVariable.woff2"
            crossorigin
        />

        <style>
            @font-face {
                font-family: "Inter Var";
                src: url("/fonts/InterVariable.woff2") format("woff2");
                font-weight: 100 900;
                font-display: swap;
            }
        </style>

        <style is:global>
            /* Base Variables & Reset */
            *,
            *::before,
            *::after {
                box-sizing: border-box;
            }
            html,
            body {
                margin: 0;
                padding: 0;
                width: 100%;
            }

            /* ONLY lock scrolling if on the landing page */
            html.is-landing,
            html.is-landing body {
                height: 100%;
                overflow: hidden;
            }

            :root {
                --container-width: 1120px;
                --header-height: 64px;

                /* Typography Variables */
                --font-sans-en:
                    "Inter Var", -apple-system, BlinkMacSystemFont, sans-serif;
                --font-sans-hi: "Noto Sans Devanagari", sans-serif;
                --fw-bold: 750;
            }

            :root[data-theme="light"] {
                --bg-main: oklch(100% 0 0);
                --bg-sub: oklch(97% 0 0);

                /* Subtle Premium Gradient Background */
                --body-bg: linear-gradient(
                    160deg,
                    oklch(100% 0 0) 0%,
                    color-mix(in srgb, oklch(97% 0 0), var(--primary) 3%) 100%
                );

                --text-main: oklch(20% 0 0);
                --text-muted: oklch(42% 0 0);
                --primary: oklch(62% 0.14 145);
                --border: oklch(92% 0 0);
                --shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            }

            :root[data-theme="dark"] {
                --bg-main: oklch(15% 0.01 145);
                --bg-sub: oklch(18% 0.01 145);

                /* Subtle Premium Gradient Background */
                --body-bg: linear-gradient(
                    160deg,
                    oklch(16% 0.01 145) 0%,
                    oklch(12% 0.01 145) 100%
                );

                --text-main: oklch(96% 0 0);
                --text-muted: oklch(75% 0 0);
                --primary: oklch(70% 0.12 145);
                --border: oklch(25% 0 0);
                --shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
            }

            /* --- GLOBAL TYPOGRAPHY LOGIC --- */
            body {
                font-family: var(--font-sans-en);
                color: var(--text-main);
                background: var(--body-bg);
                background-attachment: fixed;
                transition: color 0.3s ease;
                -webkit-font-smoothing: antialiased;
                line-height: 1.6;
            }

            body:lang(hi) {
                font-family: var(--font-sans-hi);
                line-height: 1.7; /* Devanagari needs more breathing room */
            }

            h1,
            h2,
            h3,
            .section-title,
            .hero-title {
                margin: 0;
                font-weight: var(--fw-bold);
                line-height: 1.15;
                letter-spacing: -0.02em; /* English looks great tight */
            }

            /* Hindi Typography Overrides */
            :lang(hi) h1,
            :lang(hi) h2,
            :lang(hi) h3,
            :lang(hi) .section-title,
            :lang(hi) .hero-title {
                font-weight: 700; /* Dial back the boldness for clearer counters */
                letter-spacing: normal; /* Restore tracking to keep the shirorekha continuous */
                line-height: 1.35;
            }

            /* Optical adjustment for Hindi buttons */
            :lang(hi) .btn-pill,
            :lang(hi) .btn-sm,
            :lang(hi) .filter-btn {
                padding-top: 10px;
                padding-bottom: 8px;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            /* --- SCOPED SNAP SCROLLING ARCHITECTURE --- */
            html.is-landing .scroll-container {
                height: 100dvh;
                width: 100%;
                overflow-y: scroll;
                scroll-snap-type: y mandatory;
                scroll-behavior: smooth;
                scrollbar-width: none;
            }
            html.is-landing .scroll-container::-webkit-scrollbar {
                display: none;
            }

            html.is-landing .scroll-section {
                height: 100dvh;
                width: 100%;
                scroll-snap-align: start;
                display: flex;
                align-items: center;
                justify-content: center;
                position: relative;
                overflow: hidden;
                padding-top: var(--header-height);
            }

            /* --- FALLBACK FOR NORMAL PAGES --- */
            html:not(.is-landing) .scroll-container {
                padding-top: var(--header-height);
                min-height: 100vh;
            }
            html:not(.is-landing) .normal-footer {
                margin-top: 60px;
                padding-bottom: 40px;
            }

            /* --- PREMIUM ANIMATIONS --- */
            .animate-on-scroll {
                opacity: 0;
                transform: translateY(30px);
                transition:
                    opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .delay-1 {
                transition-delay: 0.15s;
            }
            .delay-2 {
                transition-delay: 0.3s;
            }

            .is-visible .animate-on-scroll {
                opacity: 1;
                transform: translateY(0);
            }

            /* Utilities */
            .container {
                max-width: var(--container-width);
                margin: 0 auto;
                padding: 0 24px;
                width: 100%;
            }

            /* Header styles */
            header {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                height: var(--header-height);
                z-index: 50;
                background: color-mix(in srgb, var(--bg-main), transparent 15%);
                backdrop-filter: blur(12px);
                border-bottom: 1px solid var(--border);
            }
            header .inner {
                display: flex;
                align-items: center;
                justify-content: space-between;
                height: 100%;
            }
            .logo {
                display: flex;
                align-items: center;
                gap: 10px;
                font-weight: var(--fw-bold);
            }
            .logo img {
                width: 32px;
                height: 32px;
                border-radius: 8px;
            }
            .header-actions {
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .lang-icon {
                font-size: 1rem;
                line-height: 1;
            }
            .lang-toggle {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                padding: 4px 10px;
                font-size: 0.8rem;
                font-weight: 600;
                color: var(--text-main);
                background: none;
                border: 1px solid var(--border);
                border-radius: 99px;
                transition: background 0.2s;
            }
            .lang-toggle:hover {
                background: var(--bg-sub);
            }

            .theme-toggle {
                background: none;
                border: none;
                cursor: pointer;
                color: var(--text-main);
                padding: 8px;
                border-radius: 50%;
                transition: background 0.2s;
            }
            .theme-toggle:hover {
                background: var(--bg-sub);
            }

            /* Footer & Toast Styles */
            .contact-btn {
                background: none;
                border: none;
                font: inherit;
                color: var(--text-muted);
                cursor: pointer;
                transition: color 0.2s ease;
            }
            .contact-btn:hover {
                color: var(--text-main);
                text-decoration: underline;
            }

            .copy-toast {
                position: fixed;
                bottom: 24px;
                left: 50%;
                transform: translateX(-50%) translateY(20px);
                background: color-mix(in srgb, var(--bg-sub), transparent 10%);
                color: var(--text-main);
                padding: 10px 16px;
                border-radius: 999px;
                font-size: 0.85rem;
                border: 1px solid var(--border);
                box-shadow: var(--shadow);
                opacity: 0;
                pointer-events: none;
                transition: all 0.3s ease;
                backdrop-filter: blur(10px);
                z-index: 1000;
            }
            .copy-toast.show {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }
        </style>
    </head>

    <body>
        <header>
            <div class="container inner">
                <a href={getLink("/")} class="logo">
                    <img
                        src="https://images.tulaa.life/logo_64.webp"
                        alt="Tulaa Logo"
                    />
                    <span>Tulaa</span>
                </a>
                <div class="header-actions">
                    {
                        hasTranslation && (
                            <a href={targetUrl} class="lang-toggle">
                                <span class="lang-icon">🌐</span>
                                {currentLang === "en" ? "हिंदी" : "EN"}
                            </a>
                        )
                    }
                    <button
                        id="themeBtn"
                        class="theme-toggle"
                        aria-label="Toggle Theme"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><circle cx="12" cy="12" r="5"></circle><path
                                d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
                            ></path></svg
                        >
                    </button>
                </div>
            </div>
        </header>

        <main class="scroll-container" id="main-scroll-container">
            <slot />

            <!-- Conditionally style the footer depending on if it's the landing page -->
            {
                !hideFooter && (
                    <section
                        class={
                            isLandingPage ? "scroll-section" : "normal-footer"
                        }
                        style={
                            isLandingPage
                                ? "height: auto; padding: 60px 0; scroll-snap-align: end;"
                                : ""
                        }
                    >
                        <div class="container">
                            <FooterCard />
                            <div
                                class="legal"
                                style="margin-top:24px; display:flex; gap:24px; justify-content:center;"
                            >
                                <a href={getLink("/legal/privacy")}>
                                    {t.privacy}
                                </a>
                                <a href={getLink("/legal/terms")}>{t.terms}</a>
                                <button class="contact-btn" id="contactBtn">
                                    {t.contact}
                                </button>
                            </div>
                            <p style="text-align: center; font-size: 0.8rem; margin-top: 20px; color: var(--text-muted);">
                                © {new Date().getFullYear()} Tulaalife Wellness
                                Private Limited
                            </p>
                        </div>
                    </section>
                )
            }
        </main>

        <script>
            declare global {
                interface Window {
                    toggleTheme: () => void;
                    copyEmail: () => void;
                }
            }

            window.copyEmail = async function () {
                const email = "contact@tulaalife.com";
                try {
                    await navigator.clipboard.writeText(email);
                } catch (e) {
                    console.error("Clipboard copy failed", e);
                    return;
                }

                const toastId = "copyToast";
                let toast = document.getElementById(toastId);
                const isHindi = document.documentElement.lang === "hi";
                const message = isHindi
                    ? "ईमेल कॉपी हो गया 💛 आप हमें कभी भी लिख सकते हैं"
                    : "Email copied 💛 You can write to us anytime";

                if (!toast) {
                    toast = document.createElement("div");
                    toast.id = toastId;
                    toast.className = "copy-toast";
                    document.body.appendChild(toast);
                }

                if (toast.classList.contains("show")) return;

                toast.innerText = message;
                toast.classList.add("show");

                setTimeout(() => {
                    toast.classList.remove("show");
                }, 2200);
            };

            document.addEventListener("astro:page-load", () => {
                const themeBtn = document.getElementById("themeBtn");
                if (themeBtn) {
                    themeBtn.addEventListener("click", () =>
                        window.toggleTheme(),
                    );
                }

                const contactBtn = document.getElementById("contactBtn");
                if (contactBtn) {
                    contactBtn.addEventListener("click", window.copyEmail);
                }

                const observerOptions = {
                    root: document.getElementById("main-scroll-container"),
                    threshold: 0.2,
                };

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-visible");
                        }
                    });
                }, observerOptions);

                // This will safely observe on landing pages, and peacefully do nothing on standard pages
                document
                    .querySelectorAll(".scroll-section, .footer-card-container")
                    .forEach((section) => {
                        observer.observe(section);
                    });
            });
        </script>
    </body>
</html>
