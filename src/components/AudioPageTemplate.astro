---
import { guidedAudios } from "../data/generated";
import Site from "../layouts/Site.astro";
import CTAButton from "./CTAButton.astro";

interface Props {
    audio: any;
    lang: "en" | "hi";
}

const { audio, lang } = Astro.props;

const LABELS = {
    hi: {
        back: "लाइब्रेरी पर वापस जाएं",
        tag: "गाइडेड ऑडियो",
        listen: "Tulaa ऐप में पूरा सेशन सुनें।",
        btnApp: "ऐप में चलाएं",
        btnBrowse: "लाइब्रेरी ब्राउज़ करें",
        browseLink: "/hi/audio",
    },
    en: {
        back: "Back to Library",
        tag: "Guided Audio",
        listen: "Listen to the full session offline in the Tulaa app.",
        btnApp: "Play in App",
        btnBrowse: "Browse Library",
        browseLink: "/audio",
    },
};

const t = LABELS[lang];
const canonical = `/audio/${audio.slug}`;
---

<Site
    title={`${audio.title} · Tulaa`}
    description={audio.description || "Gentle audio preview from Tulaa."}
    canonicalPath={canonical}
    ogImage={audio.image}
    hasTranslation={false}
>
    <div class="content-shell">
        <article class="audio-detail">
            <nav class="audio-nav">
                <a href={t.browseLink} class="back-link">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="m15 18-6-6 6-6"></path></svg
                    >
                    {t.back}
                </a>
            </nav>

            <div class="image-stage">
                <div class="image-frame">
                    <img
                        src={audio.image}
                        alt={audio.title}
                        width="1200"
                        height="630"
                        loading="eager"
                    />
                    <div class="play-overlay">
                        <div class="play-button">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                class="play-icon"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="audio-header">
                <span class="tag-pill">{t.tag}</span>
                <h1 class="audio-title">{audio.title}</h1>
                {
                    audio.subtitle && (
                        <p class="audio-subtitle">{audio.subtitle}</p>
                    )
                }
            </div>

            <div class="audio-body">
                {
                    audio.description && (
                        <p class="audio-lead">{audio.description}</p>
                    )
                }
            </div>

            <footer class="audio-footer">
                <div class="app-prompt">🎧 {t.listen}</div>
                <div class="button-group">
                    <CTAButton
                        href="https://tulaa.app"
                        label={t.btnApp}
                        variant="solid"
                        size="md"
                    />
                    <CTAButton
                        href={t.browseLink}
                        label={t.btnBrowse}
                        variant="soft"
                        size="md"
                    />
                </div>
            </footer>
        </article>
    </div>
</Site>

<style>
    .content-shell {
        max-width: 880px;
        margin: 0 auto;
        padding: 40px 20px 80px;
    }

    .audio-detail {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    /* =========================
       NAV
    ========================== */
    .audio-nav {
        display: flex;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--text-muted);
        transition: all 0.2s ease;
    }

    .back-link:hover {
        color: var(--primary);
        transform: translateX(-2px);
    }

    /* =========================
       HERO
    ========================== */
    .image-stage {
        display: flex;
        justify-content: center;
    }

    .image-frame {
        width: 100%;
        max-width: 680px;
        aspect-ratio: 16 / 10;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        background: var(--bg-sub);
        position: relative;
    }

    .image-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .image-frame:hover img {
        transform: scale(1.03);
    }

    .play-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .image-frame:hover .play-overlay {
        opacity: 1;
    }

    .play-button {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.25);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        transform: scale(0.9);
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .image-frame:hover .play-button {
        transform: scale(1);
    }

    .play-button:hover {
        background: var(--primary);
        border-color: var(--primary);
    }

    .play-icon {
        width: 24px;
        height: 24px;
        color: white;
        margin-left: 2px;
    }

    /* =========================
       HEADER
    ========================== */
    .audio-header {
        text-align: center;
        max-width: 720px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .tag-pill {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        color: var(--primary);
        background: var(--bg-sub);
        border: 1px solid var(--border);
        padding: 6px 14px;
        border-radius: 999px;
        width: fit-content;
        margin: 0 auto;
    }

    .audio-title {
        font-size: clamp(2rem, 4vw, 2.75rem);
    }

    /* CLEANED: Removed .audio-title letter-spacing & line-height; configured via layout file globally now */

    .audio-subtitle {
        font-size: 1.1rem;
        color: var(--text-muted);
        line-height: 1.6;
        max-width: 600px;
        margin: 0 auto;
    }

    /* =========================
       BODY
    ========================== */
    .audio-body {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
    }

    .audio-lead {
        font-size: 1.15rem;
        line-height: 1.7;
        color: var(--text-main);
    }

    /* =========================
       FOOTER
    ========================== */
    .audio-footer {
        margin-top: 16px;
        padding-top: 32px;
        border-top: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        text-align: center;
    }

    .app-prompt {
        font-size: 0.95rem;
        color: var(--text-muted);
    }

    .button-group {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        justify-content: center;
    }

    /* =========================
       MOBILE
    ========================== */
    @media (max-width: 600px) {
        .content-shell {
            padding: 24px 16px 60px;
        }

        .audio-title {
            font-size: 1.8rem;
        }
    }
</style>
