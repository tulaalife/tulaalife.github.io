---
import Site from "../layouts/Site.astro";
import type { Page } from "astro";
import { CATEGORY_MAP } from "../utils/ui-strings";

interface Plan {
    slug: string;
    title: string;
    subtitle: string;
    image: string;
    language?: string;
    goals: string[];
}

interface Props {
    page: Page<Plan>;
    title: string;
    description: string;
    canonicalPath: string;
    lang: string;
    labels: {
        title: string;
        description: string;
        view: string;
        prev: string;
        next: string;
        metaPage: string;
    };
}

const { page, title, description, canonicalPath, lang, labels } = Astro.props;
---

<Site title={title} description={description} canonicalPath={canonicalPath}>
    <main class="listing-container">
        <div class="listing-header">
            <h1 class="page-title">{labels.title}</h1>
            <p class="page-subtitle">{labels.description}</p>
        </div>

        <div class="plans-grid" id="plans-grid">
            {
                page.data.map((p) => (
                    <a
                        href={`/${lang}/yoga/${p.slug}`}
                        class="plan-card"
                        data-goals={p.goals?.join(",")}
                    >
                        <div class="card-image">
                            <img
                                src={p.image}
                                alt={p.title}
                                loading="lazy"
                                decoding="async"
                            />
                        </div>

                        <div class="card-content">
                            <h3 class="card-title">{p.title}</h3>
                            <p class="card-desc">{p.subtitle}</p>

                            <div class="card-footer">
                                <span class="view-link">{labels.view}</span>
                                <span class="icon">→</span>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>

        {
            page.lastPage > 1 && (
                <nav
                    class="pagination"
                    id="listing-pagination"
                    aria-label="Pagination"
                >
                    {page.url.prev ? (
                        <a href={page.url.prev} class="btn-pill">
                            ← {labels.prev}
                        </a>
                    ) : (
                        <span class="btn-pill disabled">← {labels.prev}</span>
                    )}

                    <span class="page-meta">
                        {labels.metaPage} {page.currentPage} / {page.lastPage}
                    </span>

                    {page.url.next ? (
                        <a href={page.url.next} class="btn-pill">
                            {labels.next} →
                        </a>
                    ) : (
                        <span class="btn-pill disabled">{labels.next} →</span>
                    )}
                </nav>
            )
        }
    </main>
</Site>

<script is:inline define:vars={{ CATEGORY_MAP }}>
    function applyImplicitSort() {
        const params = new URLSearchParams(window.location.search);
        const catId = params.get("goal");

        if (!catId) {
            return;
        }

        if (!CATEGORY_MAP[catId]) {
            return;
        }

        const grid = document.getElementById("plans-grid");
        const cards = Array.from(document.querySelectorAll(".plan-card"));

        if (cards.length === 0) {
            return;
        }

        const targetGoals = CATEGORY_MAP[catId];
        const matches = [];
        const nonMatches = [];

        cards.forEach((card) => {
            const itemGoals = (card.getAttribute("data-goals") || "").split(
                ",",
            );
            const isMatch = targetGoals.some((goal) =>
                itemGoals.includes(goal),
            );

            if (isMatch) {
                matches.push(card);
                card.classList.add("highlight-match");
            } else {
                nonMatches.push(card);
            }
        });

        if (matches.length > 0) {
            grid.innerHTML = "";
            matches.forEach((card) => grid.appendChild(card));
            nonMatches.forEach((card) => grid.appendChild(card));
        }
    }

    applyImplicitSort();

    // Attempt 2: DOMContentLoaded
    window.addEventListener("DOMContentLoaded", () => {
        applyImplicitSort();
    });

    // Attempt 3: View Transitions (If you use Astro View Transitions)
    document.addEventListener("astro:page-load", () => {
        applyImplicitSort();
    });
</script>

<style>
    .listing-container {
        max-width: var(--container-width);
        margin: 0 auto;
        padding: 60px 24px 80px;
    }

    .listing-header {
        text-align: center;
        margin-bottom: 60px; /* Increased margin since filter buttons are gone */
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .page-title {
        font-size: var(--text-display);
        margin-bottom: 16px;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }

    .page-subtitle {
        font-size: 1.15rem;
        color: var(--text-muted);
        line-height: 1.5;
    }

    .plans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 32px;
    }

    .plan-card {
        display: flex;
        flex-direction: column;
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        height: 100%;
    }

    /* Subtle highlight for prioritized plans */
    .plan-card.highlight-match {
        border-color: var(--primary);
        background: color-mix(in srgb, var(--primary), transparent 97%);
    }

    .plan-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
        border-color: var(--primary);
    }

    .card-image {
        position: relative;
        aspect-ratio: 4/3;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .card-content {
        padding: 24px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-title {
        font-size: 1.35rem;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .card-desc {
        font-size: 1rem;
        color: var(--text-muted);
        line-height: 1.2; /* Slightly tighter for shorter text */
        margin-bottom: 16px; /* Reduced from 24px for a tighter look */
        flex-grow: 1;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        color: var(--primary);
    }

    .pagination {
        margin-top: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
    }

    .btn-pill {
        padding: 10px 24px;
        border-radius: 999px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: var(--text-main);
        font-weight: 500;
    }

    .btn-pill.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    @media (max-width: 600px) {
        .plans-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
