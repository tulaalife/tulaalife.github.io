---
import Site from "../layouts/Site.astro";
import type { Page } from "astro";
import { CATEGORY_MAP } from "../utils/ui-strings";

interface Plan {
    slug: string;
    title: string;
    description: string;
    image: string;
    language?: string;
    goals: string[];
}

interface Props {
    page: Page<Plan>;
    title: string;
    description: string;
    canonicalPath: string;
    lang: string;
    labels: {
        title: string;
        description: string;
        view: string;
        prev: string;
        next: string;
        metaPage: string;
        filterLabel: string;
        filterAll: string;
        filterGeneral: string;
        filterSeniors: string;
        filterMedical: string;
        filterWomens: string;
    };
}

const { page, title, description, canonicalPath, lang, labels } = Astro.props;
---

<Site title={title} description={description} canonicalPath={canonicalPath}>
    <main class="listing-container">
        <div class="listing-header">
            <h1 class="page-title">{labels.title}</h1>
            <p class="page-subtitle">{labels.description}</p>
        </div>

        <div class="filter-wrapper">
            <button
                class="filter-btn active"
                data-category="all"
                onclick="setSort('all')"
            >
                {labels.filterAll}
            </button>
            <button
                class="filter-btn"
                data-category="general"
                onclick="setSort('general')"
            >
                {labels.filterGeneral}
            </button>
            <button
                class="filter-btn"
                data-category="seniors"
                onclick="setSort('seniors')"
            >
                {labels.filterSeniors}
            </button>
            <button
                class="filter-btn"
                data-category="medical"
                onclick="setSort('medical')"
            >
                {labels.filterMedical}
            </button>
            <button
                class="filter-btn"
                data-category="womens"
                onclick="setSort('womens')"
            >
                {labels.filterWomens}
            </button>
        </div>

        <div class="plans-grid" id="plans-grid">
            {
                page.data.map((p) => (
                    <a
                        href={`/${lang}/yoga/${p.slug}`}
                        class="plan-card"
                        data-goals={p.goals?.join(",")}
                    >
                        <div class="card-image">
                            <img
                                src={p.image}
                                alt={p.title}
                                loading="lazy"
                                decoding="async"
                            />
                        </div>

                        <div class="card-content">
                            <h3 class="card-title">{p.title}</h3>
                            <p class="card-desc">{p.description}</p>

                            <div class="card-footer">
                                <span class="view-link">{labels.view}</span>
                                <span class="icon">→</span>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>

        {
            page.lastPage > 1 && (
                <nav
                    class="pagination"
                    id="listing-pagination"
                    aria-label="Pagination"
                >
                    {page.url.prev ? (
                        <a href={page.url.prev} class="btn-pill">
                            ← {labels.prev}
                        </a>
                    ) : (
                        <span class="btn-pill disabled">← {labels.prev}</span>
                    )}

                    <span class="page-meta">
                        {labels.metaPage} {page.currentPage} / {page.lastPage}
                    </span>

                    {page.url.next ? (
                        <a href={page.url.next} class="btn-pill">
                            {labels.next} →
                        </a>
                    ) : (
                        <span class="btn-pill disabled">{labels.next} →</span>
                    )}
                </nav>
            )
        }
    </main>
</Site>

<script is:inline define:vars={{ CATEGORY_MAP }}>
    /**
     * Client-side sorting and UI feedback
     * Uses the CATEGORY_MAP imported from ui-strings via Astro define:vars
     */
    function setSort(catId, updateUrl = true) {
        const grid = document.getElementById("plans-grid");
        const cards = Array.from(document.querySelectorAll(".plan-card"));
        const buttons = document.querySelectorAll(".filter-btn");
        const targetGoals = CATEGORY_MAP[catId] || [];

        // 1. Update Button UI
        buttons.forEach((btn) => {
            btn.classList.toggle(
                "active",
                btn.getAttribute("data-category") === (catId || "all"),
            );
        });

        // 2. Sorting Logic
        const matches = [];
        const nonMatches = [];

        cards.forEach((card) => {
            const itemGoals = (card.getAttribute("data-goals") || "").split(
                ",",
            );
            const isMatch =
                catId === "all" || !catId
                    ? false
                    : targetGoals.some((goal) => itemGoals.includes(goal));

            if (isMatch) {
                matches.push(card);
                card.classList.add("highlight-match");
            } else {
                nonMatches.push(card);
                card.classList.remove("highlight-match");
            }
        });

        // Clear and Re-append in sorted order (Matches first)
        grid.innerHTML = "";
        matches.forEach((card) => grid.appendChild(card));
        nonMatches.forEach((card) => grid.appendChild(card));

        // 3. URL Sync
        if (updateUrl) {
            const url = new URL(window.location);
            if (catId === "all" || !catId) {
                url.searchParams.delete("goal");
            } else {
                url.searchParams.set("goal", catId);
            }
            window.history.pushState({}, "", url);
        }
    }

    // Initialize on Page Load
    window.addEventListener("DOMContentLoaded", () => {
        const params = new URLSearchParams(window.location.search);
        const goal = params.get("goal");
        if (goal) {
            setSort(goal, false);
        }
    });

    // Make setSort available to the inline onclick handlers
    window.setSort = setSort;
</script>

<style>
    .listing-container {
        max-width: var(--container-width);
        margin: 0 auto;
        padding: 60px 24px 80px;
    }

    .listing-header {
        text-align: center;
        margin-bottom: 40px;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .page-title {
        font-size: var(--text-display);
        margin-bottom: 16px;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }

    .page-subtitle {
        font-size: 1.15rem;
        color: var(--text-muted);
        line-height: 1.5;
    }

    /* --- FILTERS --- */
    .filter-wrapper {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 48px;
    }

    .filter-btn {
        padding: 8px 20px;
        border-radius: 99px;
        border: 1px solid var(--border);
        background: var(--bg-main);
        color: var(--text-muted);
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .filter-btn.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    /* --- GRID & CARDS --- */
    .plans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 32px;
    }

    .plan-card {
        display: flex;
        flex-direction: column;
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        height: 100%;
    }

    .plan-card.highlight-match {
        border-color: var(--primary);
        background: color-mix(in srgb, var(--primary), transparent 95%);
    }

    .plan-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
        border-color: color-mix(in srgb, var(--primary), transparent 70%);
    }

    .card-image {
        position: relative;
        aspect-ratio: 4/3;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .plan-card:hover .card-image img {
        transform: scale(1.06);
    }

    .card-content {
        padding: 24px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-title {
        font-size: 1.35rem;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .card-desc {
        font-size: 1rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 24px;
        flex-grow: 1;
    }

    .card-footer {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        color: var(--primary);
    }

    /* --- PAGINATION --- */
    .pagination {
        margin-top: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
    }

    .btn-pill {
        padding: 10px 24px;
        border-radius: 999px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: var(--text-main);
        font-weight: 500;
    }

    .btn-pill.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    @media (max-width: 600px) {
        .plans-grid {
            grid-template-columns: 1fr;
        }
        .filter-wrapper {
            justify-content: flex-start;
            margin: 0 -24px 32px;
            padding: 0 24px 12px;
            overflow-x: auto;
            flex-wrap: nowrap;
        }
    }
</style>
