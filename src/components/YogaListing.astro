---
import Site from "../layouts/Site.astro";
import type { Page } from "astro";

interface Plan {
    slug: string;
    title: string;
    description: string;
    image: string;
    language?: string;
    goals: string[];
}

interface Props {
    page: Page<Plan>;
    title: string;
    description: string;
    canonicalPath: string;
    lang: string;
    labels: {
        title: string;
        description: string;
        view: string;
        prev: string;
        next: string;
        metaPage: string;
        filterLabel: string;
        filterAll: string;
        filterOffice: string;
        filterSeniors: string;
        filterMedical: string;
    };
}

const { page, title, description, canonicalPath, lang, labels } = Astro.props;

/** * These IDs match the keys in CATEGORY_MAP below
 */
const availableFilters = [
    { id: "all", label: labels.filterAll, emoji: "✨" },
    { id: "office", label: labels.filterOffice, emoji: "💻" },
    { id: "seniors", label: labels.filterSeniors, emoji: "🪑" },
    { id: "medical", label: labels.filterMedical, emoji: "🔬" },
];
---

<Site title={title} description={description} canonicalPath={canonicalPath}>
    <main class="listing-container">
        <div class="listing-header">
            <h1 class="page-title">{labels.title}</h1>
            <p class="page-subtitle">{labels.description}</p>

            <div class="filter-section">
                <p class="filter-heading">{labels.filterLabel}</p>

                <div class="filter-wrapper">
                    <div class="filter-bar" id="filter-bar">
                        {
                            availableFilters.map((g) => (
                                <button
                                    class="filter-btn"
                                    data-category={g.id}
                                    onclick={`setFilter('${g.id}')`}
                                >
                                    <span class="btn-emoji">{g.emoji}</span>
                                    {g.label}
                                </button>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="plans-grid" id="plans-grid">
            {
                page.data.map((p) => (
                    <a
                        href={`/${lang}/yoga/${p.slug}`}
                        class="plan-card"
                        data-goals={p.goals?.join(",")}
                    >
                        <div class="card-image">
                            <img
                                src={p.image}
                                alt={p.title}
                                loading="lazy"
                                decoding="async"
                            />
                        </div>

                        <div class="card-content">
                            <h3 class="card-title">{p.title}</h3>
                            <p class="card-desc">{p.description}</p>

                            <div class="card-footer">
                                <span class="view-link">{labels.view}</span>
                                <span class="icon">→</span>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>

        <div id="no-results" class="no-results" style="display: none;">
            <p>No plans found for this category.</p>
        </div>

        {
            page.lastPage > 1 && (
                <nav
                    class="pagination"
                    id="listing-pagination"
                    aria-label="Pagination"
                >
                    {page.url.prev ? (
                        <a href={page.url.prev} class="btn-pill">
                            ← {labels.prev}
                        </a>
                    ) : (
                        <span class="btn-pill disabled">← {labels.prev}</span>
                    )}

                    <span class="page-meta">
                        {labels.metaPage} {page.currentPage} / {page.lastPage}
                    </span>

                    {page.url.next ? (
                        <a href={page.url.next} class="btn-pill">
                            {labels.next} →
                        </a>
                    ) : (
                        <span class="btn-pill disabled">{labels.next} →</span>
                    )}
                </nav>
            )
        }
    </main>
</Site>

<script is:inline>
    const CATEGORY_MAP = {
        office: ["pain_relief", "stress_relief", "fitness_posture"],
        seniors: ["pain_relief", "seniors"],
        medical: ["yoga_therapy", "womens_health"],
    };

    function setFilter(catId, updateUrl = true) {
        const cards = document.querySelectorAll(".plan-card");
        const buttons = document.querySelectorAll(".filter-btn");
        const pagination = document.getElementById("listing-pagination");
        const noResults = document.getElementById("no-results");

        let visibleCount = 0;

        // Toggle Button Active Class
        buttons.forEach((btn) => {
            btn.classList.toggle(
                "active",
                btn.getAttribute("data-category") === catId,
            );
        });

        // Filter Logic
        cards.forEach((card) => {
            if (catId === "all") {
                card.style.display = "flex";
                visibleCount++;
            } else {
                const itemGoals = (card.getAttribute("data-goals") || "").split(
                    ",",
                );
                const targetGoals = CATEGORY_MAP[catId] || [];

                // Matches if the plan contains ANY of the goals in the lifestyle bucket
                const isMatch = targetGoals.some((goal) =>
                    itemGoals.includes(goal),
                );

                if (isMatch) {
                    card.style.display = "flex";
                    visibleCount++;
                } else {
                    card.style.display = "none";
                }
            }
        });

        // Hide pagination when filtering locally
        if (pagination) {
            pagination.style.display = catId === "all" ? "flex" : "none";
        }

        if (noResults) {
            noResults.style.display = visibleCount === 0 ? "block" : "none";
        }

        // URL Sync
        if (updateUrl) {
            const url = new URL(window.location);
            if (catId === "all") {
                url.searchParams.delete("goal");
            } else {
                url.searchParams.set("goal", catId);
            }
            window.history.pushState({}, "", url);
        }
    }

    // Initialize on Page Load
    window.addEventListener("DOMContentLoaded", () => {
        const params = new URLSearchParams(window.location.search);
        const goal = params.get("goal");
        setFilter(goal || "all", false);
    });
</script>

<style>
    .listing-container {
        max-width: var(--container-width);
        margin: 0 auto;
        padding: 60px 24px 80px;
    }

    .listing-header {
        text-align: center;
        margin-bottom: 60px;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .page-title {
        font-size: var(--text-display);
        margin-bottom: 16px;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }

    .page-subtitle {
        font-size: 1.15rem;
        color: var(--text-muted);
        line-height: 1.5;
    }

    /* --- FILTER STYLES --- */
    .filter-section {
        margin-top: 40px;
    }

    .filter-heading {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        margin-bottom: 12px;
        font-weight: 600;
    }

    .filter-wrapper {
        display: flex;
        justify-content: center;
        overflow-x: auto;
        padding-bottom: 8px;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .filter-wrapper::-webkit-scrollbar {
        display: none;
    }

    .filter-bar {
        display: flex;
        gap: 8px;
        padding: 6px;
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: 50px;
        width: max-content;
    }

    .filter-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 40px;
        border: none;
        background: transparent;
        color: var(--text-muted);
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .btn-emoji {
        font-size: 1.1rem;
    }

    .filter-btn:hover {
        color: var(--text-main);
        background: rgba(0, 0, 0, 0.03);
    }

    .filter-btn.active {
        background: var(--bg-main);
        color: var(--primary);
        box-shadow: var(--shadow-sm);
    }

    /* --- GRID & CARDS --- */
    .plans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 32px;
    }

    .plan-card {
        display: flex;
        flex-direction: column;
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        height: 100%;
    }

    .plan-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
        border-color: color-mix(in srgb, var(--primary), transparent 70%);
    }

    .card-image {
        position: relative;
        aspect-ratio: 4/3;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .plan-card:hover .card-image img {
        transform: scale(1.06);
    }

    .card-content {
        padding: 24px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-title {
        font-size: 1.35rem;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .card-desc {
        font-size: 1rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 24px;
        flex-grow: 1;
    }

    .card-footer {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        color: var(--primary);
    }

    .no-results {
        text-align: center;
        padding: 60px 0;
        color: var(--text-muted);
    }

    /* --- PAGINATION --- */
    .pagination {
        margin-top: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
    }

    .btn-pill {
        padding: 10px 24px;
        border-radius: 999px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: var(--text-main);
        font-weight: 500;
    }

    .btn-pill.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    @media (max-width: 600px) {
        .plans-grid {
            grid-template-columns: 1fr;
        }
        .filter-wrapper {
            justify-content: flex-start;
            margin: 0 -24px;
            padding: 0 24px 12px;
        }
    }
</style>
