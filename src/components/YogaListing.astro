---
// src/components/YogaPlanListing.astro
import Site from "../layouts/Site.astro";
import type { Page } from "astro";
import { CATEGORY_MAP } from "../utils/ui-strings";

interface Plan {
    slug: string;
    title: string;
    subtitle: string;
    image: string;
    language?: string;
    goals: string[];
}

interface Props {
    page: Page<Plan>;
    title: string;
    description: string;
    canonicalPath: string;
    lang: string;
    labels: {
        title: string;
        description: string;
        view: string;
        prev: string;
        next: string;
        metaPage: string;
    };
}

const { page, title, description, canonicalPath, lang, labels } = Astro.props;
---

<Site title={title} description={description} canonicalPath={canonicalPath}>
    <main class="listing-container">
        <!-- Enforced consistent center header alignment pattern across grid indexes -->
        <div class="section-header-center listing-header">
            <h1 class="page-title hero-title">{labels.title}</h1>
            <p class="page-subtitle body-text" style="margin-top: 12px;">
                {labels.description}
            </p>
        </div>

        <div class="plans-grid" id="plans-grid">
            {
                page.data.map((p) => (
                    <a
                        href={`/${lang}/yoga/${p.slug}`}
                        class="plan-card"
                        data-goals={p.goals?.join(",")}
                    >
                        <div class="card-image">
                            <img
                                src={p.image}
                                alt={p.title}
                                loading="lazy"
                                decoding="async"
                            />
                        </div>

                        <div class="card-content">
                            <h3 class="card-title">{p.title}</h3>
                            <p class="card-desc">{p.subtitle}</p>

                            <div class="card-footer">
                                <span class="view-link">{labels.view}</span>
                                <span class="icon">→</span>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>

        {
            page.lastPage > 1 && (
                <nav
                    class="pagination"
                    id="listing-pagination"
                    aria-label="Pagination"
                >
                    {page.url.prev ? (
                        <a href={page.url.prev} class="btn-pill">
                            ← {labels.prev}
                        </a>
                    ) : (
                        <span class="btn-pill disabled">← {labels.prev}</span>
                    )}

                    <span class="page-meta">
                        {labels.metaPage} {page.currentPage} / {page.lastPage}
                    </span>

                    {page.url.next ? (
                        <a href={page.url.next} class="btn-pill">
                            {labels.next} →
                        </a>
                    ) : (
                        <span class="btn-pill disabled">{labels.next} →</span>
                    )}
                </nav>
            )
        }
    </main>
</Site>

<script is:inline define:vars={{ CATEGORY_MAP }}>
    function applyImplicitSort() {
        const params = new URLSearchParams(window.location.search);
        const catId = params.get("goal");

        if (!catId || !CATEGORY_MAP[catId]) {
            return;
        }

        const grid = document.getElementById("plans-grid");
        const cards = Array.from(document.querySelectorAll(".plan-card"));

        if (cards.length === 0) {
            return;
        }

        const targetGoals = CATEGORY_MAP[catId];
        const matches = [];
        const nonMatches = [];

        cards.forEach((card) => {
            const itemGoals = (card.getAttribute("data-goals") || "").split(
                ",",
            );
            const isMatch = targetGoals.some((goal) =>
                itemGoals.includes(goal),
            );

            if (isMatch) {
                matches.push(card);
                card.classList.add("highlight-match");
            } else {
                nonMatches.push(card);
            }
        });

        if (matches.length > 0) {
            grid.innerHTML = "";
            matches.forEach((card) => grid.appendChild(card));
            nonMatches.forEach((card) => grid.appendChild(card));
        }
    }

    applyImplicitSort();

    window.addEventListener("DOMContentLoaded", () => {
        applyImplicitSort();
    });

    document.addEventListener("astro:page-load", () => {
        applyImplicitSort();
    });
</script>

<style>
    .listing-container {
        max-width: var(--container-width);
        margin: 0 auto;
        padding: 60px 24px 80px;
    }

    .listing-header {
        margin-bottom: 60px;
        max-width: 800px;
    }

    .page-title {
        font-size: clamp(2.4rem, 5vw, 3.5rem);
    }

    .page-subtitle {
        color: var(--text-muted);
    }

    .plans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 32px;
    }

    .plan-card {
        display: flex;
        flex-direction: column;
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease,
            border-color 0.3s ease;
        height: 100%;
    }

    .plan-card.highlight-match {
        border-color: var(--primary);
        background: color-mix(in srgb, var(--primary), transparent 97%);
    }

    .plan-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow);
        border-color: var(--primary);
    }

    .card-image {
        position: relative;
        aspect-ratio: 16 / 10; /* Unified premium widescreen format constraint metrics */
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .plan-card:hover .card-image img {
        transform: scale(1.03);
    }

    .card-content {
        padding: 24px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        text-align: left; /* Lock internal descriptions left-flush */
    }

    .card-title {
        font-size: 1.35rem;
        margin-bottom: 10px;
        font-weight: var(--fw-bold);
        color: var(--text-main);
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin-bottom: 16px;
        flex-grow: 1;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.5;
    }

    .card-footer {
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
        color: var(--primary);
        font-size: 0.95rem;
    }

    .pagination {
        margin-top: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
    }

    .btn-pill {
        padding: 10px 24px;
        border-radius: 999px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: var(--text-main);
        font-size: 0.85rem;
        font-weight: 600;
        background: var(--bg-main);
        transition: all 0.2s ease;
    }

    .btn-pill:not(.disabled):hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--bg-sub);
    }

    .btn-pill.disabled {
        opacity: 0.4;
        cursor: not-allowed;
        background: transparent;
    }

    @media (max-width: 600px) {
        .plans-grid {
            grid-template-columns: 1fr;
        }

        .listing-container {
            padding: 40px 16px 60px;
        }
    }
</style>
