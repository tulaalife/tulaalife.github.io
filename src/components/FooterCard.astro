---
// src/components/FooterCard.astro
import StoreButtons from "./StoreButtons.astro";

// 1. Get current language
const currentLang = Astro.currentLocale || "en";

// 2. Dynamic Dictionary - Punchier, High-Conversion Copy
const ui = {
    en: {
        titleTop: "Ready to",
        titleBottom: "Transform Your Life?",
        subline:
            "Get expert yoga therapy and daily wellness tracking. <strong>100% Free, Private, and Offline.</strong> No accounts, no tracking.",
    },
    hi: {
        titleTop: "क्या आप तैयार हैं",
        titleBottom: "बदलाव के लिए?",
        subline:
            "एक्सपर्ट योग थेरेपी और डेली सेहत ट्रैकिंग। <strong>100% फ्री, सुरक्षित और ऑफलाइन।</strong> बिना किसी अकाउंट या ट्रैकिंग के।",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;

interface Props {
    headline?: string;
    subline?: string;
}

const { subline = t.subline } = Astro.props;
---

<section class="footer-card-container">
    <div class="footer-card">
        <!-- Integrated our layout structure center-alignment configuration utility framework -->
        <div class="section-header-center content">
            <h2 class="section-title">
                <span class="title-main">{t.titleTop}</span>
                <br />
                <span class="text-gradient">{t.titleBottom}</span>
            </h2>

            <p class="sub body-text" set:html={subline} />

            <div class="button-container">
                <StoreButtons centered={true} />
            </div>
        </div>
    </div>
</section>

<style>
    .footer-card-container {
        width: 100%;
        display: flex;
        justify-content: center;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .footer-card {
        position: relative;
        width: 100%;
        max-width: var(--container-width);
        /* Replaced static 4rem padding with a dynamic scale to optimize vertical space */
        padding: clamp(2.5rem, 6vh, 4.5rem) var(--space-md);
        border-radius: var(--radius-lg);
        overflow: hidden;
        isolation: isolate;

        /* Glassmorphism base styling setup */
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--bg-main), white 2%) 0%,
            color-mix(in srgb, var(--bg-sub), transparent 50%) 100%
        );
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }

    :global([data-theme="dark"]) .footer-card {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.03) 0%,
            rgba(255, 255, 255, 0.01) 100%
        );
    }

    .content {
        max-width: 700px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .section-title {
        font-size: clamp(2rem, 5.5vw, 3.6rem);
        margin-bottom: var(--space-sm); /* Controlled rhythm step */
        line-height: 1.15;
    }

    .title-main {
        color: var(--text-main);
    }

    .sub {
        font-size: clamp(1.05rem, 2vw, 1.2rem);
        line-height: 1.6;
        margin-bottom: var(
            --space-lg
        ); /* Reduced to prevent cutting off the buttons */
        max-width: 560px;
        margin-left: auto;
        margin-right: auto;
        color: var(--text-muted);
    }

    .sub :global(strong) {
        color: var(--text-main);
        font-weight: var(--fw-bold);
    }

    .button-container {
        filter: drop-shadow(
            0 12px 24px color-mix(in srgb, var(--text-main) 10%, transparent)
        );
        transition: transform 0.3s ease;
    }

    .button-container:hover {
        transform: translateY(-4px);
    }

    /* --- GLOBAL LOCALE OPTIMIZATIONS FOR DEVANAGARI --- */
    :lang(hi) .section-title {
        line-height: 1.35;
    }
    :lang(hi) .sub {
        line-height: 1.65;
    }

    /* --- RESPONSIVE OPTIMIZATIONS FOR SMALL HEIGHT DEVICES --- */
    @media (max-height: 740px) {
        .footer-card-container {
            padding-top: var(--space-md);
            padding-bottom: var(--space-md);
        }
        .footer-card {
            padding: var(--space-lg) var(--space-md);
        }
        .section-title {
            font-size: 1.8rem;
            margin-bottom: var(--space-xs);
        }
        .sub {
            font-size: 1rem;
            margin-bottom: var(--space-md);
        }
    }

    @media (max-width: 768px) {
        .footer-card {
            padding: var(--space-xl) var(--space-sm);
            border-radius: var(--radius-lg);
        }
    }
</style>
