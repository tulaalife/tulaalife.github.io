---
// src/components/YogaPlanDetail.astro
import Site from "../layouts/Site.astro";
import CTAButton from "./CTAButton.astro";
import type { YogaPlanPreview } from "../data/types";

interface Props {
    plan: YogaPlanPreview;
    canonicalPath: string;
    lang: string;
    labels: {
        back: string;
        openApp: string;
        browse: string;
    };
    backLink?: string;
    browseLink?: string;
}

const { plan, canonicalPath, lang, labels, backLink, browseLink } = Astro.props;

const translations = {
    en: {
        benefitsLabel: "Key Benefits",
    },
    hi: {
        benefitsLabel: "मुख्य लाभ",
    },
};

const t = translations[lang as keyof typeof translations] || translations.en;

const benefitsList = plan.benefits
    ? plan.benefits
          .split(/\s*[,\n·]\s*/)
          .map((b) => b.trim())
          .filter(Boolean)
    : [];

const finalBackLink = backLink || `/${lang}/yoga`;
const finalBrowseLink = browseLink || `/${lang}/yoga`;
---

<Site
    title={`${plan.title} · Yoga Plan · Tulaa`}
    description={plan.description ||
        plan.subtitle ||
        "Gentle preview of this Tulaa yoga plan."}
    canonicalPath={canonicalPath}
    ogImage={plan.image}
    hasTranslation={true}
>
    <div class="content-shell">
        <article class="plan-card">
            <!-- Back Navigation -->
            <nav class="plan-nav">
                <a href={finalBackLink} class="back-link">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                    {labels.back}
                </a>
            </nav>

            <!-- Hero Image -->
            <div class="image-hero">
                <div class="image-frame">
                    <img
                        src={plan.image}
                        alt={plan.title}
                        width="1200"
                        height="630"
                        loading="eager"
                    />
                </div>
            </div>

            <!-- Standardized to left-alignment structural format rules for effortless readability -->
            <div class="section-header-left plan-header">
                <h1 class="plan-title section-title">{plan.title}</h1>
                {
                    plan.subtitle && (
                        <p
                            class="plan-subtitle body-text"
                            style="margin-top: 8px;"
                        >
                            {plan.subtitle}
                        </p>
                    )
                }
            </div>

            <!-- Body -->
            <div class="plan-body">
                {
                    plan.description && (
                        <p class="plan-lead body-text">{plan.description}</p>
                    )
                }

                {
                    benefitsList.length > 0 && (
                        <div class="benefits-module">
                            <h3 class="benefits-label">{t.benefitsLabel}</h3>
                            <ul class="benefits-list">
                                {benefitsList.map((benefit) => (
                                    <li>{benefit}</li>
                                ))}
                            </ul>
                        </div>
                    )
                }
            </div>

            <!-- Footer -->
            <footer class="plan-footer">
                <div class="button-group">
                    <CTAButton
                        href="https://apps.apple.com/app/id6748626498"
                        label={labels.openApp}
                        variant="solid"
                        size="md"
                    />

                    <CTAButton
                        href={finalBrowseLink}
                        label={labels.browse}
                        variant="soft"
                        size="md"
                    />
                </div>
            </footer>
        </article>
    </div>
</Site>

<style>
    .content-shell {
        max-width: 760px; /* Aligned container geometry to match dynamic content modules */
        margin: 0 auto;
        padding: 40px 24px 80px;
    }

    .plan-card {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    /* --- NAV --- */
    .plan-nav {
        display: flex;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-muted);
        transition: all 0.2s ease;
    }

    .back-link:hover {
        color: var(--primary);
        transform: translateX(-2px);
    }

    /* --- HERO IMAGE --- */
    .image-hero {
        margin-top: 4px;
    }

    .image-frame {
        width: 100%;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        background: var(--bg-sub);
    }

    .image-frame img {
        width: 100%;
        aspect-ratio: 16 / 10; /* Clean cinematic look for desktop layouts */
        max-height: 420px; /* Prevents it from scaling too massive on ultra-wide desktop monitors */
        object-fit: cover;
        display: block;
        transition: transform 0.6s ease;
    }

    .image-frame:hover img {
        transform: scale(1.02);
    }

    /* --- TITLE SECTION --- */
    .plan-header {
        width: 100%;
        text-align: left;
    }

    .plan-title {
        font-size: clamp(2rem, 4vw, 2.75rem);
        text-align: left;
    }

    .plan-subtitle {
        color: var(--text-muted);
        text-align: left;
    }

    /* --- BODY --- */
    .plan-body {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 28px;
    }

    .plan-lead {
        color: var(--text-main);
        text-align: left;
    }

    /* --- BENEFITS MODULE --- */
    .benefits-module {
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 28px;
        box-shadow: var(--shadow);
        text-align: left;
    }

    .benefits-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: var(--primary);
        margin-bottom: 16px;
        font-weight: var(--fw-bold);
        letter-spacing: 0.05em;
    }

    .benefits-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .benefits-list li {
        font-size: 1.05rem;
        line-height: 1.6;
        color: var(--text-main);
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

    .benefits-list li::before {
        content: "✦";
        color: var(--primary);
        font-size: 0.85rem;
        margin-top: 4px;
        flex-shrink: 0;
    }

    /* --- FOOTER / CTA --- */
    .plan-footer {
        margin-top: 16px;
        padding-top: 32px;
        border-top: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 20px;
        text-align: left;
    }

    .button-group {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        justify-content: flex-start;
    }

    @media (max-width: 600px) {
        .content-shell {
            padding: 24px 16px 60px;
        }

        .image-frame img {
            aspect-ratio: 16 / 11;
            max-height: 250px;
        }

        .plan-title {
            font-size: 1.8rem;
        }

        .plan-lead {
            font-size: 1.05rem;
        }
    }
</style>
