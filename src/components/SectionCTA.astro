---
const { href, labelEn, labelHi, class: className } = Astro.props;

const currentLang = Astro.currentLocale || "en";
const label = currentLang === "hi" ? labelHi : labelEn;

const getLink = (path: string) => {
    if (currentLang === "en") return path;
    return path === "/" ? "/hi" : `/hi${path}`;
};
---

<a href={getLink(href)} class={`cta-link ${className || ""}`}>
    <div class="cta-glow"></div>

    <div class="cta-label-container">
        <span class="cta-text">{label}</span>
    </div>

    <div class="icon-circle">
        <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
    </div>
</a>

<style>
    .cta-link {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: 40px;
        padding: 12px 28px;
        background: var(--primary);
        color: var(--primary-fg);
        border-radius: 99px;
        font-weight: 750;
        font-size: 1.1rem;
        letter-spacing: -0.01em;
        text-decoration: none;
        transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
        border: 1px solid rgba(255, 255, 255, 0.1);
        isolation: isolate;
        /* Ensure the button doesn't get ridiculously wide on small screens */
        max-width: 100%;
        overflow: hidden;
    }

    /* Logic for Ellipsis */
    .cta-label-container {
        flex: 1;
        min-width: 0; /* Allows container to shrink below content size */
        display: flex;
    }

    .cta-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
        width: 100%;
    }

    /* High-end ambient glow */
    .cta-glow {
        position: absolute;
        inset: 0;
        border-radius: 99px;
        background: linear-gradient(90deg, var(--primary), #a855f7);
        filter: blur(20px);
        opacity: 0;
        z-index: -1;
        transition:
            opacity 0.5s ease,
            transform 0.5s ease;
        transform: scale(0.8);
    }

    .icon-circle {
        display: flex;
        flex-shrink: 0; /* Prevents arrow from squishing */
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 50%;
        transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    }

    .cta-link svg {
        width: 16px;
        height: 16px;
        stroke: var(--primary-fg);
        transition: transform 0.5s ease;
    }

    /* --- HOVER EFFECTS --- */
    .cta-link:hover {
        transform: translateY(-4px);
        background: color-mix(in srgb, var(--primary), white 10%);
        box-shadow:
            0 20px 40px rgba(0, 0, 0, 0.1),
            inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    .cta-link:hover .cta-glow {
        opacity: 0.6;
        transform: scale(1.1);
    }

    .cta-link:hover .icon-circle {
        background: var(--primary-fg);
        transform: scale(1.1);
    }

    .cta-link:hover svg {
        stroke: var(--primary);
        transform: translateX(2px);
    }

    /* --- MOBILE OPTIMIZATIONS --- */
    @media (max-width: 768px) {
        .cta-link {
            padding: 10px 20px;
            font-size: 1rem;
            margin-top: 24px;
            /* Force button to stay manageable on mobile */
            max-width: 260px;
        }

        .icon-circle {
            width: 28px;
            height: 28px;
        }
    }

    /* --- HINDI SPECIFIC FIXES --- */
    :global([lang="hi"]) .cta-text {
        line-height: 1.5; /* Essential for Hindi matras not to get clipped */
        font-weight: 700;
        font-size: 0.95em; /* Hindi characters are naturally larger */
    }
</style>
