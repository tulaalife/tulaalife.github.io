---
const { href, labelEn, labelHi, class: className } = Astro.props;

const currentLang = Astro.currentLocale || "en";
const label = currentLang === "hi" ? labelHi : labelEn;

const getLink = (path: string) => {
    if (currentLang === "en") return path;
    return path === "/" ? "/hi" : `/hi${path}`;
};
---

<a href={getLink(href)} class={`cta-link ${className || ""}`}>
    <div class="cta-glow"></div>

    <span class="cta-text">{label}</span>

    <div class="icon-circle">
        <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
    </div>
</a>

<style>
    .cta-link {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 16px;
        margin-top: 40px;
        /* Increased padding for desktop presence */
        padding: 14px 32px;
        background: var(--primary);
        color: var(--primary-fg);
        border-radius: 99px;
        font-weight: 750; /* Using your bold weight */
        font-size: 1.15rem;
        letter-spacing: -0.01em;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        border: 1px solid color-mix(in srgb, var(--primary), white 20%);
        overflow: visible; /* To allow glow to show */
        isolation: isolate;
    }

    /* Subtle glow behind the button */
    .cta-glow {
        position: absolute;
        inset: 0;
        border-radius: 99px;
        background: var(--primary);
        filter: blur(15px);
        opacity: 0;
        z-index: -1;
        transition: opacity 0.4s ease;
    }

    /* Small circle around the arrow for premium feel */
    .icon-circle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        background: color-mix(in srgb, var(--primary-fg), transparent 85%);
        border-radius: 50%;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .cta-link svg {
        width: 14px;
        height: 14px;
        stroke: var(--primary-fg);
    }

    /* Hover States */
    .cta-link:hover {
        transform: translateY(-3px) scale(1.03);
        background: color-mix(in srgb, var(--primary), white 5%);
        box-shadow:
            0 10px 30px color-mix(in srgb, var(--primary), transparent 60%),
            inset 0 1px 1px
                color-mix(in srgb, var(--primary-fg), transparent 80%);
    }

    .cta-link:hover .cta-glow {
        opacity: 0.4;
    }

    .cta-link:hover .icon-circle {
        transform: translateX(4px) scale(1.1);
        background: color-mix(in srgb, var(--primary-fg), transparent 75%);
    }

    /* Active/Tap state */
    .cta-link:active {
        transform: translateY(-1px) scale(0.98);
    }

    /* Support for Hindi font rendering */
    :global([lang="hi"]) .cta-text {
        line-height: 1;
        padding-bottom: 4px;
        font-weight: 700;
    }

    @media (max-width: 768px) {
        .cta-link {
            margin-top: 28px;
            padding: 12px 24px;
            font-size: 1.05rem;
            gap: 12px;
        }

        .icon-circle {
            width: 24px;
            height: 24px;
        }

        .cta-glow {
            display: none; /* Keep mobile clean */
        }
    }
</style>
