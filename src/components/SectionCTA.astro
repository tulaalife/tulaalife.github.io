---
// src/components/SectionCTA.astro
const { href, labelEn, labelHi, class: className } = Astro.props;

const currentLang = Astro.currentLocale || "en";
const label = currentLang === "hi" ? labelHi : labelEn;

const getLink = (path: string) => {
    if (currentLang === "en") return path;
    if (path === "/") return "/hi";
    if (path.startsWith("/hi/") || path === "/hi") return path;
    return `/hi${path}`;
};
---

<a href={getLink(href)} class:list={["cta-link", className]}>
    <div class="cta-shimmer"></div>

    <div class="cta-label-container">
        <span class="cta-text">{label}</span>
    </div>

    <div class="icon-circle">
        <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
    </div>
</a>

<style>
    .cta-link {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-top: 40px;
        padding: 14px 32px;
        background: var(--primary);
        color: oklch(
            100% 0 0
        ); /* Force crisp white text on primary background fill */
        border-radius: 99px;
        font-family: var(--font-sans-en);
        font-weight: var(--fw-bold);
        font-size: 1.1rem;
        letter-spacing: -0.015em;
        text-decoration: none;
        box-shadow: var(--shadow);
        border: 1px solid rgba(255, 255, 255, 0.15);
        isolation: isolate;
        overflow: hidden;
        width: fit-content;
        max-width: 100%;
        will-change: transform;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    :global(:lang(hi)) .cta-link {
        font-family: var(--font-sans-hi);
        font-weight: 600;
        letter-spacing: normal;
    }

    .cta-label-container {
        flex: 1;
        min-width: 0;
        display: flex;
        align-items: center;
    }

    .cta-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
        width: 100%;
        line-height: 1.2;
    }

    :global(:lang(hi)) .cta-text {
        line-height: 1.4;
        font-size: 1.05rem;
    }

    /* 🌟 Smooth, high-performance specular shine sheen effect */
    .cta-shimmer {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            90deg,
            rgba(255, 255, 255, 0) 0%,
            rgba(255, 255, 255, 0.2) 50%,
            rgba(255, 255, 255, 0) 100%
        );
        transform: translateX(-100%) skewX(-15deg);
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 1;
    }

    .icon-circle {
        display: flex;
        flex-shrink: 0;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 50%;
        z-index: 2;
        transition:
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            background-color 0.3s ease;
    }

    .cta-link svg {
        width: 14px;
        height: 14px;
        stroke: oklch(100% 0 0);
        transition:
            stroke 0.3s ease,
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* --- INTERACTIONS --- */
    .cta-link:hover {
        transform: translateY(-3px);
    }

    .cta-link:hover .cta-shimmer {
        transform: translateX(100%) skewX(-15deg);
    }

    .cta-link:hover .icon-circle {
        background: oklch(100% 0 0);
        transform: scale(1.05);
    }

    .cta-link:hover svg {
        stroke: var(--primary);
        transform: translateX(1px);
    }

    .cta-link:active {
        transform: translateY(-1px) scale(0.98);
    }

    /* --- RESPONSIVE OPTIMIZATIONS --- */
    @media (max-width: 768px) {
        .cta-link {
            padding: 12px 24px;
            font-size: 1rem;
            margin-top: 24px;
            gap: 12px;
        }

        :global(:lang(hi)) .cta-link {
            padding-top: 13px;
            padding-bottom: 11px;
        }

        .icon-circle {
            width: 26px;
            height: 26px;
        }

        .cta-link svg {
            width: 12px;
            height: 12px;
        }
    }
</style>
