---
import Site from "../layouts/Site.astro";
import faqData from "../data/faq.json";

interface Props {
    lang: "en" | "hi";
    title: string;
    canonicalPath: string;
}

const { lang, title, canonicalPath } = Astro.props;
const faqs = faqData[lang] || faqData.en;

const disclaimer = {
    en: {
        title: "Medical Disclaimer",
        text: "Tulaa is for wellness and education only. It is not a substitute for professional medical advice, diagnosis, or treatment. Consult your doctor before starting any new routine.",
    },
    hi: {
        title: "मेडिकल डिस्क्लेमर",
        text: "Tulaa केवल वेलनेस और शिक्षा के लिए है। यह मेडिकल सलाह या उपचार का विकल्प नहीं है। कोई भी नया रूटीन शुरू करने से पहले अपने डॉक्टर से सलाह लें।",
    },
};

const d = disclaimer[lang] || disclaimer.en;

const motivation = {
    en: {
        badge: "OUR VISION",
        text: "Tulaa was born from a simple belief: <strong>Wellness shouldn't come at the cost of your privacy.</strong> We built this as a 100% offline sanctuary to bridge the gap between ancient yoga therapy and modern digital freedom. No accounts, no tracking—just authentic healing.",
    },
    hi: {
        badge: "हमारा विजन",
        text: "तुला (Tulaa) की शुरुआत एक सरल विश्वास के साथ हुई थी: <strong>वेलनेस के लिए आपकी प्राइवेसी से समझौता नहीं होना चाहिए।</strong> हमने इसे प्राचीन योग थेरेपी और आधुनिक डिजिटल स्वतंत्रता के बीच एक सेतु (bridge) के रूप में बनाया है। कोई अकाउंट नहीं, कोई ट्रैकिंग नहीं—बस शुद्ध स्वास्थ्य और शांति।",
    },
};

const m = motivation[lang] || motivation.en;
---

<Site
    title={`${title} · Tulaa`}
    canonicalPath={canonicalPath}
    hasTranslation={true}
>
    <div class="faq-container">
        <div class="faq-hero">
            <h1 class="page-title">{title}</h1>
            <span class="philosophy-badge">{m.badge}</span>
            <p class="hero-text" set:html={m.text} />
        </div>

        <div class="faq-list">
            {
                faqs.map((item) => (
                    <details class="faq-item">
                        <summary class="faq-question">
                            <span>{item.question}</span>
                            <div class="icon-wrapper">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="feather feather-chevron-down"
                                >
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </div>
                        </summary>
                        <div class="faq-answer">
                            <div class="answer-content">
                                <p>{item.answer}</p>
                            </div>
                        </div>
                    </details>
                ))
            }
        </div>

        <footer class="medical-disclaimer">
            <div class="disclaimer-badge">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m12 14 4-4"></path><path d="m16 14-4-4"
                    ></path><path d="m8 14 4-4"></path><path d="m12 14-4-4"
                    ></path><rect width="20" height="14" x="2" y="6" rx="2"
                    ></rect><path d="M6 6V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"
                    ></path></svg
                >
                {d.title}
            </div>
            <p class="disclaimer-text">{d.text}</p>
        </footer>
    </div>
</Site>

<style>
    .faq-container {
        max-width: 720px; /* Narrower for better readability */
        margin: 0 auto;
        padding: 80px 24px 120px;
    }

    /* --- Hero/Motivation Combined --- */
    .faq-hero {
        text-align: center;
        margin-bottom: 64px;
    }

    .philosophy-badge {
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.15em;
        color: var(--primary);
        text-transform: uppercase;
        display: inline-block;
        margin-bottom: 16px;
    }

    .page-title {
        font-size: clamp(2.5rem, 8vw, 3.5rem);
        letter-spacing: -0.04em;
        font-weight: 850;
        line-height: 1.1;
        margin-bottom: 24px;
        color: var(--text-main);
    }

    .hero-text {
        font-size: 1.15rem;
        line-height: 1.7;
        color: var(--text-muted);
        max-width: 600px;
        margin: 0 auto;
    }

    /* --- Modern FAQ List --- */
    .faq-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .faq-item {
        background: var(--bg-sub);
        border: 1px solid var(--border-light);
        border-radius: 24px;
        transition: all 0.3s ease;
    }

    .faq-item[open] {
        background: var(--bg-main);
        border-color: var(--primary);
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
    }

    .faq-question {
        padding: 24px 32px;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        font-weight: 600;
        font-size: 1.1rem;
        color: var(--text-main);
        user-select: none;
    }

    .faq-question::-webkit-details-marker {
        display: none;
    }

    .icon-wrapper {
        color: var(--primary);
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: flex;
        align-items: center;
        justify-content: center;
        background: color-mix(in srgb, var(--primary), transparent 92%);
        padding: 8px;
        border-radius: 50%;
    }

    .faq-item[open] .icon-wrapper {
        transform: rotate(180deg);
        background: var(--primary);
        color: white;
    }

    .faq-answer {
        overflow: hidden;
    }

    .answer-content {
        padding: 0 32px 32px;
        color: var(--text-muted);
        line-height: 1.8;
        font-size: 1.05rem;
    }

    /* --- Disclaimer --- */
    .medical-disclaimer {
        margin-top: 100px;
        padding: 40px;
        background: var(--bg-sub);
        border-radius: 32px;
        border: 1px solid var(--border-light);
        text-align: center;
    }

    .disclaimer-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 16px;
        background: color-mix(in srgb, var(--primary), transparent 90%);
        color: var(--primary);
        font-size: 0.7rem;
        font-weight: 800;
        border-radius: 100px;
        margin-bottom: 16px;
    }

    .disclaimer-text {
        font-size: 0.95rem;
        color: var(--text-muted);
        max-width: 500px;
        margin: 0 auto;
    }

    @media (max-width: 768px) {
        .faq-container {
            padding: 60px 20px;
        }
        .page-title {
            font-size: 2.2rem;
        }
        .faq-question {
            padding: 20px 24px;
            font-size: 1rem;
        }
        .answer-content {
            padding: 0 24px 24px;
        }
    }
</style>
