---
import SectionCTA from "../SectionCTA.astro";
import {
    YOGA_UI,
    CATEGORY_MAP,
    type SupportedLang,
} from "../../utils/ui-strings";
import { yogaPlans } from "../../data/generated";

const currentLang = (Astro.currentLocale || "en") as SupportedLang;
const t = YOGA_UI[currentLang] || YOGA_UI.en;

const displayPlans = yogaPlans
    .filter((p) => p.language === currentLang)
    .slice(0, 8);
---

<section class="scroll-section section-yoga">
    <div class="container animate-on-scroll">
        <div class="header-row">
            <!-- Driven through common layout system utility section-header-left -->
            <div class="section-header-left header-text">
                <h2 class="section-title">
                    <span class="title-main">{t.heroTitleTop}</span>
                    <br />
                    <span class="text-gradient">{t.heroTitleBottom}</span>
                </h2>
                <p class="body-text" style="margin-top: 8px;">{t.heroBody}</p>
            </div>

            <div class="desktop-cta hidden-mobile">
                <SectionCTA
                    href={`/${currentLang}/yoga`}
                    labelEn="Explore All Plans"
                    labelHi="सभी प्लान देखें"
                />
            </div>
        </div>

        <!-- Filter Navigation -->
        <div class="filter-container animate-on-scroll delay-1">
            <span class="filter-label hidden-mobile">{t.filterLabel}</span>
            <div class="filter-scroll">
                <button class="filter-btn active" data-filter="all"
                    >{t.filterAll}</button
                >
                <button class="filter-btn" data-filter="general"
                    >{t.filterGeneral}</button
                >
                <button class="filter-btn" data-filter="womens"
                    >{t.filterWomens}</button
                >
                <button class="filter-btn" data-filter="seniors"
                    >{t.filterSeniors}</button
                >
                <button class="filter-btn" data-filter="medical"
                    >{t.filterMedical}</button
                >
            </div>
        </div>

        <!-- Horizontal Plan Carousel -->
        <div class="carousel-wrapper animate-on-scroll delay-2">
            <div class="carousel-track" id="featured-plans-track">
                {
                    displayPlans.map((p) => (
                        <a
                            href={`/${currentLang}/yoga/${p.slug}`}
                            class="carousel-card"
                            data-goals={p.goals?.join(",")}
                        >
                            <div class="card-image">
                                <img
                                    src={p.image}
                                    alt={p.title}
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                            <div class="card-content">
                                <h3 class="card-title">{p.title}</h3>
                                <p class="card-desc">{p.subtitle}</p>
                                <div class="card-footer">
                                    <span class="view-link">{t.view}</span>
                                    <span class="icon">→</span>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>

        <div class="mobile-cta animate-on-scroll delay-2">
            <SectionCTA
                href={`/${currentLang}/yoga`}
                labelEn="Explore All Plans"
                labelHi="सभी प्लान देखें"
            />
        </div>
    </div>
</section>

<script is:inline define:vars={{ CATEGORY_MAP }}>
    document.addEventListener("astro:page-load", () => {
        const filterBtns = document.querySelectorAll(".filter-btn");
        const track = document.getElementById("featured-plans-track");
        if (!track || filterBtns.length === 0) return;

        const cards = Array.from(track.querySelectorAll(".carousel-card"));

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                filterBtns.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                const filterId = btn.getAttribute("data-filter");

                cards.forEach((card) => {
                    if (filterId === "all") {
                        card.style.display = "flex";
                        setTimeout(() => (card.style.opacity = "1"), 10);
                        return;
                    }

                    const targetGoals = CATEGORY_MAP[filterId] || [];
                    const itemGoals = (
                        card.getAttribute("data-goals") || ""
                    ).split(",");
                    const isMatch = targetGoals.some((goal) =>
                        itemGoals.includes(goal),
                    );

                    if (isMatch) {
                        card.style.display = "flex";
                        setTimeout(() => (card.style.opacity = "1"), 10);
                    } else {
                        card.style.opacity = "0";
                        setTimeout(() => (card.style.display = "none"), 300);
                    }
                });

                track.scrollTo({ left: 0, behavior: "smooth" });
            });
        });
    });
</script>

<style>
    .section-yoga {
        width: 100%;
        background-color: var(--bg-main);
        display: flex;
        align-items: center;
    }

    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 16px;
        width: 100%;
    }

    .header-text {
        max-width: 600px;
    }

    .section-title {
        font-size: clamp(2.2rem, 4vw, 3.2rem);
    }

    .title-main {
        color: var(--text-main);
    }

    /* --- FILTER NAVIGATION --- */
    .filter-container {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
        padding-bottom: 4px;
    }

    .filter-label {
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.95rem;
        white-space: nowrap;
    }

    .filter-scroll {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
        padding: 4px 4px 4px 0;
    }

    .filter-scroll::-webkit-scrollbar {
        display: none;
    }

    .filter-btn {
        background: var(--bg-sub);
        border: 1px solid var(--border);
        color: var(--text-main);
        padding: 6px 16px;
        border-radius: 99px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.25s ease;
    }

    .filter-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
    }

    .filter-btn.active {
        background: var(--primary);
        color: #fff;
        border-color: var(--primary);
        box-shadow: var(--shadow);
    }

    /* --- HORIZONTAL CAROUSEL --- */
    .carousel-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: 16px;
    }

    .carousel-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 80px;
        height: 100%;
        pointer-events: none;
        z-index: 5;
    }

    html[data-theme="light"] .carousel-wrapper::after,
    html[data-theme="dark"] .carousel-wrapper::after {
        background: linear-gradient(
            to left,
            var(--bg-main) 0%,
            transparent 100%
        );
    }

    .carousel-track {
        display: flex;
        gap: 20px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-padding-left: 0;
        padding-bottom: 16px;
        scrollbar-width: none;
    }

    .carousel-track::-webkit-scrollbar {
        display: none;
    }

    .carousel-card {
        scroll-snap-align: start;
        flex: 0 0 300px;
        display: flex;
        flex-direction: column;
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease,
            opacity 0.3s ease;
        height: 100%;
    }

    .carousel-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
        border-color: var(--primary);
    }

    .card-image {
        position: relative;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .carousel-card:hover .card-image img {
        transform: scale(1.03);
    }

    .card-content {
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-title {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 4px;
        line-height: 1.3;
    }

    .card-desc {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.4;
        margin-bottom: 12px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex-grow: 1;
    }

    .card-footer {
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
        color: var(--primary);
        font-size: 0.9rem;
    }

    .mobile-cta {
        display: none;
    }

    @media (max-width: 768px) {
        .header-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }

        .hidden-mobile {
            display: none;
        }

        .filter-container {
            margin-bottom: 16px;
        }

        .carousel-card {
            flex: 0 0 260px;
        }

        .carousel-wrapper::after {
            width: 40px;
        }

        .mobile-cta {
            display: flex;
            justify-content: center;
            margin-top: 8px;
        }
    }
</style>
