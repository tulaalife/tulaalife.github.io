---
// 1. Get current language
const currentLang = Astro.currentLocale || "en";

// 2. Dictionary for Yoga Features content
const ui = {
    en: {
        baseImg: "yoga-plans-collage",
        imgAlt: "Tulaa Yoga Plans Interface",
        titleTop: "Yoga for Every Body,",
        titleBottom: "At Every Stage.",
        bodyText:
            "From pregnancy to your golden years, Tulaa adapts to you. Our research-backed plans are designed for real bodies, real pain, and real life.",
        features: [
            {
                id: "office",
                title: "For the Office Worker",
                desc: 'Instant relief for "Tech Neck," Eye Strain, and Lower Back pain.',
                icon: "💻",
                color: "rgba(99, 102, 241, 0.15)",
            },
            {
                id: "seniors",
                title: "For Seniors & Beginners",
                desc: "Gentle Chair Yoga, Arthritis care, and Balance improvement routines.",
                icon: "🪑",
                color: "rgba(34, 197, 94, 0.15)",
            },
            {
                id: "chronic",
                title: "For Chronic Conditions",
                desc: "Scientific management for PCOS, Diabetes, Thyroid, and Blood Pressure.",
                icon: "🔬",
                iconColor: "rgba(236, 72, 153, 0.15)",
            },
        ],
    },
    hi: {
        baseImg: "yoga-plans-collage-hi",
        imgAlt: "योग प्लान इंटरफेस",
        titleTop: "हर शरीर के लिए योग,",
        titleBottom: "जीवन के हर पड़ाव पर।",
        bodyText:
            "प्रेग्नेंसी से लेकर वरिष्ठ आयु तक, Tulaa आपकी ज़रूरतों के अनुसार ढलता है। हमारे रिसर्च-आधारित प्लान असली शरीर और असली दर्द के लिए हैं।",
        features: [
            {
                id: "office",
                title: "ऑफ़िस वर्कर्स के लिए",
                desc: "'टेक नेक', आंखों के तनाव और कमर दर्द से तुरंत राहत।",
                icon: "💻",
                color: "rgba(99, 102, 241, 0.15)",
            },
            {
                id: "seniors",
                title: "बुजुर्गों के लिए",
                desc: "चेयर योगा, गठिया (Arthritis) की देखभाल और सुरक्षित रूटीन।",
                icon: "🪑",
                color: "rgba(34, 197, 94, 0.15)",
            },
            {
                id: "chronic",
                title: "दीर्घकालिक रोगों के लिए",
                desc: "PCOS, डायबिटीज और थायराइड के लिए वैज्ञानिक योग सहायता।",
                icon: "🔬",
                color: "rgba(236, 72, 153, 0.15)",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const isHindi = currentLang === "hi";

const mobileImg = `/images/mobile/${t.baseImg}.webp`;
const desktopImg = `/images/desktop/${t.baseImg}.webp`;
---

<section class="section section-yoga">
    <div class="container grid-layout reverse-mobile">
        <div class="visual-col">
            <picture>
                <source srcset={mobileImg} media="(max-width: 767px)" />
                <img
                    src={desktopImg}
                    alt={t.imgAlt}
                    class="feature-img"
                    width="600"
                    height="495"
                    loading="lazy"
                    decoding="async"
                />
            </picture>
        </div>

        <div class="text-col">
            <h2 class={`section-title ${isHindi ? "is-hindi" : ""}`}>
                {t.titleTop}<br />
                <span class="text-gradient">{t.titleBottom}</span>
            </h2>
            <p class="body-text">{t.bodyText}</p>

            <div class="feature-list">
                {
                    t.features.map((feature) => (
                        <div
                            class="feature-card"
                            style={`--card-accent: ${feature.color}`}
                        >
                            <div class="card-content">
                                <strong>{feature.title}</strong>
                                <p>{feature.desc}</p>
                            </div>
                            <span class="bg-icon" aria-hidden="true">
                                {feature.icon}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    .section {
        padding: 100px 0;
        overflow: hidden;
    }
    .grid-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .section-title {
        font-size: clamp(2.6rem, 4vw, 3.5rem);
        line-height: 1.2;
        font-weight: 800;
        margin-bottom: 24px;
        letter-spacing: -0.02em;
    }

    .section-title.is-hindi {
        line-height: 1.4;
        font-size: clamp(2.2rem, 3.8vw, 3.2rem);
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--primary), #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
    }

    .body-text {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--text-muted);
        margin-bottom: 32px;
        max-width: 520px;
    }

    .feature-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
    }

    /* CARD STYLING - Reactive to Theme Variables */
    .feature-card {
        position: relative;
        overflow: hidden;
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--bg-main), white 5%) 0%,
            var(--card-accent) 100%
        );
        backdrop-filter: blur(10px);
        padding: 24px;
        border-radius: 24px;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        display: flex;
        align-items: center;
        z-index: 1;
    }

    :root[data-theme="dark"] .feature-card {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.05) 0%,
            var(--card-accent) 100%
        );
    }

    .feature-card:hover {
        transform: translateX(8px);
    }

    .card-content {
        position: relative;
        z-index: 2;
        padding-right: 60px;
    }

    .feature-card strong {
        display: block;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 4px;
    }

    .feature-card p {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.5;
    }

    .bg-icon {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%) rotate(10deg);
        font-size: 3.5rem;
        opacity: 0.12;
        filter: blur(0.5px);
        pointer-events: none;
        transition:
            transform 0.4s ease,
            opacity 0.4s ease;
    }

    .feature-card:hover .bg-icon {
        transform: translateY(-50%) rotate(0deg) scale(1.1);
        opacity: 0.2;
    }

    .feature-img {
        width: 100%;
        height: auto;
        filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.12));
    }

    :root[data-theme="dark"] .feature-img {
        filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.4));
    }

    @media (max-width: 768px) {
        .grid-layout {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 40px;
        }
        .reverse-mobile {
            display: flex;
            flex-direction: column-reverse;
        }
        .text-col {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .feature-list {
            text-align: left;
        }
        .feature-card:hover {
            transform: translateY(-5px);
        }
        .section-title {
            font-size: 2.2rem;
        }
    }
</style>
