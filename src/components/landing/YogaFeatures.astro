---
// src/components/YogaSection.astro
import SectionCTA from "../SectionCTA.astro";
import {
    YOGA_UI,
    CATEGORY_MAP,
    type SupportedLang,
} from "../../utils/ui-strings";
import { yogaPlans } from "../../data/generated";

const currentLang = (Astro.currentLocale || "en") as SupportedLang;
const t = YOGA_UI[currentLang] || YOGA_UI.en;

const displayPlans = yogaPlans
    .filter((p) => p.language === currentLang)
    .slice(0, 8);
---

<section class="scroll-section section-yoga">
    <div class="content-wrapper">
        <!-- 1. Pure Header Container Grid Alignment Module -->
        <div class="container">
            <div class="section-header-left text-col animate-on-scroll">
                <h2 class="section-title">
                    <span class="title-main">{t.heroTitleTop}</span>
                    <br />
                    <span class="text-gradient">{t.heroTitleBottom}</span>
                </h2>
                <p class="body-text">{t.heroBody}</p>
            </div>
        </div>

        <!-- 2. Filter Navigation Control Module -->
        <div class="container filter-container animate-on-scroll delay-1">
            <span class="filter-label hidden-mobile">{t.filterLabel}</span>
            <div class="filter-scroll">
                <button class="filter-btn active" data-filter="all"
                    >{t.filterAll}</button
                >
                <button class="filter-btn" data-filter="general"
                    >{t.filterGeneral}</button
                >
                <button class="filter-btn" data-filter="womens"
                    >{t.filterWomens}</button
                >
                <button class="filter-btn" data-filter="seniors"
                    >{t.filterSeniors}</button
                >
                <button class="filter-btn" data-filter="medical"
                    >{t.filterMedical}</button
                >
            </div>
        </div>

        <!-- 3. Full Width Horizontal Carousel Container Track -->
        <div class="container carousel-wrapper animate-on-scroll delay-2">
            <div class="carousel-track" id="featured-plans-track">
                {
                    displayPlans.map((p) => (
                        <a
                            href={`/${currentLang}/yoga/${p.slug}`}
                            class="carousel-card"
                            data-goals={p.goals?.join(",")}
                        >
                            <div class="card-image">
                                <img
                                    src={p.image}
                                    alt={p.title}
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                            <div class="card-content">
                                <h3 class="card-title">{p.title}</h3>
                                <p class="card-desc">{p.subtitle}</p>
                                <div class="card-footer">
                                    <span class="view-link">{t.view}</span>
                                    <span class="icon">→</span>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>

        <!-- 4. Left-Aligned Unified Secondary Button Hook -->
        <div class="container cta-wrapper animate-on-scroll delay-2">
            <SectionCTA
                href={`/${currentLang}/yoga`}
                labelEn="Explore All Plans"
                labelHi="सभी प्लान देखें"
            />
        </div>
    </div>
</section>

<script is:inline define:vars={{ CATEGORY_MAP }}>
    document.addEventListener("astro:page-load", () => {
        const filterBtns = document.querySelectorAll(".filter-btn");
        const track = document.getElementById("featured-plans-track");
        if (!track || filterBtns.length === 0) return;

        const cards = Array.from(track.querySelectorAll(".carousel-card"));

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                filterBtns.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                const filterId = btn.getAttribute("data-filter");

                cards.forEach((card) => {
                    if (filterId === "all") {
                        card.style.display = "flex";
                        setTimeout(() => (card.style.opacity = "1"), 10);
                        return;
                    }

                    const targetGoals = CATEGORY_MAP[filterId] || [];
                    const itemGoals = (
                        card.getAttribute("data-goals") || ""
                    ).split(",");
                    const isMatch = targetGoals.some((goal) =>
                        itemGoals.includes(goal),
                    );

                    if (isMatch) {
                        card.style.display = "flex";
                        setTimeout(() => (card.style.opacity = "1"), 10);
                    } else {
                        card.style.opacity = "0";
                        setTimeout(() => (card.style.display = "none"), 300);
                    }
                });

                track.scrollTo({ left: 0, behavior: "smooth" });
            });
        });
    });
</script>

<style>
    .section-yoga {
        width: 100%;
        display: flex;
        align-items: center;
    }

    .content-wrapper {
        display: flex;
        flex-direction: column;
        width: 100%;
        margin: 0 auto;
    }

    .text-col {
        margin-bottom: 3.5rem;
        text-align: left;
        width: 100%;
    }

    .section-title {
        font-size: clamp(3rem, 5vw, 4.2rem);
        letter-spacing: -0.03em;
        line-height: 1.1;
        text-align: left;
    }

    .body-text {
        font-size: 1.25rem;
        color: var(--text-muted);
        max-width: 600px;
        text-align: left;
        line-height: 1.7;
        margin-top: 1.5rem;
    }

    /* --- FILTER NAVIGATION --- */
    .filter-container {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 2.5rem;
        width: 100%;
    }

    .filter-label {
        font-weight: 700;
        color: var(--text-muted);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        white-space: nowrap;
    }

    .filter-scroll {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
        padding: 4px 0;
    }

    .filter-scroll::-webkit-scrollbar {
        display: none;
    }

    .filter-btn {
        background: var(--bg-sub);
        border: 1px solid var(--border);
        color: var(--text-muted);
        padding: 8px 18px;
        border-radius: 99px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .filter-btn:hover {
        border-color: color-mix(in srgb, var(--primary) 40%, var(--border));
        color: var(--text-main);
    }

    .filter-btn.active {
        background: var(--primary);
        color: var(--bg-main);
        border-color: var(--primary);
        box-shadow: none; /* Strip out heavy pixel shadows to sustain minimalism */
    }

    /* --- HORIZONTAL CAROUSEL --- */
    .carousel-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: 3.5rem;
    }

    .carousel-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 100px;
        height: 100%;
        background: linear-gradient(
            to left,
            var(--bg-main) 0%,
            transparent 100%
        );
        pointer-events: none;
        z-index: 5;
    }

    .carousel-track {
        display: flex;
        gap: 24px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        padding-bottom: 20px;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }

    .carousel-track::-webkit-scrollbar {
        display: none;
    }

    .carousel-card {
        scroll-snap-align: start;
        flex: 0 0 310px;
        display: flex;
        flex-direction: column;
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition:
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            box-shadow 0.4s ease,
            border-color 0.4s ease;
        height: 100%;
    }

    .carousel-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow);
        border-color: color-mix(in srgb, var(--primary) 40%, var(--border));
    }

    .card-image {
        position: relative;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .card-content {
        padding: 24px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 6px;
        color: var(--text-main);
        letter-spacing: -0.01em;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 20px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex-grow: 1;
    }

    .card-footer {
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
        color: var(--primary);
        font-size: 0.9rem;
        margin-top: auto;
        letter-spacing: 0.02em;
    }

    .cta-wrapper {
        display: flex;
        justify-content: flex-start;
    }

    @media (max-width: 768px) {
        .text-col {
            margin-bottom: 2.5rem;
        }

        .section-title {
            font-size: clamp(2.6rem, 8vw, 3.4rem);
        }

        .filter-container {
            margin-bottom: 2rem;
            gap: 12px;
        }

        .carousel-card {
            flex: 0 0 270px;
        }

        .carousel-wrapper {
            margin-bottom: 2.5rem;
        }

        .carousel-wrapper::after {
            width: 40px;
        }
    }
</style>
