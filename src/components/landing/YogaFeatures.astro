---
import SectionCTA from "../SectionCTA.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        baseImg: "yoga-plans-collage",
        imgAlt: "Tulaa Yoga Plans Interface",
        titleTop: "Yoga for Every Body,",
        titleBottom: "At Every Stage.",
        bodyText:
            "From pregnancy to your golden years, Tulaa adapts to you. Our research-backed plans are designed for real bodies, real pain, and real life.",
        features: [
            {
                id: "womens",
                title: "Women's Health & Wellness",
                desc: "Specialized care for PCOS, Menstrual comfort, and all Prenatal trimesters.",
                icon: "✨",
                color: "rgba(236, 72, 153, 0.15)",
                link: "/yoga?goal=womens",
            },
            {
                id: "pain",
                title: "Therapeutic Pain Relief",
                desc: "Fix 'Tech Neck', Sciatica, and Lower Back stiffness with targeted flows.",
                icon: "🧘",
                color: "rgba(99, 102, 241, 0.15)",
                link: "/yoga?goal=general",
            },
            {
                id: "seniors",
                title: "Seniors & Gentle Aging",
                desc: "Maintain independence with Chair Yoga, Arthritis care, and Balance routines.",
                icon: "🦯",
                color: "rgba(34, 197, 94, 0.15)",
                link: "/yoga?goal=seniors",
            },
            {
                id: "medical",
                title: "Metabolic & Spine Care",
                desc: "Scientific management for Diabetes, Thyroid, and Scoliosis alignment.",
                icon: "🔬",
                color: "rgba(20, 184, 166, 0.15)",
                link: "/yoga?goal=medical",
            },
        ],
    },
    hi: {
        baseImg: "yoga-plans-collage-hi",
        imgAlt: "योग प्लान इंटरफेस",
        titleTop: "हर शरीर के लिए योग,",
        titleBottom: "जीवन के हर पड़ाव पर।",
        bodyText:
            "प्रेग्नेंसी से लेकर वरिष्ठ आयु तक, Tulaa आपकी ज़रूरतों के अनुसार ढलता है। हमारे रिसर्च-आधारित प्लान असली शरीर और असली दर्द के लिए हैं।",
        features: [
            {
                id: "womens",
                title: "महिला स्वास्थ्य और कल्याण",
                desc: "PCOS, मासिक धर्म में राहत और प्रेगनेंसी के सभी चरणों के लिए विशेष योग।",
                icon: "✨",
                color: "rgba(236, 72, 153, 0.15)",
                link: "/hi/yoga?goal=womens",
            },
            {
                id: "pain",
                title: "दर्द से वैज्ञानिक राहत",
                desc: "'टेक नेक', साइटिका और कमर दर्द के लिए खास तौर पर तैयार रूटीन।",
                icon: "🧘",
                color: "rgba(99, 102, 241, 0.15)",
                link: "/hi/yoga?goal=general",
            },
            {
                id: "seniors",
                title: "बुजुर्गों के लिए सुरक्षित योग",
                desc: "चेयर योगा, गठिया (Arthritis) की देखभाल और संतुलन सुधारने के लिए।",
                icon: "🦯",
                color: "rgba(34, 197, 94, 0.15)",
                link: "/hi/yoga?goal=seniors",
            },
            {
                id: "medical",
                title: "मेटाबॉलिक और स्पाइन केयर",
                desc: "डायबिटीज, थायराइड और रीढ़ की हड्डी की देखभाल के लिए वैज्ञानिक समाधान।",
                icon: "🔬",
                color: "rgba(20, 184, 166, 0.15)",
                link: "/hi/yoga?goal=medical",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const isHindi = currentLang === "hi";

const mobileImg = `/images/mobile/${t.baseImg}.webp`;
const desktopImg = `/images/desktop/${t.baseImg}.webp`;
---

<section class="section section-yoga">
    <div class="container grid-layout">
        <div class="text-col">
            <h2 class={`section-title ${isHindi ? "is-hindi" : ""}`}>
                <span class="title-main">{t.titleTop}</span>
                <br />
                <span class="text-gradient">{t.titleBottom}</span>
            </h2>
            <p class="body-text">{t.bodyText}</p>

            <div class="feature-list-wrapper">
                <div class="feature-list">
                    {
                        t.features.map((feature) => (
                            <a
                                href={feature.link}
                                class="feature-card"
                                style={`--card-accent: ${feature.color}`}
                            >
                                <div class="card-content">
                                    <strong class="card-title">
                                        {feature.title}
                                    </strong>
                                    <p class="card-desc">{feature.desc}</p>
                                </div>
                                <span class="bg-icon" aria-hidden="true">
                                    {feature.icon}
                                </span>
                            </a>
                        ))
                    }
                </div>

                <div class="desktop-cta">
                    <SectionCTA
                        href="/yoga"
                        labelEn="Explore All Yoga Plans"
                        labelHi="सभी योग प्लान देखें"
                    />
                </div>
            </div>
        </div>

        <div class="visual-col">
            <picture>
                <source srcset={mobileImg} media="(max-width: 767px)" />
                <img
                    src={desktopImg}
                    alt={t.imgAlt}
                    class="feature-img"
                    width="600"
                    height="495"
                    loading="lazy"
                    decoding="async"
                />
            </picture>
        </div>

        <div class="mobile-cta">
            <SectionCTA
                href="/yoga"
                labelEn="Explore All Yoga Plans"
                labelHi="सभी योग प्लान देखें"
            />
        </div>
    </div>
</section>

<style>
    .section {
        padding: 100px 0;
        overflow: hidden;
    }
    .grid-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .mobile-cta {
        display: none;
    }

    /* --- TYPOGRAPHY --- */
    .section-title {
        font-size: clamp(2.6rem, 4vw, 3.5rem);
        line-height: 1.15;
        font-weight: 800;
        margin-bottom: 24px;
        letter-spacing: -0.02em;
    }

    .title-main {
        color: var(--text-main);
    }

    .section-title.is-hindi {
        line-height: 1.4;
        font-size: clamp(2.2rem, 3.8vw, 3.2rem);
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--primary), #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
        padding-bottom: 4px;
    }

    .body-text {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--text-muted);
        margin-bottom: 32px;
        max-width: 520px;
    }

    /* --- FEATURE CARDS --- */
    .feature-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
    }

    .feature-card {
        position: relative;
        overflow: hidden;
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--bg-main), white 5%) 0%,
            var(--card-accent) 100%
        );
        backdrop-filter: blur(10px);
        padding: 24px;
        border-radius: 24px;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        display: flex;
        align-items: center;
        z-index: 1;
        text-decoration: none; /* Reset for <a> */
        cursor: pointer;
    }

    :root[data-theme="dark"] .feature-card {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.05) 0%,
            var(--card-accent) 100%
        );
    }

    .feature-card:hover {
        transform: translateX(8px);
        border-color: var(--primary);
    }

    .card-content {
        position: relative;
        z-index: 2;
        padding-right: 60px;
    }

    .card-title {
        display: block;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 4px;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        opacity: 0.85;
        margin: 0;
        line-height: 1.5;
        font-weight: 400;
    }

    .bg-icon {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%) rotate(10deg);
        font-size: 3.5rem;
        opacity: 0.12;
        pointer-events: none;
    }

    /* --- VISUALS --- */
    .feature-img {
        width: 100%;
        height: auto;
        filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.12));
    }

    @media (max-width: 768px) {
        .grid-layout {
            display: flex;
            flex-direction: column;
            text-align: center;
            gap: 32px;
        }

        .text-col {
            display: contents;
        }

        .section-title {
            order: 1;
            margin-bottom: 12px;
        }
        .body-text {
            order: 1;
            margin-bottom: 24px;
        }

        .visual-col {
            order: 2;
            margin-bottom: 10px;
        }

        .feature-list-wrapper {
            order: 3;
            width: 100%;
        }

        .feature-list {
            text-align: left;
        }

        .mobile-cta {
            order: 4;
            display: block;
            margin-top: 8px;
        }

        .desktop-cta {
            display: none;
        }
    }
</style>
