---
// src/components/YogaSection.astro
import SectionCTA from "../SectionCTA.astro";
import {
    YOGA_UI,
    CATEGORY_MAP,
    type SupportedLang,
} from "../../utils/ui-strings";
import { yogaPlans } from "../../data/generated";

const currentLang = (Astro.currentLocale || "en") as SupportedLang;
const t = YOGA_UI[currentLang] || YOGA_UI.en;

const displayPlans = yogaPlans.filter((p) => p.language === currentLang);
---

<section class="scroll-section section-yoga">
    <div class="content-wrapper">
        <div class="container">
            <div class="section-header-left text-col animate-on-scroll">
                <h2 class="section-title">
                    <span class="title-main">{t.heroTitleTop}</span>
                    <br />
                    <span class="text-gradient">{t.heroTitleBottom}</span>
                </h2>
                <p class="body-text">{t.heroBody}</p>
            </div>
        </div>

        <div class="container filter-container animate-on-scroll delay-1">
            <div class="filter-scroll">
                <button class="filter-btn active" data-filter="all"
                    >{t.filterAll}</button
                >
                <button class="filter-btn" data-filter="general"
                    >{t.filterGeneral}</button
                >
                <button class="filter-btn" data-filter="womens"
                    >{t.filterWomens}</button
                >
                <button class="filter-btn" data-filter="seniors"
                    >{t.filterSeniors}</button
                >
                <button class="filter-btn" data-filter="medical"
                    >{t.filterMedical}</button
                >
            </div>
        </div>

        <div class="container carousel-wrapper animate-on-scroll delay-2">
            <div class="carousel-track" id="featured-plans-track">
                {
                    displayPlans.map((p) => (
                        <a
                            href={`/${currentLang}/yoga/${p.slug}`}
                            class="carousel-card premium-gloss-surface"
                            data-goals={p.goals?.join(",")}
                        >
                            <div class="card-image">
                                <img
                                    src={p.image}
                                    alt={p.title}
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                            <div class="card-content">
                                <h3 class="card-title">{p.title}</h3>
                                <div class="card-footer">
                                    <span class="view-link">{t.view}</span>
                                    <span class="icon">→</span>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>

        <div class="container cta-wrapper animate-on-scroll delay-2">
            <SectionCTA
                href={`/${currentLang}/yoga`}
                labelEn="Explore All Plans"
                labelHi="सभी प्लान देखें"
            />
        </div>
    </div>
</section>

<script is:inline define:vars={{ CATEGORY_MAP }}>
    document.addEventListener("astro:page-load", () => {
        const filterBtns = document.querySelectorAll(".filter-btn");
        const track = document.getElementById("featured-plans-track");
        if (!track || filterBtns.length === 0) return;

        const cards = Array.from(track.querySelectorAll(".carousel-card"));

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                filterBtns.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                const filterId = btn.getAttribute("data-filter");

                cards.forEach((card) => {
                    if (filterId === "all") {
                        card.style.display = "flex";
                        setTimeout(() => (card.style.opacity = "1"), 10);
                        return;
                    }

                    const targetGoals = CATEGORY_MAP[filterId] || [];
                    const itemGoals = (
                        card.getAttribute("data-goals") || ""
                    ).split(",");
                    const isMatch = targetGoals.some((goal) =>
                        itemGoals.includes(goal),
                    );

                    if (isMatch) {
                        card.style.display = "flex";
                        setTimeout(() => (card.style.opacity = "1"), 10);
                    } else {
                        card.style.opacity = "0";
                        setTimeout(() => (card.style.display = "none"), 300);
                    }
                });

                track.scrollTo({ left: 0, behavior: "smooth" });
            });
        });
    });
</script>

<style>
    .section-yoga {
        width: 100%;
        display: flex;
        align-items: center;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .content-wrapper {
        display: flex;
        flex-direction: column;
        width: 100%;
        margin: 0 auto;
    }

    .text-col {
        margin-bottom: var(--space-md);
        text-align: left;
        width: 100%;
    }

    .section-title {
        font-size: clamp(2.2rem, 5.5vw, 3.8rem);
        letter-spacing: -0.035em;
        line-height: 1.1;
        text-align: left;
        color: var(--text-main);
    }

    .body-text {
        font-size: clamp(1.05rem, 2vw, 1.2rem);
        color: var(--text-muted);
        max-width: 54ch; /* Restricts long paragraphs for higher reading fidelity */
        text-align: left;
        line-height: 1.6;
        margin-top: var(--space-xs);
    }

    /* --- FILTER NAVIGATION (CLEAN CHIPS) --- */
    .filter-container {
        display: flex;
        align-items: center;
        margin-bottom: var(--space-md);
        width: 100%;
    }

    .filter-scroll {
        display: flex;
        gap: var(--space-xs);
        overflow-x: auto;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
        padding: 4px 0;
    }

    .filter-scroll::-webkit-scrollbar {
        display: none;
    }

    .filter-btn {
        background: var(--bg-sub);
        border: 1px solid var(--border);
        color: var(--text-muted);
        padding: 8px 18px;
        border-radius: 99px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        will-change: transform;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .filter-btn:hover {
        border-color: color-mix(in srgb, var(--primary) 40%, var(--border));
        color: var(--text-main);
    }

    .filter-btn.active {
        background: var(--primary);
        color: oklch(100% 0 0);
        border-color: var(--primary);
    }

    .filter-btn:active {
        transform: scale(0.96);
    }

    /* --- HORIZONTAL CAROUSEL --- */
    .carousel-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: var(--space-md);
    }

    .carousel-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 48px;
        height: 100%;
        background: linear-gradient(
            to left,
            var(--bg-main) 0%,
            transparent 100%
        );
        pointer-events: none;
        z-index: 5;
    }

    .carousel-track {
        display: flex;
        gap: var(--space-md);
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        padding: 6px 0 var(--space-sm) 0;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }

    .carousel-track::-webkit-scrollbar {
        display: none;
    }

    .carousel-card {
        scroll-snap-align: start;
        flex: 0 0 290px;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        height: 100%;
        min-height: 250px;
        border-radius: var(--radius-lg);
        overflow: hidden;
        will-change: transform, opacity;
        transition:
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            opacity 0.3s ease;
    }

    .carousel-card:hover {
        transform: translateY(-4px);
    }

    .carousel-card:active {
        transform: translateY(-2px) scale(0.98);
    }

    .card-image {
        position: relative;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
        background: var(--bg-main);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        will-change: transform;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .carousel-card:hover .card-image img {
        transform: scale(1.02);
    }

    .card-content {
        padding: var(--space-md);
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        flex-grow: 1;
        justify-content: space-between;
    }

    .card-title {
        font-size: 1.2rem;
        font-weight: 750;
        margin: 0;
        color: var(--text-main);
        letter-spacing: -0.015em;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        min-height: calc(1.35em * 2);
    }

    .card-footer {
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
        color: var(--primary);
        font-size: 0.9rem;
        letter-spacing: 0.01em;
        margin-top: auto;
    }

    .icon {
        display: inline-flex;
        align-items: center;
        transform: translateY(-1px);
        transition: transform 0.2s ease;
    }

    .carousel-card:hover .icon {
        transform: translateX(2px) translateY(-1px);
    }

    .cta-wrapper {
        display: flex;
        justify-content: flex-start;
        margin-top: var(--space-xs);
    }

    /* --- GLOBAL LOCALE OPTIMIZATIONS FOR DEVANAGARI --- */
    :lang(hi) .section-title {
        line-height: 1.35;
    }
    :lang(hi) .filter-btn {
        padding-top: 9px;
        padding-bottom: 7px;
    }
    :lang(hi) .card-title {
        line-height: 1.45;
        min-height: calc(1.45em * 2);
    }

    /* --- RESPONSIVE OPTIMIZATIONS FOR SMALL HEIGHT DEVICES --- */
    @media (max-height: 740px) {
        .text-col {
            margin-bottom: var(--space-sm);
        }
        .body-text {
            display: none;
        }
        .carousel-card {
            flex: 0 0 250px;
        }
        .card-content {
            padding: var(--space-sm);
        }
    }
</style>
