---
import SectionCTA from "../SectionCTA.astro";
import { YOGA_UI, type SupportedLang } from "../../utils/ui-strings";

const currentLang = (Astro.currentLocale || "en") as SupportedLang;
const t = YOGA_UI[currentLang] || YOGA_UI.en;
const isHindi = currentLang === "hi";

// Extract feature values into an array for mapping
const featureList = Object.values(t.features);

const mobileImg = `/images/mobile/${t.heroImg}.webp`;
const desktopImg = `/images/desktop/${t.heroImg}.webp`;
---

<section class="scroll-section section-yoga">
    <div class="container grid-layout">
        <div class="text-col animate-on-scroll">
            <h2 class={`section-title ${isHindi ? "is-hindi" : ""}`}>
                <span class="title-main">{t.heroTitleTop}</span>
                <br />
                <span class="text-gradient">{t.heroTitleBottom}</span>
            </h2>
            <p class="body-text">{t.heroBody}</p>

            <div class="feature-list-wrapper">
                <div class="feature-list">
                    {
                        featureList.map((feature) => (
                            <a
                                href={feature.link}
                                class="feature-card"
                                style={`--card-accent: ${feature.color}`}
                            >
                                <div class="card-content">
                                    <strong class="card-title">
                                        {feature.title}
                                    </strong>
                                    <p class="card-desc">{feature.desc}</p>
                                </div>
                                <span class="bg-icon" aria-hidden="true">
                                    {feature.icon}
                                </span>
                            </a>
                        ))
                    }
                </div>

                <div class="desktop-cta">
                    <SectionCTA
                        href="/yoga"
                        labelEn="Explore All Yoga Plans"
                        labelHi="सभी योग प्लान देखें"
                    />
                </div>
            </div>
        </div>

        <div class="visual-col animate-on-scroll delay-1">
            <picture>
                <source srcset={mobileImg} media="(max-width: 767px)" />
                <img
                    src={desktopImg}
                    alt={t.heroImgAlt}
                    class="feature-img"
                    width="600"
                    height="495"
                    loading="lazy"
                    decoding="async"
                />
            </picture>
        </div>

        <div class="mobile-cta animate-on-scroll delay-2">
            <SectionCTA
                href="/yoga"
                labelEn="Explore All Yoga Plans"
                labelHi="सभी योग प्लान देखें"
            />
        </div>
    </div>
</section>

<style>
    .section-yoga {
        width: 100%;
        overflow: hidden;
    }

    .grid-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px; /* Reduced from 80px to save horizontal/vertical space */
        align-items: center;
    }

    .mobile-cta {
        display: none;
    }

    /* --- TYPOGRAPHY --- */
    .section-title {
        font-size: clamp(2.6rem, 4vw, 3.5rem);
        line-height: 1.15;
        font-weight: 800;
        margin-bottom: 20px; /* Reduced from 24px */
        letter-spacing: -0.02em;
    }

    .title-main {
        color: var(--text-main);
    }

    .section-title.is-hindi {
        line-height: 1.4;
        font-size: clamp(2.2rem, 3.8vw, 3.2rem);
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--primary), #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
        padding-bottom: 4px;
    }

    .body-text {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--text-muted);
        margin-bottom: 24px; /* Reduced from 32px */
        max-width: 520px;
    }

    /* --- FEATURE CARDS --- */
    .feature-list {
        display: flex;
        flex-direction: column;
        gap: 12px; /* Reduced from 16px to compress the list height */
        width: 100%;
    }

    .feature-card {
        position: relative;
        overflow: hidden;
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--bg-main), white 5%) 0%,
            var(--card-accent) 100%
        );
        backdrop-filter: blur(10px);
        padding: 20px 24px; /* Slightly reduced top/bottom padding */
        border-radius: 24px;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        display: flex;
        align-items: center;
        z-index: 1;
        text-decoration: none;
        cursor: pointer;
    }

    :root[data-theme="dark"] .feature-card {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.05) 0%,
            var(--card-accent) 100%
        );
    }

    .feature-card:hover {
        transform: translateX(8px);
        border-color: var(--primary);
    }

    .card-content {
        position: relative;
        z-index: 2;
        padding-right: 60px;
    }

    .card-title {
        display: block;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 4px;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        opacity: 0.85;
        margin: 0;
        line-height: 1.5;
        font-weight: 400;
    }

    .bg-icon {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%) rotate(10deg);
        font-size: 3.5rem;
        opacity: 0.12;
        pointer-events: none;
    }

    .desktop-cta {
        margin-top: 24px;
    }

    /* --- VISUALS --- */
    .feature-img {
        width: 100%;
        height: auto;
        max-height: 55dvh; /* CRITICAL: Constrains image to respect viewport */
        object-fit: contain;
        filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.12));
    }

    @media (max-width: 768px) {
        .grid-layout {
            display: flex;
            flex-direction: column;
            text-align: center;
            gap: 32px;
        }

        .text-col {
            display: contents;
        }

        .section-title {
            order: 1;
            margin-bottom: 8px;
        }
        .body-text {
            order: 1;
            margin-bottom: 24px;
        }

        .visual-col {
            order: 2;
            margin-bottom: 8px;
        }

        .feature-list-wrapper {
            order: 3;
            width: 100%;
        }

        .feature-list {
            text-align: left;
        }

        .mobile-cta {
            order: 4;
            display: block;
            margin-top: 16px;
        }

        .desktop-cta {
            display: none;
        }

        .feature-img {
            max-height: 45dvh; /* Stricter on mobile to ensure the list fits */
        }
    }
</style>
