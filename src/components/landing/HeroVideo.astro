---
const currentLang = Astro.currentLocale || "en";

const ui = {
    en: { basePoster: "poster" },
    hi: { basePoster: "poster-hindi" },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;

const mobilePoster = `/images/mobile/${t.basePoster}.webp`;
const desktopPoster = `/images/desktop/${t.basePoster}.webp`;

const videoWebm =
    currentLang === "hi"
        ? "/website-app-demo-hindi.webm"
        : "/website-app-demo.webm";
const videoMp4 =
    currentLang === "hi"
        ? "/website-app-demo-hindi.mp4"
        : "/website-app-demo.mp4";
---

<section class="scroll-section video-section">
    <div class="container visual-centered">
        <div class="visual-backlightstage">
            <div
                class="phone-frame-wrapper animate-on-scroll"
                id="phoneWrapper"
                data-webm={videoWebm}
                data-mp4={videoMp4}
            >
                <div class="video-loader" id="videoLoader"></div>
                <picture>
                    <source media="(min-width: 768px)" srcset={desktopPoster} />
                    <img
                        src={mobilePoster}
                        alt="Tulaa App Preview"
                        class="poster-img"
                        id="posterImg"
                        fetchpriority="high"
                        loading="eager"
                    />
                </picture>
                <video
                    id="heroVideo"
                    class="app-video"
                    loop
                    muted
                    playsinline
                    preload="none"></video>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const wrapper = document.getElementById("phoneWrapper");
        const video = document.getElementById("heroVideo") as HTMLVideoElement;
        const loader = document.getElementById("videoLoader");
        const poster = document.getElementById("posterImg");

        if (!wrapper || !video) return;

        const initVideo = () => {
            const webmSrc = wrapper.getAttribute("data-webm");
            const mp4Src = wrapper.getAttribute("data-mp4");

            if (
                webmSrc &&
                video.querySelectorAll('source[type="video/webm"]').length === 0
            ) {
                const s = document.createElement("source");
                s.src = webmSrc;
                s.type = "video/webm";
                video.appendChild(s);
            }
            if (
                mp4Src &&
                video.querySelectorAll('source[type="video/mp4"]').length === 0
            ) {
                const s = document.createElement("source");
                s.src = mp4Src;
                s.type = "video/mp4";
                video.appendChild(s);
            }

            video.addEventListener(
                "playing",
                () => {
                    video.classList.add("is-playing");
                    if (loader) loader.style.opacity = "0";
                    setTimeout(() => {
                        if (poster)
                            (poster as HTMLElement).style.visibility = "hidden";
                        if (loader) loader.style.display = "none";
                    }, 1000);
                },
                { once: true },
            );

            video.load();
            video.play().catch(() => {
                if (loader) loader.style.display = "none";
            });
        };

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        initVideo();
                        observer.disconnect();
                    }
                });
            },
            { threshold: 0.15 },
        );

        observer.observe(wrapper);

        document.addEventListener("visibilitychange", () => {
            if (document.visibilityState === "visible") {
                video.play().catch(() => {});
            }
        });
    });
</script>

<style>
    .video-section {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .visual-centered {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
    }

    /* Soft ambient backing glow to pop the device canvas out dynamically */
    .visual-backlightstage {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        padding: 2rem 0;
    }

    .visual-backlightstage::before {
        content: "";
        position: absolute;
        width: 500px;
        height: 500px;
        background: radial-gradient(
            circle,
            color-mix(in srgb, var(--primary), transparent 96%) 0%,
            transparent 70%
        );
        z-index: 1;
        pointer-events: none;
    }

    /* Upgraded edge-to-edge hardware frame emulation */
    .phone-frame-wrapper {
        position: relative;
        z-index: 2;
        width: auto;
        height: 72dvh; /* Carefully scoped height scale footprint */
        max-height: 760px;
        aspect-ratio: 540 / 1174;
        background-color: var(--bg-sub);
        border-radius: 40px;

        /* Thin luxury bezel treatment to sustain minimalism */
        border: 1px solid var(--border);
        outline: 8px solid
            color-mix(in srgb, var(--bg-sub) 60%, var(--text-main) 4%);

        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .app-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 10;
    }

    .app-video.is-playing {
        opacity: 1;
    }

    .poster-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        inset: 0;
        z-index: 5;
    }

    .video-loader {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 36px;
        height: 36px;
        border: 2px solid color-mix(in srgb, var(--text-muted), transparent 90%);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        z-index: 6;
        transition: opacity 0.4s ease;
    }

    @media (max-width: 768px) {
        .phone-frame-wrapper {
            height: 62dvh;
            border-radius: 32px;
            outline-width: 6px;
        }

        .visual-backlightstage::before {
            width: 300px;
            height: 300px;
        }
    }
</style>
