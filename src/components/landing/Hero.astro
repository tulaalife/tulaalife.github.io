---
import StoreButtons from "../StoreButtons.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        badge: "✨ 100% Free • No Ads • No Login ✨",
        titleTop: "Heal with Expert",
        titleBottom: "Yoga Therapy.",
        subtitle:
            "Specialized yoga for 30+ health needs, including <strong>Back Pain, PCOS, Thyroid, and Sciatica.</strong> Your health data stays 100% private on your device.",
        ctaLead: "Download the free app",
        socialProofs: [
            "Join 5,000+ users healing naturally",
            "Rated 5 stars on Play Store & App Store",
            "Yoga plans for 30+ health needs",
            "100% Private: No account needed",
            "Completely Free: No hidden costs",
            "Mediate, track, and find balance",
            "Sleep better and relax deeply",
        ],
    },
    hi: {
        badge: "✨ 100% फ्री • बिना विज्ञापन • बिना लॉगिन ✨",
        titleTop: "विशेषज्ञ योग थेरेपी",
        titleBottom: "अब आपके हाथ में।",
        subtitle:
            "30+ बीमारियों के लिए खास योग, जैसे <strong>कमर दर्द, PCOS, थायरॉइड और साइटिका।</strong> आपका हेल्थ डेटा आपके ही फोन में 100% सुरक्षित रहता है।",
        ctaLead: "फ्री ऐप डाउनलोड करें",
        socialProofs: [
            "5,000+ लोगों का भरोसेमंद साथी",
            "Play Store पर 5-स्टार रेटिंग",
            "30+ बीमारियों के लिए खास योग प्लान",
            "100% प्राइवेट: लॉगिन की ज़रूरत नहीं",
            "पूरी तरह फ्री: कोई गुप्त शुल्क नहीं",
            "ध्यान लगाएं और संतुलन पाएं",
            "बेहतर नींद और गहरी शांति",
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section id="hero" class="scroll-section hero-section">
    <!-- Combined layout tracking under standard common header wrapper -->
    <div class="container section-header-center hero-content">
        <div class="badge-small animate-on-scroll" style="margin-bottom: 32px;">
            {t.badge}
        </div>

        <h1 class="hero-title animate-on-scroll" lang={currentLang}>
            {t.titleTop}<br />
            <span class="text-gradient">{t.titleBottom}</span>
        </h1>

        <p class="hero-sub animate-on-scroll delay-1" set:html={t.subtitle} />

        <div class="cta-wrapper animate-on-scroll delay-2">
            <p class="cta-lead">{t.ctaLead}</p>
            <StoreButtons centered={true} class="hero-buttons" />

            <div class="proof-slider">
                {
                    t.socialProofs.map((proof, index) => (
                        <p
                            class={`social-proof-item ${index === 0 ? "active" : ""}`}
                        >
                            {proof}
                        </p>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const proofs = document.querySelectorAll(".social-proof-item");
        let currentProof = 0;

        if (proofs.length > 0) {
            setInterval(() => {
                proofs[currentProof].classList.remove("active");
                currentProof = (currentProof + 1) % proofs.length;
                proofs[currentProof].classList.add("active");
            }, 3000);
        }
    });
</script>

<style>
    .hero-section {
        width: 100%;
        display: flex;
        align-items: center;
        background-color: var(--bg-main);
    }

    .hero-content {
        max-width: 800px;
        z-index: 2;
    }

    .hero-title {
        font-size: clamp(3rem, 5vw, 4.5rem);
        margin-bottom: 24px;
    }

    .hero-sub {
        font-size: 1.2rem;
        line-height: 1.6;
        color: var(--text-muted);
        margin-bottom: 40px;
        max-width: 650px;
    }

    .cta-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        width: 100%;
    }

    .cta-lead {
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0 0 4px 0;
    }

    .proof-slider {
        height: 1.8rem;
        position: relative;
        overflow: hidden;
        margin-top: 12px;
        width: 100%;
    }

    .social-proof-item {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        margin: 0 auto;
        text-align: center;
        font-size: 0.9rem;
        color: var(--text-muted);
        font-style: italic;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.5s ease;
        line-height: 1.6;
    }

    .social-proof-item.active {
        opacity: 1;
        transform: translateY(0);
    }

    @media (max-width: 768px) {
        .hero-title {
            font-size: clamp(2.6rem, 8vw, 3.2rem);
        }
        .hero-sub {
            font-size: 1.1rem;
        }
        :global(.hero-buttons) {
            justify-content: center !important;
        }
    }
</style>
