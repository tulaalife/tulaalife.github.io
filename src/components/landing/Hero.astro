---
import StoreButtons from "../StoreButtons.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        badge: "✨ 100% Free • Private • Offline",
        titleTop: "Heal with Expert",
        titleBottom: "Yoga Therapy.",
        highlight: "No Ads. No Login.",
        author: "<strong>By Latika Bissa</strong>",
        cred1: "🏅 Gold Medalist, M.Sc Yoga Therapy",
        cred2: "🧘‍♀️ 10+ Years of Experience",
        subtitle:
            "Specialized recovery plans for <strong>Back Pain, PCOS, Thyroid, and Prenatal care.</strong> Your health data stays on your device—where it belongs.",
        basePoster: "poster",
    },
    hi: {
        badge: "✨ 100% फ्री • प्राइवेट • ऑफलाइन",
        titleTop: "विशेषज्ञ योग थेरेपी",
        titleBottom: "अब आपके हाथ में।",
        highlight: "बिना विज्ञापन। बिना लॉगिन।",
        author: "<strong>लतिका बिस्सा द्वारा</strong>",
        cred1: "🏅 गोल्ड मेडलिस्ट, M.Sc योग थेरेपी",
        cred2: "🧘‍♀️ 10+ वर्षों का अनुभव",
        subtitle:
            "<strong>कमर दर्द, PCOS और थायरॉइड</strong> के लिए विशेष योगाभ्यास। आपकी गोपनीयता हमारी प्राथमिकता है।", // More concise
        basePoster: "poster-hindi",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const isHindi = currentLang === "hi";

const mobilePoster = `/images/mobile/${t.basePoster}.webp`;
const desktopPoster = `/images/desktop/${t.basePoster}.webp`;

const videoWebm =
    currentLang === "hi"
        ? "/website-app-demo-hindi.webm"
        : "/website-app-demo.webm";
const videoMp4 =
    currentLang === "hi"
        ? "/website-app-demo-hindi.mp4"
        : "/website-app-demo.mp4";
---

<section id="hero" class="hero-section">
    <div class="container hero-grid">
        <div class="hero-content">
            <div class="badge">{t.badge}</div>

            <h1
                class={`hero-title ${isHindi ? "is-hindi" : ""}`}
                lang={currentLang}
            >
                {t.titleTop}
                <br />
                {t.titleBottom}
                <br />
                <span class="text-gradient">{t.highlight}</span>
            </h1>

            <div class="author-card">
                <div class="author-info">
                    <Fragment set:html={t.author} />
                    <div class="creds-list">
                        <span class="cred">{t.cred1}</span>
                        <span class="cred">{t.cred2}</span>
                    </div>
                </div>
            </div>

            <p class="hero-sub" set:html={t.subtitle} />

            <div class="cta-wrapper">
                <StoreButtons centered={true} />
            </div>
        </div>

        <div class="hero-visual">
            <div
                class="phone-frame-wrapper"
                id="phoneWrapper"
                data-webm={videoWebm}
                data-mp4={videoMp4}
            >
                <div class="video-loader" id="videoLoader"></div>
                <picture>
                    <source media="(min-width: 768px)" srcset={desktopPoster} />
                    <img
                        src={mobilePoster}
                        alt="Tulaa App Preview"
                        class="poster-img"
                        id="posterImg"
                        fetchpriority="high"
                        loading="eager"
                        decoding="sync"
                    />
                </picture>

                <video
                    id="heroVideo"
                    class="app-video"
                    loop
                    muted
                    playsinline
                    preload="none"></video>
                <div class="glow-blob"></div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const wrapper = document.getElementById("phoneWrapper");
        const video = document.getElementById("heroVideo") as HTMLVideoElement;
        const loader = document.getElementById("videoLoader");
        const poster = document.getElementById("posterImg");

        if (!wrapper || !video) return;

        video.innerHTML = "";
        const initVideo = () => {
            const webmSrc = wrapper.getAttribute("data-webm");
            const mp4Src = wrapper.getAttribute("data-mp4");

            if (webmSrc) {
                const s = document.createElement("source");
                s.src = webmSrc;
                s.type = "video/webm";
                video.appendChild(s);
            }
            if (mp4Src) {
                const s = document.createElement("source");
                s.src = mp4Src;
                s.type = "video/mp4";
                video.appendChild(s);
            }

            video.addEventListener(
                "playing",
                () => {
                    video.classList.add("is-playing");
                    if (loader) loader.style.opacity = "0";
                    setTimeout(() => {
                        if (poster)
                            (poster as HTMLElement).style.visibility = "hidden";
                        if (loader) loader.style.display = "none";
                    }, 1000);
                },
                { once: true },
            );

            video.load();
            video.play().catch(() => {
                if (loader) loader.style.display = "none";
            });
        };

        if ("requestIdleCallback" in window) {
            (window as any).requestIdleCallback(initVideo);
        } else {
            setTimeout(initVideo, 300);
        }
    });
</script>

<style>
    .hero-section {
        padding: 120px 0 80px;
        min-height: 85vh;
        display: flex;
        align-items: center;
    }
    .hero-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 60px;
        align-items: center;
    }

    .badge {
        display: inline-flex;
        padding: 6px 14px;
        border-radius: 100px;
        background: var(--bg-sub);
        color: var(--primary);
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 24px;
        border: 1px solid var(--border);
    }

    .hero-title {
        font-size: clamp(2.6rem, 4vw, 3.5rem);
        line-height: 1.2;
        font-weight: 800;
        margin-bottom: 28px;
        letter-spacing: -0.02em;
    }

    /* Handling Hindi Specific Clipping & Spacing */
    .hero-title.is-hindi {
        line-height: 1.4; /* Extra space for top/bottom Hindi strokes */
        font-size: clamp(
            2.2rem,
            3.8vw,
            3.2rem
        ); /* Slightly smaller to prevent width overflow */
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--primary), #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
        padding-bottom: 4px; /* Fix for lower stroke clipping in Hindi */
    }

    .author-card {
        margin-bottom: 28px;
    }
    .author-info {
        border-left: 3px solid var(--primary);
        padding: 4px 0 4px 16px;
    }
    .creds-list {
        margin-top: 4px;
        display: flex;
        flex-direction: column;
        gap: 1px;
    }
    .cred {
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    .hero-sub {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--text-muted);
        margin-bottom: 40px;
        max-width: 500px;
    }

    .phone-frame-wrapper {
        position: relative;
        width: 280px;
        margin: 0 auto;
        aspect-ratio: 540 / 1174;
        background-color: #000;
        border-radius: 44px;
        border: 12px solid #1a1a1a;
        overflow: hidden;
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.4);
    }

    .video-loader {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.05);
        border-top-color: var(--primary);
        border-radius: 50%;
        z-index: 6;
        animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
        to {
            transform: translate(-50%, -50%) rotate(360deg);
        }
    }

    .poster-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 5;
    }

    .app-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.8s ease;
        z-index: 10;
    }

    .app-video.is-playing {
        opacity: 1;
    }

    .glow-blob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 150%;
        height: 100%;
        background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
        opacity: 0.1;
        z-index: -1;
    }

    @media (max-width: 768px) {
        .hero-section {
            padding-top: 40px;
        }
        .hero-grid {
            display: flex;
            flex-direction: column;
            text-align: center;
            gap: 32px;
        }
        .hero-title {
            font-size: 2.2rem;
        }
        .hero-title.is-hindi {
            font-size: 1.9rem;
        }
        .author-info {
            border-left: none;
            padding: 0;
        }
        .hero-sub {
            font-size: 1.05rem;
            padding: 0 10px;
            margin-bottom: 30px;
        }
        .phone-frame-wrapper {
            width: 250px;
        }

        .badge {
            order: 1;
        }
        .hero-title {
            order: 2;
        }
        .hero-visual {
            order: 3;
        }
        .author-card {
            order: 4;
        }
        .hero-sub {
            order: 5;
        }
        .cta-wrapper {
            order: 6;
        }
    }
</style>
