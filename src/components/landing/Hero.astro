---
import StoreButtons from "../StoreButtons.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        badge: "No Login • No Ads • 100% Free",
        titleTop: "Unlock the power of",
        titleBottom: "Therapeutic Yoga.",
        subtitle:
            "Science-backed plans for <strong>Back Pain, PCOS, Thyroid, and 30+ health needs.</strong> Reduce stress, heal naturally, and reclaim your vitality through Yoga Therapy.",
        ctaLead: "Start your free journey today",
        socialProofs: [
            "Science-backed yoga for 30+ health needs",
            "100% Private: No accounts, no data mining",
            "Guided audio for deep sleep and anxiety",
            "Built-in trackers for cycles, moods, and fasting",
            "Completely free. No hidden paywalls.",
        ],
    },
    hi: {
        badge: "कोई लॉगिन नहीं • कोई विज्ञापन नहीं • 100% फ्री",
        titleTop: "योग की रोग-मुक्त करने वाली",
        titleBottom: "शक्तियों को सीखें।",
        subtitle:
            "<strong>कमर दर्द, PCOS, थायरॉइड</strong> और 30+ स्वास्थ्य समस्याओं के लिए वैज्ञानिक योग। प्राकृतिक रूप से स्वस्थ बनें—आपका डेटा आपके ही फोन में 100% सुरक्षित है।",
        ctaLead: "आज ही अपनी फ्री शुरुआत करें",
        socialProofs: [
            "30+ बीमारियों के लिए वैज्ञानिक योग प्लान",
            "100% सुरक्षित: कोई अकाउंट या डेटा ट्रैकिंग नहीं",
            "बेहतर नींद और तनाव-मुक्ति के लिए गाइडेड ऑडियो",
            "पीरियड, मूड और फास्टिंग के लिए वेलनेस ट्रैकर्स",
            "पूरी तरह फ्री। कोई छिपा हुआ शुल्क नहीं।",
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section id="hero" class="scroll-section hero-section">
    <div class="container">
        <div class="section-header-left hero-content">
            <div class="badge-pill animate-on-scroll">
                {t.badge}
            </div>

            <h1 class="hero-title animate-on-scroll" lang={currentLang}>
                {t.titleTop}<br />
                <span class="text-gradient">{t.titleBottom}</span>
            </h1>

            <p
                class="hero-sub animate-on-scroll delay-1"
                set:html={t.subtitle}
            />

            <div class="cta-wrapper animate-on-scroll delay-2">
                <p class="cta-lead">{t.ctaLead}</p>
                <StoreButtons class="hero-buttons" />

                <div class="proof-slider">
                    {
                        t.socialProofs.map((proof, index) => (
                            <p
                                class={`social-proof-item ${index === 0 ? "active" : ""}`}
                            >
                                {proof}
                            </p>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const proofs = document.querySelectorAll(".social-proof-item");
        let currentProof = 0;

        if (proofs.length > 0) {
            setInterval(() => {
                proofs[currentProof].classList.remove("active");
                currentProof = (currentProof + 1) % proofs.length;
                proofs[currentProof].classList.add("active");
            }, 8000);
        }
    });
</script>

<style>
    .hero-section {
        width: 100%;
        display: flex;
        align-items: center;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .hero-content {
        max-width: 720px;
        z-index: 2;
        display: flex;
        flex-direction: column;
    }

    /* Polished Premium Pill Badge */
    .badge-pill {
        display: inline-flex;
        padding: 6px 14px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--primary) 6%, transparent);
        color: var(--primary);
        font-weight: 600;
        font-size: 0.8rem;
        letter-spacing: 0.03em;
        margin-bottom: var(--space-md);
        border: 1px solid color-mix(in srgb, var(--primary) 12%, transparent);
        backdrop-filter: blur(8px);
        align-self: flex-start;
    }

    .hero-title {
        font-size: clamp(2.4rem, 5.5vw, 4.4rem);
        margin-bottom: var(--space-md);
        letter-spacing: -0.035em;
        line-height: 1.08;
        color: var(--text-main);
    }

    /* Enhanced contrast readability for the subtitle */
    .hero-sub {
        font-size: clamp(1.1rem, 2vw, 1.25rem);
        line-height: 1.65;
        color: var(--text-muted);
        margin-bottom: var(--space-lg);
        max-width: 640px;
    }

    /* Makes the inline-bold elements truly pop out from muted prose */
    .hero-sub :global(strong) {
        color: var(--text-main);
        font-weight: 700;
    }

    .cta-wrapper {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-sm);
        width: 100%;
    }

    /* Polished label styling */
    .cta-lead {
        font-weight: 700;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 2px;
    }

    /* --- FIXED PROOF SLIDER CONTAINER --- */
    .proof-slider {
        position: relative;
        margin-top: var(--space-md);
        width: 100%;
        min-height: 2rem;
        display: grid;
        grid-template-columns: 1fr;
    }

    .social-proof-item {
        grid-area: 1 / 1 / 2 / 2;
        text-align: left;
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--text-muted);
        opacity: 0;
        transform: scale(0.98);
        filter: blur(4px);
        pointer-events: none;
        transition:
            opacity 0.5s ease-in-out,
            transform 0.5s ease-in-out,
            filter 0.5s ease-in-out;
        padding: 4px 0;
        line-height: 1.4;
    }

    .social-proof-item.active {
        opacity: 1;
        transform: scale(1);
        filter: blur(0);
        pointer-events: auto;
    }

    /* Keep native Hindi layout loose and beautiful */
    :lang(hi) .social-proof-item {
        line-height: 1.5;
        font-size: 1rem;
    }

    /* --- RESPONSIVE OPTIMIZATIONS FOR SMALL HEIGHT DEVICES --- */
    @media (max-height: 740px) {
        .badge-pill {
            margin-bottom: var(--space-xs);
            padding: 4px 12px;
            font-size: 0.75rem;
        }
        .hero-title {
            font-size: 2.2rem;
            margin-bottom: var(--space-xs);
        }
        .hero-sub {
            font-size: 1.05rem;
            margin-bottom: var(--space-md);
        }
        .proof-slider {
            margin-top: var(--space-xs);
        }
    }

    @media (max-width: 768px) {
        .hero-section {
            padding-top: calc(var(--header-height) + var(--space-md));
        }
    }
</style>
