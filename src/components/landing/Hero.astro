---
import StoreButtons from "../StoreButtons.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        badge: "✨ 100% Free • No Ads • No Login",
        titleTop: "Heal with Expert",
        titleBottom: "Yoga Therapy.",
        subtitle:
            "Specialized yoga for 30+ health needs, including <strong>Back Pain, PCOS, Thyroid, and Sciatica.</strong> Your health data stays 100% private on your device.",
        ctaLead: "Download the free app",
        socialProofs: [
            "Join 5,000+ users healing naturally",
            "Rated 5 stars on Play Store & App Store",
            "Yoga plans for 30+ health needs",
            "100% Private: No account needed",
            "Completely Free: No hidden costs",
            "Mediate, track, and find balance",
            "Sleep better and relax deeply",
        ],
    },
    hi: {
        badge: "✨ 100% फ्री • बिना विज्ञापन • बिना लॉगिन",
        titleTop: "विशेषज्ञ योग थेरेपी",
        titleBottom: "अब आपके हाथ में।",
        subtitle:
            "30+ बीमारियों के लिए खास योग, जैसे <strong>कमर दर्द, PCOS, थायरॉइड और साइटिका।</strong> आपका हेल्थ डेटा आपके ही फोन में 100% सुरक्षित रहता है।",
        ctaLead: "फ्री ऐप डाउनलोड करें",
        socialProofs: [
            "5,000+ लोगों का भरोसेमंद साथी",
            "Play Store पर 5-स्टार रेटिंग",
            "30+ बीमारियों के लिए खास योग प्लान",
            "100% प्राइवेट: लॉगिन की ज़रूरत नहीं",
            "पूरी तरह फ्री: कोई गुप्त शुल्क नहीं",
            "ध्यान लगाएं और संतुलन पाएं",
            "बेहतर नींद और गहरी शांति",
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section id="hero" class="scroll-section hero-section">
    <div class="container">
        <div class="section-header-left hero-content">
            <div class="badge-pill animate-on-scroll">
                {t.badge}
            </div>

            <h1 class="hero-title animate-on-scroll" lang={currentLang}>
                {t.titleTop}<br />
                <span class="text-gradient">{t.titleBottom}</span>
            </h1>

            <p
                class="hero-sub animate-on-scroll delay-1"
                set:html={t.subtitle}
            />

            <div class="cta-wrapper animate-on-scroll delay-2">
                <p class="cta-lead">{t.ctaLead}</p>
                <StoreButtons class="hero-buttons" />

                <div class="proof-slider">
                    {
                        t.socialProofs.map((proof, index) => (
                            <p
                                class={`social-proof-item ${index === 0 ? "active" : ""}`}
                            >
                                {proof}
                            </p>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const proofs = document.querySelectorAll(".social-proof-item");
        let currentProof = 0;

        if (proofs.length > 0) {
            setInterval(() => {
                proofs[currentProof].classList.remove("active");
                currentProof = (currentProof + 1) % proofs.length;
                proofs[currentProof].classList.add("active");
            }, 3000);
        }
    });
</script>

<style>
    .hero-section {
        width: 100%;
        display: flex;
        align-items: center;
        background-color: transparent; /* Let the global body background handle this */
    }

    .hero-content {
        max-width: 720px; /* Slightly tighter for better reading line-length */
        z-index: 2;
    }

    /* Upgraded premium pill badge */
    .badge-pill {
        display: inline-flex;
        padding: 8px 18px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--primary) 8%, transparent);
        color: var(--primary);
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.02em;
        margin-bottom: 2.5rem;
        border: 1px solid color-mix(in srgb, var(--primary) 20%, transparent);
        backdrop-filter: blur(8px);
    }

    .hero-title {
        font-size: clamp(3.2rem, 6vw, 5rem);
        margin-bottom: 1.5rem;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .hero-sub {
        font-size: 1.25rem;
        line-height: 1.7;
        color: var(--text-muted);
        margin-bottom: 3.5rem; /* Increased whitespace */
        max-width: 600px;
    }

    .cta-wrapper {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
        width: 100%;
    }

    .cta-lead {
        font-weight: 700;
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin: 0 0 4px 0;
    }

    .proof-slider {
        height: 24px;
        position: relative;
        overflow: hidden;
        margin-top: 12px;
        width: 100%;
        /* Subtle fade out at the bottom of the slider */
        mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
        -webkit-mask-image: linear-gradient(
            to bottom,
            black 60%,
            transparent 100%
        );
    }

    .social-proof-item {
        position: absolute;
        top: 0;
        left: 0;
        text-align: left;
        font-size: 0.95rem;
        font-weight: 500; /* Replaced italic with a clean medium weight */
        color: var(--text-muted);
        opacity: 0;
        transform: translateY(12px);
        transition:
            opacity 0.6s ease,
            transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .social-proof-item.active {
        opacity: 1;
        transform: translateY(0);
    }

    @media (max-width: 768px) {
        .hero-section {
            padding-top: 8vh; /* extra breathing room top for mobile */
        }
        .hero-title {
            font-size: clamp(2.8rem, 10vw, 3.8rem);
        }
        .hero-sub {
            font-size: 1.15rem;
        }
        .badge-pill {
            margin-bottom: 2rem;
        }
    }
</style>
