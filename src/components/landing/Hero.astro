---
import StoreButtons from "../StoreButtons.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        badge: "✨ 100% Free • Private • Offline",
        titleTop: "Heal with Expert",
        titleBottom: "Yoga Therapy.",
        highlight: "No Ads. No Login.",
        author: "<strong>By Latika Bissa</strong>",
        cred1: "🏅 Gold Medalist, M.Sc Yoga Therapy",
        cred2: "🧘‍♀️ 10+ Years of Experience",
        subtitle:
            "Specialized recovery Yoga plans for <strong>Back Pain, PCOS, Thyroid, and Prenatal care.</strong> Your health data stays on your device—where it belongs.",
        ctaLead: "Download the Free Yoga App",
        socialProofs: [
            "Join 5,000+ users healing naturally",
            "Rated 5 stars on Play Store & App Store",
            "Yoga plans for 30+ health needs",
            "100% Private: No account needed",
            "Completely Free: No hidden costs",
            "Mediate, track, and find balance",
            "Sleep better and relax deeply",
        ],
        basePoster: "poster",
    },
    hi: {
        badge: "✨ 100% फ्री • प्राइवेट • ऑफलाइन",
        titleTop: "विशेषज्ञ योग थेरेपी",
        titleBottom: "अब आपके हाथ में।",
        highlight: "बिना विज्ञापन। बिना लॉगिन।",
        author: "<strong>लतिका बिस्सा द्वारा</strong>",
        cred1: "🏅 गोल्ड मेडलिस्ट, M.Sc योग थेरेपी",
        cred2: "🧘‍♀️ 10+ वर्षों का अनुभव",
        subtitle:
            "<strong>कमर दर्द, PCOS और थायरॉइड</strong> के लिए विशेष योगाभ्यास। आपकी गोपनीयता हमारी प्राथमिकता है।",
        ctaLead: "फ्री योग ऐप डाउनलोड करें",
        socialProofs: [
            "5,000+ लोगों का भरोसेमंद साथी",
            "Play Store पर 5-स्टार रेटिंग",
            "30+ बीमारियों के लिए खास योग प्लान",
            "100% प्राइवेट: लॉगिन की ज़रूरत नहीं",
            "पूरी तरह फ्री: कोई गुप्त शुल्क नहीं",
            "ध्यान लगाएं और संतुलन पाएं",
            "बेहतर नींद और गहरी शांति",
        ],
        basePoster: "poster-hindi",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const isHindi = currentLang === "hi";

const mobilePoster = `/images/mobile/${t.basePoster}.webp`;
const desktopPoster = `/images/desktop/${t.basePoster}.webp`;

const videoWebm =
    currentLang === "hi"
        ? "/website-app-demo-hindi.webm"
        : "/website-app-demo.webm";
const videoMp4 =
    currentLang === "hi"
        ? "/website-app-demo-hindi.mp4"
        : "/website-app-demo.mp4";
---

<section id="hero" class="hero-section">
    <div class="container hero-grid">
        <div class="hero-content">
            <div class="badge">{t.badge}</div>

            <h1
                class={`hero-title ${isHindi ? "is-hindi" : ""}`}
                lang={currentLang}
            >
                {t.titleTop}<br />
                {t.titleBottom}<br />
                <span class="text-gradient">{t.highlight}</span>
            </h1>

            <div class="author-card">
                <div class="author-info">
                    <Fragment set:html={t.author} />
                    <div class="creds-list">
                        <span class="cred">{t.cred1}</span>
                        <span class="cred">{t.cred2}</span>
                    </div>
                </div>
            </div>

            <p class="hero-sub" set:html={t.subtitle} />

            <div class="cta-wrapper">
                <p class="cta-lead">{t.ctaLead}</p>
                <StoreButtons centered={false} class="hero-buttons" />

                <div class="proof-slider">
                    {
                        t.socialProofs.map((proof, index) => (
                            <p
                                class={`social-proof-item ${index === 0 ? "active" : ""}`}
                            >
                                {proof}
                            </p>
                        ))
                    }
                </div>
            </div>
        </div>

        <div class="hero-visual">
            <div
                class="phone-frame-wrapper"
                id="phoneWrapper"
                data-webm={videoWebm}
                data-mp4={videoMp4}
            >
                <div class="video-loader" id="videoLoader"></div>
                <picture>
                    <source media="(min-width: 768px)" srcset={desktopPoster} />
                    <img
                        src={mobilePoster}
                        alt="Tulaa App Preview"
                        class="poster-img"
                        id="posterImg"
                        fetchpriority="high"
                        loading="eager"
                    />
                </picture>
                <video
                    id="heroVideo"
                    class="app-video"
                    loop
                    muted
                    playsinline
                    preload="none"></video>
                <div class="glow-blob"></div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const proofs = document.querySelectorAll(".social-proof-item");
        let currentProof = 0;

        if (proofs.length > 0) {
            setInterval(() => {
                proofs[currentProof].classList.remove("active");
                currentProof = (currentProof + 1) % proofs.length;
                proofs[currentProof].classList.add("active");
            }, 3000);
        }

        const wrapper = document.getElementById("phoneWrapper");
        const video = document.getElementById("heroVideo") as HTMLVideoElement;
        const loader = document.getElementById("videoLoader");
        const poster = document.getElementById("posterImg");

        if (!wrapper || !video) return;

        const initVideo = () => {
            const webmSrc = wrapper.getAttribute("data-webm");
            const mp4Src = wrapper.getAttribute("data-mp4");

            if (webmSrc) {
                const s = document.createElement("source");
                s.src = webmSrc;
                s.type = "video/webm";
                video.appendChild(s);
            }
            if (mp4Src) {
                const s = document.createElement("source");
                s.src = mp4Src;
                s.type = "video/mp4";
                video.appendChild(s);
            }

            video.addEventListener(
                "playing",
                () => {
                    video.classList.add("is-playing");
                    if (loader) loader.style.opacity = "0";
                    setTimeout(() => {
                        if (poster)
                            (poster as HTMLElement).style.visibility = "hidden";
                        if (loader) loader.style.display = "none";
                    }, 1000);
                },
                { once: true },
            );

            video.load();
            video.play().catch(() => {
                if (loader) loader.style.display = "none";
            });
        };

        if ("requestIdleCallback" in window) {
            (window as any).requestIdleCallback(initVideo);
        } else {
            setTimeout(initVideo, 300);
        }
    });
</script>

<style>
    .hero-section {
        padding: 140px 0 100px;
        min-height: 80vh;
        display: flex;
        align-items: center;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
        width: 100%;
    }

    .hero-content {
        z-index: 2;
    }

    .badge {
        display: inline-flex;
        padding: 6px 14px;
        border-radius: 100px;
        background: var(--bg-sub);
        color: var(--primary);
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 24px;
        border: 1px solid var(--border);
    }

    .hero-title {
        font-size: clamp(2.6rem, 4vw, 3.5rem);
        line-height: 1.2;
        font-weight: 800;
        margin-bottom: 28px;
        letter-spacing: -0.02em;
    }

    .hero-title.is-hindi {
        line-height: 1.4;
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--primary), #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .author-card {
        margin-bottom: 24px;
        display: inline-block;
    }

    .author-info {
        border-left: 3px solid var(--primary);
        padding: 4px 0 4px 16px;
    }

    .cred {
        font-size: 0.9rem;
        color: var(--text-muted);
        display: block;
    }

    .hero-sub {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--text-muted);
        margin-bottom: 40px;
        max-width: 580px;
    }

    .cta-wrapper {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .cta-lead {
        font-weight: 750;
        font-size: 1rem;
        color: var(--text-main);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0;
    }

    .proof-slider {
        /* Increased height to accommodate Hindi ascenders/descenders */
        height: 1.8rem;
        position: relative;
        overflow: hidden;
    }

    .social-proof-item {
        position: absolute;
        top: 0;
        left: 0;
        margin: 0;
        font-size: 0.9rem;
        color: var(--text-muted);
        font-style: italic;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.5s ease;
        /* Added line-height to prevent clipping of Hindi characters */
        line-height: 1.6;
    }

    .social-proof-item.active {
        opacity: 1;
        transform: translateY(0);
    }

    .hero-visual {
        display: flex;
        justify-content: flex-end;
        /* Added margin to increase distance from content/slider */
        margin-top: 40px;
    }

    .phone-frame-wrapper {
        position: relative;
        width: 280px;
        aspect-ratio: 540 / 1174;
        background-color: #000;
        border-radius: 44px;
        border: 12px solid #1a1a1a;
        overflow: hidden;
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.4);
    }

    .app-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.8s ease;
        z-index: 10;
    }

    .app-video.is-playing {
        opacity: 1;
    }

    .video-loader {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.05);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
        to {
            transform: translate(-50%, -50%) rotate(360deg);
        }
    }

    @media (max-width: 768px) {
        .hero-section {
            padding-top: 60px;
        }
        .hero-grid {
            display: flex;
            flex-direction: column;
            text-align: center;
            gap: 32px;
        }
        .author-card {
            background: color-mix(in srgb, var(--bg-sub), transparent 40%);
            backdrop-filter: blur(8px);
            padding: 16px 24px;
            border-radius: 20px;
            border: 1px solid var(--border);
            width: 100%;
            max-width: 400px;
            margin: 0 auto 24px;
        }
        .author-info {
            border-left: none;
            padding: 0;
        }
        .cta-wrapper {
            align-items: center;
        }
        .proof-slider {
            width: 100%;
        }
        .social-proof-item {
            width: 100%;
            text-align: center;
        }
        .hero-visual {
            justify-content: center;
            /* Increased margin for mobile spacing */
            margin-top: 40px;
        }
        :global(.hero-buttons) {
            justify-content: center !important;
        }
    }
</style>
