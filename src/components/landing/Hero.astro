---
import StoreButtons from "../StoreButtons.astro";

// 1. Get current language
const currentLang = Astro.currentLocale || "en";

// 2. Dictionary for Hero content
const ui = {
    en: {
        badge: "✨ 100% Free. Private. Offline.",
        titleTop: "Expert Yoga Therapy.",
        titleBottom: "No Ads. No Login.",
        author: "<strong>By Latika Bissa</strong>",
        cred1: "🏅 Gold Medalist, M.Sc Yoga Therapy",
        cred2: "🧘‍♀️ 10+ Years of Clinical Experience",
        subtitle:
            "Specialized plans for <strong>Back Pain, PCOS, Thyroid, and Prenatal care.</strong> Designed to help you heal, without tracking your data.",
        basePoster: "poster",
    },
    hi: {
        badge: "✨ 100% फ्री • प्राइवेट • ऑफलाइन",
        titleTop: "एक्सपर्ट योग थेरेपी",
        titleBottom: "कोई विज्ञापन नहीं। कोई लॉगिन नहीं।",
        author: "<strong>योग विशेषज्ञ लतिका द्वारा</strong>",
        cred1: "🏅 गोल्ड मेडलिस्ट, M.Sc योग थेरेपी",
        cred2: "🧘‍♀️ 10+ वर्षों का क्लिनिकल अनुभव",
        subtitle:
            "<strong>पीठ दर्द, PCOS, थायरॉइड और गर्भावस्था देखभाल</strong> के लिए विशेष योग प्लान। उपचार में सहायक, पूरी गोपनीयता के साथ।",
        basePoster: "poster-hindi",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;

// 3. Define the optimized paths for posters
const mobilePoster = `/images/mobile/${t.basePoster}.webp`;
const desktopPoster = `/images/desktop/${t.basePoster}.webp`;

// 4. Video paths
const videoWebm =
    currentLang === "hi"
        ? "/website-app-demo-hindi.webm"
        : "/website-app-demo.webm";
const videoMp4 =
    currentLang === "hi"
        ? "/website-app-demo-hindi.mp4"
        : "/website-app-demo.mp4";
---

<section id="hero" class="hero-section">
    <div class="container hero-grid">
        <div class="hero-content" id="download-content">
            <div class="badge">{t.badge}</div>
            <h1 class="hero-title">
                {t.titleTop}
                <br />
                <span class="text-gradient">{t.titleBottom}</span>
            </h1>

            <div class="author-card">
                <p>
                    <Fragment set:html={t.author} /><br />
                    <span class="cred">{t.cred1}</span>
                    <span class="cred">{t.cred2}</span>
                </p>
            </div>

            <p class="hero-sub" set:html={t.subtitle} />

            <div class="cta-wrapper">
                <StoreButtons centered={false} />
            </div>
        </div>

        <div class="hero-visual">
            <div
                class="phone-frame-wrapper"
                id="phoneWrapper"
                data-webm={videoWebm}
                data-mp4={videoMp4}
            >
                <picture>
                    <source media="(min-width: 768px)" srcset={desktopPoster} />
                    <img
                        src={mobilePoster}
                        alt="Tulaa App Preview"
                        class="poster-img"
                        fetchpriority="high"
                        decoding="sync"
                    />
                </picture>

                <video
                    id="heroVideo"
                    class="app-video"
                    loop
                    muted
                    playsinline
                    preload="none"
                    width="300"
                    height="533"></video>
                <div class="glow-blob"></div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const wrapper = document.getElementById("phoneWrapper");
        const video = document.getElementById("heroVideo") as HTMLVideoElement;

        if (!wrapper || !video) return;

        // Reset state for language toggling
        video.innerHTML = "";
        video.classList.remove("is-playing");

        // --- Intelligent Video Loading ---
        const nav = navigator as any;
        const connection =
            nav.connection || nav.mozConnection || nav.webkitConnection;
        const isSlow =
            connection &&
            (connection.saveData ||
                ["slow-2g", "2g"].includes(connection.effectiveType || ""));

        // Don't load video on slow connections to save user data
        if (isSlow) return;

        const initVideo = () => {
            const webmSrc = wrapper.getAttribute("data-webm");
            const mp4Src = wrapper.getAttribute("data-mp4");

            if (webmSrc) {
                const s = document.createElement("source");
                s.src = webmSrc;
                s.type = "video/webm";
                video.appendChild(s);
            }
            if (mp4Src) {
                const s = document.createElement("source");
                s.src = mp4Src;
                s.type = "video/mp4";
                video.appendChild(s);
            }

            video.addEventListener(
                "canplay",
                () => {
                    video
                        .play()
                        .then(() => video.classList.add("is-playing"))
                        .catch(() => {});
                },
                { once: true },
            );
            video.load();
        };

        // Use Idle Callback to avoid blocking main thread
        if ("requestIdleCallback" in window) {
            // @ts-ignore
            requestIdleCallback(initVideo);
        } else {
            setTimeout(initVideo, 200);
        }
    });
</script>

<style>
    #download-content {
        scroll-margin-top: 100px;
    }
    .hero-section {
        padding-top: 140px;
        padding-bottom: 80px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .hero-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 60px;
        align-items: center;
        width: 100%;
    }
    .badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 99px;
        background: var(--bg-sub);
        color: var(--primary);
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 24px;
        border: 1px solid var(--border);
    }
    .hero-title {
        font-size: var(--text-display);
        line-height: 1.1;
        margin-bottom: 24px;
    }
    .author-card {
        background: var(--bg-sub);
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 24px;
        display: inline-block;
        border: 1px solid var(--border);
        text-align: left;
    }
    .author-card p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.4;
    }
    .cred {
        opacity: 0.8;
        font-size: 0.9rem;
        display: block;
    }

    .hero-sub {
        font-size: 1.2rem;
        color: var(--text-muted);
        margin-bottom: 40px;
        max-width: 500px;
    }
    .cta-wrapper {
        display: flex;
        justify-content: flex-start;
        width: 100%;
    }
    .text-gradient {
        background: linear-gradient(135deg, var(--primary), #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        padding-bottom: 0.2em;
        margin-bottom: -0.2em;
        display: inline-block;
        line-height: 1.2;
    }

    .phone-frame-wrapper {
        position: relative;
        width: 280px;
        margin: 0 auto;
        z-index: 2;
        aspect-ratio: 540 / 1174;
        background-color: #0d0d0d;
        border-radius: 36px;
        border: 10px solid #1a1a1a;
        overflow: hidden;
    }

    /* NEW: Poster image styles */
    .poster-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 5;
    }

    .app-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 26px;
        opacity: 0;
        transition: opacity 1.2s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 10;
    }

    .app-video.is-playing {
        opacity: 1;
    }

    .glow-blob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120%;
        height: 80%;
        background: var(--primary);
        filter: blur(80px);
        opacity: 0.2;
        z-index: -1;
    }

    @media (max-width: 768px) {
        .hero-section {
            padding-top: 32px;
            padding-bottom: 60px;
            min-height: 100dvh;
        }
        .hero-grid {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 30px;
        }
        .cta-wrapper {
            justify-content: center;
        }
        .hero-content {
            order: 2;
        }
        .hero-visual {
            order: 1;
            margin-bottom: 10px;
        }
        .hero-sub {
            margin-left: auto;
            margin-right: auto;
        }
        .hero-title {
            font-size: 2.5rem;
        }
    }
</style>
