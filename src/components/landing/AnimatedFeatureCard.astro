---
// src/components/landing/AnimatedFeatureCard.astro
interface Props {
    title: string;
    desc: string;
    color: string;
    type: string;
    index: number;
    activeClass: string;
}

const { title, desc, color, type, index, activeClass } = Astro.props;
---

<div
    class:list={[
        "animated-feature-card premium-gloss-surface",
        index === 0 ? activeClass : "",
    ]}
    style={`--card-accent: ${color}`}
>
    <!-- Centered Vertical Watermark Alignment Engine -->
    <div class="card-watermark">
        <slot name="watermark" />
    </div>

    <!-- Protected Text Layer Content -->
    <div class="card-content">
        <h3 class="card-title">{title}</h3>
        <p class="card-desc">{desc}</p>
    </div>
</div>

<style>
    .animated-feature-card {
        grid-area: 1 / 1 / 2 / 2;
        padding: var(--space-md) var(--space-xl) var(--space-md) var(--space-md);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        overflow: hidden;
        width: 100%;
        height: 100%;

        /* Unified GPU Accelerated Transition System */
        opacity: 0;
        transform: translateY(6px) scale(0.98);
        pointer-events: none;
        will-change: transform, opacity;
        transition:
            opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Top decorative color bar accent indicator */
    .animated-feature-card::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--card-accent);
        opacity: 0.8;
        z-index: 3;
    }

    /* Triggers when either section applies its active selector token */
    .animated-feature-card.active {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }

    /* --- RE-ARCHITECTED WATERMARK MARKUP --- */
    .card-watermark {
        position: absolute;
        top: 50%;
        right: 20px;
        transform: translateY(-50%);
        color: var(--card-accent);
        opacity: 0.05;
        pointer-events: none;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        will-change: transform, opacity;
        transition:
            opacity 0.4s ease,
            transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    :global(.card-watermark svg) {
        width: 64px;
        height: 64px;
        display: block;
        fill: currentColor;
    }

    .animated-feature-card.active .card-watermark {
        opacity: 0.12;
        transform: translateY(-50%) scale(1.06) rotate(-4deg);
    }

    .card-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 2;
        width: 100%;
        padding-right: 70px; /* Buffer zone safeguards line wrapping overlays */
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 750;
        margin: 0 0 4px 0;
        color: var(--text-main);
        letter-spacing: -0.015em;
        line-height: 1.3;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.4;
    }

    /* --- RESPONSIVE CONTROLS --- */
    @media (max-height: 740px) {
        .animated-feature-card {
            padding: var(--space-md);
        }
        :global(.card-watermark svg) {
            width: 56px;
            height: 56px;
        }
    }
</style>
