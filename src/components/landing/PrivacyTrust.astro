---
import SectionCTA from "../SectionCTA.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        titleTop: "100% Private.",
        titleBottom: "Truly Yours.",
        descTop:
            "Wellness shouldn't come with hidden costs or tracking pixels.",
        descBottom: "Tulaa is designed to be your safe, personal sanctuary.",
        features: [
            {
                title: "Privacy First",
                desc: "No account needed. Your data is stored locally. Export or delete it anytime.",
                icon: "🔒",
                color: "rgba(99, 102, 241, 0.15)",
            },
            {
                title: "Free & Offline",
                desc: "No ads, no tracking, no subscriptions. Works perfectly without internet access.",
                icon: "⚡",
                color: "rgba(34, 197, 94, 0.15)",
            },
            {
                title: "Make it Yours",
                desc: "Choose from 30+ themes and fonts. Set your own daily wellbeing goals.",
                icon: "🎨",
                color: "rgba(236, 72, 153, 0.15)",
            },
        ],
    },
    hi: {
        titleTop: "100% प्राइवेट।",
        titleBottom: "आपकी अपनी।",
        descTop:
            "सेहत की देखभाल—बिना किसी गुप्त कीमत या प्राइवेसी से समझौते के।",
        descBottom: "Tulaa आपकी अपनी सुरक्षित और निजी जगह है।",
        features: [
            {
                title: "प्राइवेसी सबसे पहले",
                desc: "किसी अकाउंट की ज़रूरत नहीं। आपका डेटा आपके डिवाइस पर रहता है।",
                icon: "🔒",
                color: "rgba(99, 102, 241, 0.15)",
            },
            {
                title: "फ्री और ऑफलाइन",
                desc: "कोई विज्ञापन नहीं, कोई ट्रैकिंग नहीं। बिना इंटरनेट के भी बेहतरीन काम करता है।",
                icon: "⚡",
                color: "rgba(34, 197, 94, 0.15)",
            },
            {
                title: "इसे अपना बनाएं",
                desc: "30+ थीम्स और फ़ॉन्ट्स में से चुनें। अपने दैनिक सेहत लक्ष्य खुद तय करें।",
                icon: "🎨",
                color: "rgba(236, 72, 153, 0.15)",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section class="scroll-section section-privacy">
    <div style="width: 100%;">
        <!-- 1. Pure container for standard left-edge alignment -->
        <div class="container">
            <!-- 2. Inner wrapper to restrict width and align text -->
            <div class="section-header-left header-content animate-on-scroll">
                <h2 class="section-title">
                    <span class="title-main">{t.titleTop}</span>
                    <br />
                    <span class="text-gradient">{t.titleBottom}</span>
                </h2>
                <p class="body-text" style="margin-top: 12px;">
                    {t.descTop}
                    <br class="hidden-mobile" />
                    {t.descBottom}
                </p>
            </div>
        </div>

        <div class="container carousel-wrapper animate-on-scroll delay-1">
            <div class="features-track">
                {
                    t.features.map((feature) => (
                        <div
                            class="privacy-card"
                            style={`--card-accent: ${feature.color}`}
                        >
                            <div class="card-content">
                                <h3 class="card-title">{feature.title}</h3>
                                <p class="card-desc">{feature.desc}</p>
                            </div>
                            <span class="bg-icon" aria-hidden="true">
                                {feature.icon}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Aligned CTA button beautifully to match the left margin setup -->
        <div class="container cta-wrapper animate-on-scroll delay-2">
            <SectionCTA
                href="/faq"
                labelEn="Frequently Asked Questions"
                labelHi="अक्सर पूछे जाने वाले प्रश्न"
            />
        </div>
    </div>
</section>

<style>
    .section-privacy {
        width: 100%;
        background-color: var(--bg-main);
        display: flex;
        align-items: center;
    }

    .header-content {
        max-width: 800px;
        margin-bottom: 4vh;
        text-align: left; /* FIX: Clear structural alignment shift away from center */
        width: 100%;
    }

    .section-title {
        font-size: clamp(2.6rem, 4vw, 3.5rem);
        text-align: left; /* FIX: Removes visual shifting on gradient lines */
    }

    .title-main {
        color: var(--text-main);
    }

    .body-text {
        text-align: left; /* FIX: Corrects the split shown in your screenshot */
    }

    /* --- RESPONSIVE GRID / CAROUSEL --- */
    .carousel-wrapper {
        position: relative;
        width: 100%;
    }

    .features-track {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        width: 100%;
    }

    .privacy-card {
        position: relative;
        overflow: hidden;
        padding: 32px;
        border-radius: var(--radius-lg);
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--bg-main), white 5%) 0%,
            var(--card-accent) 100%
        );
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
        transition:
            transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
            box-shadow 0.3s ease;
        text-align: left;
        display: flex;
        flex-direction: column;
        z-index: 1;
        height: 100%;
    }

    :root[data-theme="dark"] .privacy-card {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.05) 0%,
            var(--card-accent) 100%
        );
    }

    .privacy-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .card-content {
        position: relative;
        z-index: 2;
    }

    .card-title {
        font-size: 1.35rem;
        font-weight: 800;
        margin-bottom: 12px;
        color: var(--text-main);
        letter-spacing: -0.01em;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        opacity: 0.85;
        line-height: 1.6;
        margin: 0;
        font-weight: 400;
    }

    .bg-icon {
        position: absolute;
        bottom: -20px;
        right: -10px;
        font-size: 6.5rem;
        opacity: 0.06;
        transform: rotate(-15deg);
        filter: blur(1px);
        pointer-events: none;
        transition:
            transform 0.5s ease,
            opacity 0.5s ease;
    }

    .privacy-card:hover .bg-icon {
        transform: rotate(0deg) scale(1.1);
        opacity: 0.12;
    }

    .cta-wrapper {
        margin-top: 4vh;
        display: flex;
        justify-content: flex-start;
    }

    @media (max-width: 992px) {
        .carousel-wrapper::after {
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            width: 60px;
            height: 100%;
            pointer-events: none;
            z-index: 5;
        }

        html[data-theme="light"] .carousel-wrapper::after,
        html[data-theme="dark"] .carousel-wrapper::after {
            background: linear-gradient(
                to left,
                var(--bg-main) 0%,
                transparent 100%
            );
        }

        .features-track {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scrollbar-width: none;
            -webkit-overflow-scrolling: touch;
            padding-bottom: 24px;
            gap: 16px;
        }

        .features-track::-webkit-scrollbar {
            display: none;
        }

        .privacy-card {
            scroll-snap-align: start;
            flex: 0 0 85%;
            padding: 28px;
        }
    }

    @media (max-width: 768px) {
        .section-title {
            font-size: 2.2rem;
        }
        .hidden-mobile {
            display: none;
        }
        .header-content {
            margin-bottom: 4vh;
        }
        .cta-wrapper {
            margin-top: 2vh;
        }
    }
</style>
