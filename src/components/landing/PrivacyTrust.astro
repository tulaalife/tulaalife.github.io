---
// 1. Get current language
const currentLang = Astro.currentLocale || "en";

// 2. Dictionary for Privacy & Trust content
const ui = {
    en: {
        titleTop: "100% Private.",
        titleBottom: "Truly Yours.",
        descTop:
            "Wellness shouldn't come with hidden costs or tracking pixels.",
        descBottom: "Tulaa is designed to be your safe, personal sanctuary.",
        features: [
            {
                title: "Privacy First",
                desc: "No account needed. Your data is stored locally. Export or delete it anytime.",
                icon: "🔒",
                color: "rgba(99, 102, 241, 0.15)",
            },
            {
                title: "Free & Offline",
                desc: "No ads, no tracking, no subscriptions. Works perfectly without internet access.",
                icon: "⚡",
                color: "rgba(34, 197, 94, 0.15)",
            },
            {
                title: "Make it Yours",
                desc: "Choose from 30+ themes and fonts. Set your own daily wellbeing goals.",
                icon: "🎨",
                color: "rgba(236, 72, 153, 0.15)",
            },
        ],
    },
    hi: {
        titleTop: "100% प्राइवेट।",
        titleBottom: "आपकी अपनी।",
        descTop:
            "सेहत की देखभाल—बिना किसी गुप्त कीमत या प्राइवेसी से समझौते के।",
        descBottom: "Tulaa आपकी अपनी सुरक्षित और निजी जगह है।",
        features: [
            {
                title: "प्राइवेसी सबसे पहले",
                desc: "किसी अकाउंट की ज़रूरत नहीं। आपका डेटा आपके डिवाइस पर रहता है।",
                icon: "🔒",
                color: "rgba(99, 102, 241, 0.15)",
            },
            {
                title: "फ्री और ऑफलाइन",
                desc: "कोई विज्ञापन नहीं, कोई ट्रैकिंग नहीं। बिना इंटरनेट के भी बेहतरीन काम करता है।",
                icon: "⚡",
                color: "rgba(34, 197, 94, 0.15)",
            },
            {
                title: "इसे अपना बनाएं",
                desc: "30+ थीम्स और फ़ॉन्ट्स में से चुनें। अपने दैनिक सेहत लक्ष्य खुद तय करें।",
                icon: "🎨",
                color: "rgba(236, 72, 153, 0.15)",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const isHindi = currentLang === "hi";
---

<section class="section section-privacy">
    <div class="container">
        <div class="header-content">
            <h2 class={`section-title ${isHindi ? "is-hindi" : ""}`}>
                <span class="title-main">{t.titleTop}</span>
                <br />
                <span class="text-gradient">{t.titleBottom}</span>
            </h2>
            <p class="body-text">
                {t.descTop}
                <br class="hidden-mobile" />
                {t.descBottom}
            </p>
        </div>

        <div class="features-grid">
            {
                t.features.map((feature) => (
                    <div
                        class="privacy-card"
                        style={`--card-accent: ${feature.color}`}
                    >
                        <div class="card-content">
                            <h3 class="card-title">{feature.title}</h3>
                            <p class="card-desc">{feature.desc}</p>
                        </div>
                        <span class="bg-icon" aria-hidden="true">
                            {feature.icon}
                        </span>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .section {
        padding: 100px 0;
        background-color: var(--bg-main);
    }

    .header-content {
        text-align: center;
        max-width: 800px;
        margin: 0 auto 64px;
    }

    /* --- TYPOGRAPHY --- */
    .section-title {
        font-size: clamp(2.6rem, 4vw, 3.5rem);
        line-height: 1.15;
        font-weight: 800;
        margin-bottom: 24px;
        letter-spacing: -0.02em;
    }

    .title-main {
        color: var(--text-main);
    }

    .section-title.is-hindi {
        line-height: 1.4;
        font-size: clamp(2.2rem, 3.8vw, 3.2rem);
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--primary), #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
        padding-bottom: 4px;
    }

    .body-text {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--text-muted);
    }

    /* --- PREMIUM PRIVACY CARDS --- */
    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .privacy-card {
        position: relative;
        overflow: hidden;
        padding: 40px 32px;
        border-radius: 32px;
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--bg-main), white 5%) 0%,
            var(--card-accent) 100%
        );
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
        transition:
            transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
            box-shadow 0.3s ease;
        text-align: left;
        display: flex;
        flex-direction: column;
        z-index: 1;
    }

    :root[data-theme="dark"] .privacy-card {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.05) 0%,
            var(--card-accent) 100%
        );
    }

    .privacy-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .card-content {
        position: relative;
        z-index: 2;
    }

    /* Subtle Card Hierarchy */
    .card-title {
        font-size: 1.35rem;
        font-weight: 800; /* Extra bold for distinction */
        margin-bottom: 12px;
        color: var(--text-main);
        letter-spacing: -0.01em;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        opacity: 0.85; /* Lowered opacity for hierarchy */
        line-height: 1.6;
        margin: 0;
        font-weight: 400;
    }

    /* --- BACKGROUND ICON EFFECT --- */
    .bg-icon {
        position: absolute;
        bottom: -20px;
        right: -10px;
        font-size: 6.5rem;
        opacity: 0.06;
        transform: rotate(-15deg);
        filter: blur(1px);
        pointer-events: none;
        transition:
            transform 0.5s ease,
            opacity 0.5s ease;
    }

    .privacy-card:hover .bg-icon {
        transform: rotate(0deg) scale(1.1);
        opacity: 0.12;
    }

    @media (max-width: 992px) {
        .features-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }
        .privacy-card {
            padding: 32px;
        }
    }

    @media (max-width: 768px) {
        .section {
            padding: 64px 0;
        }
        .section-title {
            font-size: 2.2rem;
        }
        .section-title.is-hindi {
            font-size: 1.9rem;
        }
        .hidden-mobile {
            display: none;
        }
    }
</style>
