---
// src/components/landing/PrivacyTrust.astro
import SectionCTA from "../SectionCTA.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        titleTop: "100% Private.",
        titleBottom: "Truly Yours.",
        descTop:
            "Wellness shouldn't come with hidden costs or tracking pixels.",
        descBottom: "Tulaa is designed to be your safe, personal sanctuary.",
        features: [
            {
                title: "Privacy First",
                desc: "No account needed. Your data is stored locally. Export or delete it anytime.",
                type: "privacy",
                color: "oklch(65% 0.13 250)",
            },
            {
                title: "Free & Offline",
                desc: "No ads, no tracking, no subscriptions. Works perfectly without internet access.",
                type: "offline",
                color: "oklch(72% 0.15 140)",
            },
            {
                title: "Make it Yours",
                desc: "Choose from 30+ themes and fonts. Set your own daily wellbeing goals.",
                type: "customize",
                color: "oklch(68% 0.17 350)",
            },
        ],
    },
    hi: {
        titleTop: "100% प्राइवेट।",
        titleBottom: "आपकी अपनी।",
        descTop:
            "सेहत की देखभाल—बिना किसी गुप्त कीमत या प्राइवेसी से समझौते के।",
        descBottom: "Tulaa आपकी अपनी सुरक्षित और निजी जगह है।",
        features: [
            {
                title: "प्राइवेसी सबसे पहले",
                desc: "किसी अकाउंट की ज़रूरत नहीं। आपका डेटा आपके डिवाइस पर रहता है।",
                type: "privacy",
                color: "oklch(65% 0.13 250)",
            },
            {
                title: "फ्री और ऑफलाइन",
                desc: "कोई विज्ञापन नहीं, कोई ट्रैकिंग नहीं। बिना इंटरनेट के भी बेहतरीन काम करता है।",
                type: "offline",
                color: "oklch(72% 0.15 140)",
            },
            {
                title: "इसे अपना बनाएं",
                desc: "30+ थीम्स और फ़ॉन्ट्स में से चुनें। अपने दैनिक सेहत लक्ष्य खुद तय करें।",
                type: "customize",
                color: "oklch(68% 0.17 350)",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section class="scroll-section section-privacy">
    <div style="width: 100%;">
        <!-- 1. Left-Aligned Minimalist Header -->
        <div class="container">
            <div class="section-header-left header-content animate-on-scroll">
                <h2 class="section-title">
                    <span class="title-main">{t.titleTop}</span>
                    <br />
                    <span class="text-gradient">{t.titleBottom}</span>
                </h2>
                <p class="body-text">
                    {t.descTop}
                    <br class="hidden-mobile" />
                    {t.descBottom}
                </p>
            </div>
        </div>

        <!-- 2. Single Feature Animation Display Frame -->
        <div class="container stack-stage-container animate-on-scroll delay-1">
            <div class="stage-frame" id="privacy-stage-frame">
                {
                    t.features.map((feature, index) => (
                        <div
                            class={`animated-privacy-card ${index === 0 ? "active" : ""}`}
                            style={`--card-accent: ${feature.color}`}
                        >
                            <!-- Premium Background Watermark Icons -->
                            <div class="card-watermark">
                                {feature.type === "privacy" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg" fill="none" stroke="currentColor" stroke-width="14" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="56" y="104" width="144" height="112" rx="16"/>
                                        <path d="M88,104V72a40,40,0,0,1,80,0v32"/>
                                        <circle cx="128" cy="160" r="12" fill="currentColor" stroke="none"/>
                                    </svg>
                                )}
                                {feature.type === "offline" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg" fill="none" stroke="currentColor" stroke-width="14" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M48,208,208,48"/>
                                        <path d="M84.5,123.5a72,72,0,0,1,87,0"/>
                                        <path d="M50.4,89.5a120,120,0,0,1,155.2,0"/>
                                        <circle cx="128" cy="176" r="12" fill="currentColor" stroke="none"/>
                                    </svg>
                                )}
                                {feature.type === "customize" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg" fill="none" stroke="currentColor" stroke-width="14" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="40" y1="88" x2="216" y2="88"/>
                                        <line x1="40" y1="168" x2="216" y2="168"/>
                                        <circle cx="104" cy="88" r="24"/>
                                        <circle cx="152" cy="168" r="24"/>
                                    </svg>
                                )}
                            </div>

                            <!-- Floating Content Layer -->
                            <div class="card-content">
                                <h3 class="card-title">{feature.title}</h3>
                                <p class="card-desc">{feature.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- 3. Unified Secondary CTA Interaction Hook -->
        <div class="container cta-wrapper animate-on-scroll delay-2">
            <SectionCTA
                href="/faq"
                labelEn="Frequently Asked Questions"
                labelHi="अक्सर पूछे जाने वाले प्रश्न"
            />
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const stage = document.getElementById("privacy-stage-frame");
        if (!stage) return;
        
        const cards = stage.querySelectorAll(".animated-privacy-card");
        if (cards.length === 0) return;

        let activeIndex = 0;

        setInterval(() => {
            cards[activeIndex].classList.remove("active");
            activeIndex = (activeIndex + 1) % cards.length;
            cards[activeIndex].classList.add("active");
        }, 4500); // 4.5s allows comfortable reading for the slightly longer privacy descriptions
    });
</script>

<style>
    .section-privacy {
        width: 100%;
        display: flex;
        align-items: center;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .header-content {
        max-width: 720px;
        margin-bottom: var(--space-md);
        text-align: left;
        width: 100%;
    }

    .section-title {
        font-size: clamp(2.2rem, 5.5vw, 3.8rem);
        letter-spacing: -0.035em;
        line-height: 1.1;
        text-align: left;
        color: var(--text-main);
    }

    .body-text {
        font-size: clamp(1.05rem, 2vw, 1.2rem);
        color: var(--text-muted);
        line-height: 1.6;
        text-align: left;
        margin-top: var(--space-xs);
    }

    /* --- SEQUENTIAL FADE CONTEXT DISPLAY --- */
    .stack-stage-container {
        width: 100%;
        margin-bottom: var(--space-lg);
    }

    .stage-frame {
        position: relative;
        width: 100%;
        max-width: 480px;
        height: 150px; /* Locked height preserves structural grid layouts for 2-3 line descriptions */
        display: grid;
        grid-template-columns: 1fr;
    }

    .animated-privacy-card {
        grid-area: 1 / 1 / 2 / 2;
        background: var(--bg-sub);
        padding: var(--space-md) var(--space-xl) var(--space-md) var(--space-md);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        position: relative;
        overflow: hidden;
        width: 100%;
        height: 100%;
        
        /* High-fidelity Cinematic Fade transition system */
        opacity: 0;
        transform: scale(0.97) translateY(4px);
        filter: blur(4px);
        pointer-events: none;
        transition:
            opacity 0.6s ease-in-out,
            transform 0.6s ease-in-out,
            filter 0.5s ease-in-out,
            border-color 0.3s ease;
    }

    /* Distinct top-edge security highlight line for privacy cards */
    .animated-privacy-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--card-accent);
        opacity: 0.8;
        z-index: 3;
    }

    .animated-privacy-card.active {
        opacity: 1;
        transform: scale(1) translateY(0);
        filter: blur(0);
        pointer-events: auto;
        border-color: color-mix(in srgb, var(--card-accent) 40%, var(--border));
        box-shadow: var(--shadow);
    }

    /* --- PREMIUM WATERMARK POSITIONING SYSTEM --- */
    .card-watermark {
        position: absolute;
        bottom: -20px;
        right: -20px;
        color: var(--card-accent);
        opacity: 0.05;
        pointer-events: none;
        z-index: 1;
        transition: opacity 0.4s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .watermark-svg {
        width: 140px;
        height: 140px;
    }

    .animated-privacy-card.active .card-watermark {
        opacity: 0.09;
        transform: scale(1.05) rotate(-3deg);
    }

    .card-content {
        width: 100%;
        position: relative;
        z-index: 2; /* Ensures text remains crisp and highly legible over background watermarks */
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 750;
        margin: 0 0 var(--space-xs) 0;
        color: var(--text-main);
        letter-spacing: -0.015em;
        line-height: 1.35;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
        font-weight: 400;
        max-width: 90%;
    }

    .cta-wrapper {
        display: flex;
        justify-content: flex-start;
    }

    .hidden-mobile {
        display: inline;
    }

    /* --- GLOBAL LOCALE OPTIMIZATIONS FOR DEVANAGARI --- */
    :lang(hi) .section-title {
        line-height: 1.35;
    }
    :lang(hi) .card-title {
        line-height: 1.45;
    }
    :lang(hi) .card-desc {
        line-height: 1.6;
    }

    /* --- RESPONSIVE OPTIMIZATIONS FOR SMALL HEIGHT DEVICES --- */
    @media (max-height: 740px) {
        .header-content {
            margin-bottom: var(--space-sm);
        }
        .body-text {
            display: none;
        }
        .stack-stage-container {
            margin-bottom: var(--space-sm);
        }
        .stage-frame {
            height: 130px;
        }
        .animated-privacy-card {
            padding: var(--space-md);
        }
        .watermark-svg {
            width: 110px;
            height: 110px;
        }
    }

    @media (max-width: 768px) {
        .hidden-mobile {
            display: none;
        }
        .stage-frame {
            max-width: 100%;
        }
    }
</style>