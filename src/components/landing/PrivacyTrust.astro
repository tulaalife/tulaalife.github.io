---
// src/components/landing/PrivacyTrust.astro
import SectionCTA from "../SectionCTA.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        titleTop: "100% Private.",
        titleBottom: "Truly Yours.",
        descTop:
            "Wellness shouldn't come with hidden costs or tracking pixels.",
        descBottom: "Tulaa is designed to be your safe, personal sanctuary.",
        features: [
            {
                title: "Privacy First",
                desc: "No account needed. Your data is stored locally. Export or delete it anytime.",
                type: "privacy",
                color: "oklch(65% 0.13 250)",
            },
            {
                title: "Free & Offline",
                desc: "No ads, no tracking, no subscriptions. Works perfectly without internet access.",
                type: "offline",
                color: "oklch(72% 0.15 140)",
            },
            {
                title: "Make it Yours",
                desc: "Choose from 30+ themes and fonts. Set your own daily wellbeing goals.",
                type: "customize",
                color: "oklch(68% 0.17 350)",
            },
        ],
    },
    hi: {
        titleTop: "100% प्राइवेट।",
        titleBottom: "आपकी अपनी।",
        descTop:
            "सेहत की देखभाल—बिना किसी गुप्त कीमत या प्राइवेसी से समझौते के।",
        descBottom: "Tulaa आपकी अपनी सुरक्षित और निजी जगह है।",
        features: [
            {
                title: "प्राइवेसी सबसे पहले",
                desc: "किसी अकाउंट की ज़रूरत नहीं। आपका डेटा आपके डिवाइस पर रहता है।",
                type: "privacy",
                color: "oklch(65% 0.13 250)",
            },
            {
                title: "फ्री और ऑफलाइन",
                desc: "कोई विज्ञापन नहीं, कोई ट्रैकिंग नहीं। बिना इंटरनेट के भी बेहतरीन काम करता है।",
                type: "offline",
                color: "oklch(72% 0.15 140)",
            },
            {
                title: "इसे अपना बनाएं",
                desc: "30+ थीम्स और फ़ॉन्ट्स में से चुनें। अपने दैनिक सेहत लक्ष्य खुद तय करें।",
                type: "customize",
                color: "oklch(68% 0.17 350)",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section class="scroll-section section-privacy">
    <div style="width: 100%;">
        <!-- 1. Left-Aligned Minimalist Header -->
        <div class="container">
            <div class="section-header-left header-content animate-on-scroll">
                <h2 class="section-title">
                    <span class="title-main">{t.titleTop}</span>
                    <br />
                    <span class="text-gradient">{t.titleBottom}</span>
                </h2>
                <p class="body-text">
                    {t.descTop}
                    <br class="hidden-mobile" />
                    {t.descBottom}
                </p>
            </div>
        </div>

        <!-- 2. Optimized Responsive Features Grid Layout Track -->
        <div class="container carousel-wrapper animate-on-scroll delay-1">
            <div class="features-track">
                {
                    t.features.map((feature) => (
                        <div
                            class="privacy-card"
                            style={`--card-accent: ${feature.color}`}
                        >
                            <!-- Background Watermark Container -->
                            <div class="card-watermark">
                                {feature.type === "privacy" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg">
                                        <rect width="256" height="256" fill="none"/>
                                        <rect x="40" y="88" width="176" height="128" rx="24" opacity="0.15" fill="currentColor"/>
                                        <rect x="40" y="88" width="176" height="128" rx="24" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M92,88V52a36,36,0,0,1,72,0V88" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                        <circle cx="128" cy="152" r="10" fill="currentColor"/>
                                    </svg>
                                )}
                                {feature.type === "offline" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg">
                                        <rect width="256" height="256" fill="none"/>
                                        <polygon points="120 104 80 104 144 24 136 112 176 112 112 232 120 104" opacity="0.15" fill="currentColor"/>
                                        <polygon points="120 104 80 104 144 24 136 112 176 112 112 232 120 104" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                )}
                                {feature.type === "customize" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg">
                                        <rect width="256" height="256" fill="none"/>
                                        <circle cx="128" cy="128" r="88" opacity="0.15" fill="currentColor"/>
                                        <circle cx="128" cy="128" r="88" fill="none" stroke="currentColor" stroke-width="12" stroke-miterlimit="10"/>
                                        <path d="M128,40a88,88,0,0,1,0,176Z" fill="currentColor" opacity="0.2"/>
                                        <circle cx="96" cy="96" r="12" fill="currentColor"/>
                                        <circle cx="96" cy="160" r="12" fill="currentColor"/>
                                        <circle cx="160" cy="128" r="12" fill="currentColor"/>
                                    </svg>
                                )}
                            </div>

                            <!-- Floating Content Layer -->
                            <div class="card-content">
                                <h3 class="card-title">{feature.title}</h3>
                                <p class="card-desc">{feature.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- 3. Unified Secondary CTA Interaction Hook -->
        <div class="container cta-wrapper animate-on-scroll delay-2">
            <SectionCTA
                href="/faq"
                labelEn="Frequently Asked Questions"
                labelHi="अक्सर पूछे जाने वाले प्रश्न"
            />
        </div>
    </div>
</section>

<style>
    .section-privacy {
        width: 100%;
        display: flex;
        align-items: center;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .header-content {
        max-width: 720px;
        margin-bottom: var(--space-md);
        text-align: left;
        width: 100%;
    }

    .section-title {
        font-size: clamp(2rem, 5vw, 3.8rem);
        letter-spacing: -0.03em;
        line-height: 1.1;
        text-align: left;
    }

    .body-text {
        font-size: clamp(1.05rem, 2vw, 1.2rem);
        color: var(--text-muted);
        line-height: 1.6;
        text-align: left;
        margin-top: var(--space-xs);
    }

    /* --- RESPONSIVE GRID / CAROUSEL --- */
    .carousel-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: var(--space-md);
    }

    .features-track {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-md);
        width: 100%;
    }

    .privacy-card {
        position: relative;
        overflow: hidden;
        padding: clamp(1.5rem, 4vw, 2.2rem);
        border-radius: var(--radius-lg);
        background: var(--bg-sub);
        border: 1px solid var(--border);
        transition:
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            border-color 0.4s ease,
            box-shadow 0.4s ease;
        text-align: left;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        min-height: 180px;
        justify-content: center;
    }

    .privacy-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--card-accent);
        opacity: 0.6;
        z-index: 3;
    }

    .privacy-card:hover {
        transform: translateY(-4px);
        border-color: color-mix(in srgb, var(--card-accent) 30%, var(--border));
        box-shadow: var(--shadow);
    }

    /* --- PREMIUM WATERMARK POSITIONING SYSTEM --- */
    .card-watermark {
        position: absolute;
        bottom: -20px;
        right: -20px;
        color: var(--card-accent);
        opacity: 0.05; /* Balanced ambient backdrop visibility */
        pointer-events: none;
        z-index: 1;
        transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .watermark-svg {
        width: 140px;
        height: 140px;
    }

    .privacy-card:hover .card-watermark {
        opacity: 0.09;
        transform: scale(1.05) rotate(-3deg);
    }

    .card-content {
        width: 100%;
        position: relative;
        z-index: 2; /* Ensures text remains crisp and highly legible over background watermarks */
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0 0 var(--space-xs) 0;
        color: var(--text-main);
        letter-spacing: -0.01em;
        line-height: 1.35;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
        font-weight: 400;
        max-width: 90%;
    }

    .cta-wrapper {
        display: flex;
        justify-content: flex-start;
    }

    /* --- GLOBAL LOCALE OPTIMIZATIONS FOR DEVANAGARI --- */
    :lang(hi) .section-title {
        line-height: 1.35;
    }
    :lang(hi) .card-title {
        line-height: 1.45;
    }
    :lang(hi) .card-desc {
        line-height: 1.6;
    }

    /* --- RESPONSIVE OPTIMIZATIONS FOR SMALL HEIGHT DEVICES --- */
    @media (max-height: 740px) {
        .header-content {
            margin-bottom: var(--space-sm);
        }
        .body-text {
            display: none;
        }
        .carousel-wrapper {
            margin-bottom: var(--space-sm);
        }
        .privacy-card {
            padding: var(--space-md);
            min-height: 140px;
        }
        .watermark-svg {
            width: 110px;
            height: 110px;
        }
    }

    @media (max-width: 992px) {
        .features-track {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scrollbar-width: none;
            -webkit-overflow-scrolling: touch;
            padding: 4px 0 var(--space-sm) 0;
            gap: var(--space-sm);
        }

        .features-track::-webkit-scrollbar {
            display: none;
        }

        .privacy-card {
            scroll-snap-align: start;
            flex: 0 0 280px;
            min-height: 160px;
        }
    }
</style>