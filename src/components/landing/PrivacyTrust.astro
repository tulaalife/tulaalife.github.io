---
// src/components/landing/PrivacyTrust.astro
import SectionCTA from "../SectionCTA.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        titleTop: "100% Private.",
        titleBottom: "Truly Yours.",
        descTop:
            "Wellness shouldn't come with hidden costs or tracking pixels.",
        descBottom: "Tulaa is designed to be your safe, personal sanctuary.",
        features: [
            {
                title: "Privacy First",
                desc: "No account needed. Export or delete it anytime.",
                type: "privacy",
                color: "oklch(65% 0.13 250)",
            },
            {
                title: "Free & Offline",
                desc: "No ads, no tracking, no subscriptions, works offline.",
                type: "offline",
                color: "oklch(72% 0.15 140)",
            },
            {
                title: "Make it Yours",
                desc: "Choose from 30+ themes and fonts.",
                type: "customize",
                color: "oklch(68% 0.17 350)",
            },
        ],
    },
    hi: {
        titleTop: "100% प्राइवेट।",
        titleBottom: "आपकी अपनी।",
        descTop:
            "सेहत की देखभाल—बिना किसी गुप्त कीमत या प्राइवेसी से समझौते के।",
        descBottom: "Tulaa आपकी अपनी सुरक्षित और निजी जगह है।",
        features: [
            {
                title: "प्राइवेसी सबसे पहले",
                desc: "किसी अकाउंट की ज़रूरत नहीं।",
                type: "privacy",
                color: "oklch(65% 0.13 250)",
            },
            {
                title: "फ्री और ऑफलाइन",
                desc: "कोई विज्ञापन नहीं, कोई ट्रैकिंग नहीं।",
                type: "offline",
                color: "oklch(72% 0.15 140)",
            },
            {
                title: "इसे अपना बनाएं",
                desc: "30+ थीम्स और फ़ॉन्ट्स में से चुनें।",
                type: "customize",
                color: "oklch(68% 0.17 350)",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section class="scroll-section section-privacy">
    <div style="width: 100%;">
        <!-- 1. Left-Aligned Minimalist Header -->
        <div class="container">
            <div class="section-header-left header-content animate-on-scroll">
                <h2 class="section-title">
                    <span class="title-main">{t.titleTop}</span>
                    <br />
                    <span class="text-gradient">{t.titleBottom}</span>
                </h2>
                <p class="body-text">
                    {t.descTop}
                    <br class="hidden-mobile" />
                    {t.descBottom}
                </p>
            </div>
        </div>

        <!-- 2. Single Feature Animation Display Frame -->
        <div class="container stack-stage-container animate-on-scroll delay-1">
            <div class="stage-frame" id="privacy-stage-frame">
                {
                    t.features.map((feature, index) => (
                        <div
                            class={`animated-privacy-card premium-gloss-surface ${index === 0 ? "active" : ""}`}
                            style={`--card-accent: ${feature.color}`}
                        >
                            <!-- Premium Background Watermark Icons -->
                            <div class="card-watermark">
                                {feature.type === "privacy" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M216,96V208a8,8,0,0,1-8,8H48a8,8,0,0,1-8-8V96a8,8,0,0,1,8-8H208A8,8,0,0,1,216,96Z" opacity="0.2"></path><path d="M208,80H176V56a48,48,0,0,0-96,0V80H48A16,16,0,0,0,32,96V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V96A16,16,0,0,0,208,80ZM96,56a32,32,0,0,1,64,0V80H96ZM208,208H48V96H208V208Zm-68-56a12,12,0,1,1-12-12A12,12,0,0,1,140,152Z"></path></svg>
                                )}
                                {feature.type === "offline" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M229.06,108.79l-48.7,42,14.88,62.79a8.4,8.4,0,0,1-12.52,9.17L128,189.09,73.28,222.74a8.4,8.4,0,0,1-12.52-9.17l14.88-62.79-48.7-42A8.46,8.46,0,0,1,31.73,94L95.64,88.8l24.62-59.6a8.36,8.36,0,0,1,15.48,0l24.62,59.6L224.27,94A8.46,8.46,0,0,1,229.06,108.79Z" opacity="0.2"></path><path d="M239.18,97.26A16.38,16.38,0,0,0,224.92,86l-59-4.76L143.14,26.15a16.36,16.36,0,0,0-30.27,0L90.11,81.23,31.08,86a16.46,16.46,0,0,0-9.37,28.86l45,38.83L53,211.75a16.38,16.38,0,0,0,24.5,17.82L128,198.49l50.53,31.08A16.4,16.4,0,0,0,203,211.75l-13.76-58.07,45-38.83A16.43,16.43,0,0,0,239.18,97.26Zm-15.34,5.47-48.7,42a8,8,0,0,0-2.56,7.91l14.88,62.8a.37.37,0,0,1-.17.48c-.18.14-.23.11-.38,0l-54.72-33.65a8,8,0,0,0-8.38,0L69.09,215.94c-.15.09-.19.12-.38,0a.37.37,0,0,1-.17-.48l14.88-62.8a8,8,0,0,0-2.56-7.91l-48.7-42c-.12-.1-.23-.19-.13-.5s.18-.27.33-.29l63.92-5.16A8,8,0,0,0,103,91.86l24.62-59.61c.08-.17.11-.25.35-.25s.27.08.35.25L153,91.86a8,8,0,0,0,6.75,4.92l63.92,5.16c.15,0,.24,0,.33.29S224,102.63,223.84,102.73Z"></path></svg>
                                )}
                                {feature.type === "customize" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M176,112,74.34,213.66a8,8,0,0,1-11.31,0L42.34,193a8,8,0,0,1,0-11.31L144,80Z" opacity="0.2"></path><path d="M248,152a8,8,0,0,1-8,8H224v16a8,8,0,0,1-16,0V160H192a8,8,0,0,1,0-16h16V128a8,8,0,0,1,16,0v16h16A8,8,0,0,1,248,152ZM56,72H72V88a8,8,0,0,0,16,0V72h16a8,8,0,0,0,0-16H88V40a8,8,0,0,0-16,0V56H56a8,8,0,0,0,0,16ZM184,192h-8v-8a8,8,0,0,0-16,0v8h-8a8,8,0,0,0,0,16h8v8a8,8,0,0,0,16,0v-8h8a8,8,0,0,0,0-16ZM219.31,80,80,219.31a16,16,0,0,1-22.62,0L36.68,198.63a16,16,0,0,1,0-22.63L176,36.69a16,16,0,0,1,22.63,0l20.68,20.68A16,16,0,0,1,219.31,80Zm-54.63,32L144,91.31l-96,96L68.68,208ZM208,68.69,187.31,48l-32,32L176,100.69Z"></path></svg>
                                )}
                            </div>

                            <!-- Floating Content Layer -->
                            <div class="card-content">
                                <h3 class="card-title">{feature.title}</h3>
                                <p class="card-desc">{feature.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- 3. Unified Secondary CTA Interaction Hook -->
        <div class="container cta-wrapper animate-on-scroll delay-2">
            <SectionCTA
                href="/faq"
                labelEn="Frequently Asked Questions"
                labelHi="अक्सर पूछे जाने वाले प्रश्न"
            />
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const stage = document.getElementById("privacy-stage-frame");
        if (!stage) return;
        
        const cards = stage.querySelectorAll(".animated-privacy-card");
        if (cards.length === 0) return;

        let activeIndex = 0;

        setInterval(() => {
            cards[activeIndex].classList.remove("active");
            activeIndex = (activeIndex + 1) % cards.length;
            cards[activeIndex].classList.add("active");
        }, 4500);
    });
</script>

<style>
    .section-privacy {
        width: 100%;
        display: flex;
        align-items: center;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .header-content {
        max-width: 720px;
        margin-bottom: var(--space-md);
        text-align: left;
        width: 100%;
    }

    .section-title {
        font-size: clamp(2.2rem, 5.5vw, 3.8rem);
        letter-spacing: -0.035em;
        line-height: 1.1;
        text-align: left;
        color: var(--text-main);
    }

    .body-text {
        font-size: clamp(1.05rem, 2vw, 1.2rem);
        color: var(--text-muted);
        line-height: 1.6;
        max-width: 54ch;
        text-align: left;
        margin-top: var(--space-xs);
    }

    /* --- CONTEXT DISPLAY STAGE --- */
    .stack-stage-container {
        width: 100%;
        margin-bottom: var(--space-lg);
    }

    .stage-frame {
        position: relative;
        width: 100%;
        max-width: 480px;
        height: 154px;
        display: grid;
        grid-template-columns: 1fr;
    }

    .animated-privacy-card {
        grid-area: 1 / 1 / 2 / 2;
        padding: var(--space-md) var(--space-xl) var(--space-md) var(--space-md);
        border-radius: var(--radius-lg);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        overflow: hidden;
        width: 100%;
        height: 100%;
        
        opacity: 0;
        transform: translateY(6px) scale(0.98);
        pointer-events: none;
        will-change: transform, opacity;
        transition:
            opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .animated-privacy-card::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--card-accent);
        opacity: 0.8;
        z-index: 3;
    }

    .animated-privacy-card.active {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }

    /* --- CENTERED ALIGNMENT WATERMARK SYSTEM --- */
    .card-watermark {
        position: absolute;
        top: 50%;
        right: 20px;
        transform: translateY(-50%);
        color: var(--card-accent);
        opacity: 0.05;
        pointer-events: none;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        will-change: transform, opacity;
        transition: opacity 0.4s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .card-watermark svg {
        width: 64px;
        height: 64px;
        display: block;
        fill: currentColor;
    }

    .animated-privacy-card.active .card-watermark {
        opacity: 0.12;
        transform: translateY(-50%) scale(1.06) rotate(-4deg);
    }

    .card-content {
        width: 100%;
        position: relative;
        z-index: 2;
        padding-right: 70px; /* Safe alignment boundary text buffer */
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 750;
        margin: 0 0 var(--space-xs) 0;
        color: var(--text-main);
        letter-spacing: -0.015em;
        line-height: 1.35;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
        font-weight: 400;
        max-width: 100%;
    }

    .cta-wrapper {
        display: flex;
        justify-content: flex-start;
    }

    .hidden-mobile {
        display: inline;
    }

    /* --- DEVANAGARI TRANSLATION LAYOUT TWEAKS --- */
    :lang(hi) .section-title {
        line-height: 1.35;
    }
    :lang(hi) .card-title {
        line-height: 1.45;
    }
    :lang(hi) .card-desc {
        line-height: 1.6;
    }

    /* --- RESPONSIVE SCREEN ADAPTATIONS --- */
    @media (max-height: 740px) {
        .header-content {
            margin-bottom: var(--space-sm);
        }
        .body-text {
            display: none;
        }
        .stack-stage-container {
            margin-bottom: var(--space-sm);
        }
        .stage-frame {
            height: 136px;
        }
        .animated-privacy-card {
            padding: var(--space-md);
        }
        .card-watermark svg {
            width: 56px;
            height: 56px;
        }
    }

    @media (max-width: 768px) {
        .hidden-mobile {
            display: none;
        }
        .stage-frame {
            max-width: 100%;
        }
    }
</style>