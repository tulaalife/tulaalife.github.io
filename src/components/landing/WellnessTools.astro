---
// src/components/landing/WellnessTools.astro
import SectionCTA from "../SectionCTA.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        titleTop: "Replace 5 Apps",
        titleBottom: "With One.",
        body: "Simplify your digital wellness. Tulaa brings your essential health tools into one secure, offline-first ecosystem. <strong>No data mining. No subscriptions.</strong>",
        tools: [
            {
                title: "Cycle Tracker",
                desc: "Predict periods & symptoms.",
                type: "cycle",
                color: "oklch(65% 0.18 350)",
            },
            {
                title: "Habit Rhythm",
                desc: "Build consistent healthy streaks.",
                type: "habit",
                color: "oklch(75% 0.15 90)",
            },
            {
                title: "Hydration",
                desc: "Monitor daily water intake.",
                type: "water",
                color: "oklch(62% 0.14 220)",
            },
            {
                title: "Fast Tracker",
                desc: "Track intermittent fasting.",
                type: "fast",
                color: "oklch(60% 0.12 280)",
            },
            {
                title: "Health Tips",
                desc: "Research-backed daily guidance.",
                type: "tips",
                color: "oklch(78% 0.13 60)",
            },
            {
                title: "Care Blog",
                desc: "Learn expert care routines.",
                type: "blog",
                color: "oklch(64% 0.12 150)",
            },
        ],
    },
    hi: {
        titleTop: "5 अलग ऐप्स की जगह",
        titleBottom: "अब सिर्फ एक।",
        body: "अपने डिजिटल वेलनेस को सरल बनाएं। Tulaa आपके ज़रूरी स्वास्थ्य टूल्स को एक सुरक्षित, ऑफलाइन-फर्स्ट ऐप में लाता है। <strong>कोई डेटा माइनिंग नहीं। कोई सब्सक्रिप्शन नहीं।</strong>",
        tools: [
            {
                title: "पीरियड ट्रैकर",
                desc: "पीरियड्स और लक्षणों का अनुमान।",
                type: "cycle",
                color: "oklch(65% 0.18 350)",
            },
            {
                title: "आदत रिदम",
                desc: "स्वस्थ आदतों की निरंतरता।",
                type: "habit",
                color: "oklch(75% 0.15 90)",
            },
            {
                title: "हाइड्रेशन",
                desc: "पानी पीने पर नज़र रखें।",
                type: "water",
                color: "oklch(62% 0.14 220)",
            },
            {
                title: "फास्टिंग",
                desc: "उपवास का समय ट्रैक करें।",
                type: "fast",
                color: "oklch(60% 0.12 280)",
            },
            {
                title: "हेल्थ टिप्स",
                desc: "रिसर्च आधारित सुझाव।",
                type: "tips",
                color: "oklch(78% 0.13 60)",
            },
            {
                title: "थेरेपी ब्लॉग",
                desc: "विशेषज्ञ देखभाल लेख।",
                type: "blog",
                color: "oklch(64% 0.12 150)",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section class="scroll-section section-tools">
    <div class="content-wrapper">
        <!-- 1. Pure Header Container Grid Alignment Module -->
        <div class="container">
            <div class="section-header-left text-col animate-on-scroll">
                <h2 class="section-title">
                    {t.titleTop}
                    <br class="mobile-only" />
                    <span class="text-gradient">{t.titleBottom}</span>
                </h2>
                <p class="body-text" set:html={t.body} />
            </div>
        </div>

        <!-- 2. Full Width Horizontal Carousel Container Track -->
        <div class="container carousel-wrapper animate-on-scroll delay-1">
            <div class="carousel-track">
                {
                    t.tools.map((tool) => (
                        <div
                            class="tool-card"
                            style={`--card-accent: ${tool.color}`}
                        >
                            <!-- Background Premium Watermark System -->
                            <div class="card-watermark">
                                {tool.type === "cycle" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg">
                                        <circle cx="128" cy="104" r="48" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M128,152v64" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M96,184h64" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                )}
                                {tool.type === "habit" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg">
                                        <polygon points="120 104 80 104 144 24 136 112 176 112 112 232 120 104" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                )}
                                {tool.type === "water" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg">
                                        <path d="M208,144A80,80,0,0,1,48,144C48,102,128,32,128,32S208,102,208,144Z" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                )}
                                {tool.type === "fast" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg">
                                        <circle cx="128" cy="128" r="88" fill="none" stroke="currentColor" stroke-width="12" stroke-miterlimit="10"/>
                                        <polyline points="128 72 128 128 176 128" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                )}
                                {tool.type === "tips" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg">
                                        <path d="M112,216h32" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round"/>
                                        <path d="M56,112a72,72,0,1,1,120.4,53.2c-10.4,9.2-16.4,21.6-16.4,34.8v4H96v-4c0-13.2-6-25.6-16.4-34.8A71.6,71.6,0,0,1,56,112Z" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                )}
                                {tool.type === "blog" && (
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="watermark-svg">
                                        <path d="M48,208V56A16,16,0,0,1,64,40H208V192H64A16,16,0,0,0,48,208Z" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M48,208H208" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                )}
                            </div>

                            <!-- Floating Content Module Layer -->
                            <div class="tool-info">
                                <h3 class="card-title">{tool.title}</h3>
                                <p class="card-desc">{tool.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- 3. Aligned Secondary Bottom Button -->
        <div class="container cta-wrapper animate-on-scroll delay-2">
            <SectionCTA
                href="/blog"
                labelEn="Read Wellness Blogs"
                labelHi="वेलनेस ब्लॉग पढ़ें"
            />
        </div>
    </div>
</section>

<style>
    .section-tools {
        width: 100%;
        display: flex;
        align-items: center;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .content-wrapper {
        display: flex;
        flex-direction: column;
        width: 100%;
        margin: 0 auto;
    }

    .text-col {
        margin-bottom: var(--space-md);
        text-align: left;
        width: 100%;
    }

    .section-title {
        font-size: clamp(2rem, 5vw, 3.8rem);
        letter-spacing: -0.03em;
        line-height: 1.1;
        text-align: left;
    }

    .body-text {
        font-size: clamp(1.05rem, 2vw, 1.2rem);
        color: var(--text-muted);
        max-width: 600px;
        text-align: left;
        line-height: 1.6;
        margin-top: var(--space-xs);
    }

    /* --- HORIZONTAL CAROUSEL --- */
    .carousel-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: var(--space-md);
    }

    .carousel-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 60px;
        height: 100%;
        background: linear-gradient(
            to left,
            var(--bg-main) 0%,
            transparent 100%
        );
        pointer-events: none;
        z-index: 5;
    }

    .carousel-track {
        display: flex;
        gap: var(--space-md);
        overflow-x: auto;
        width: 100%;
        padding: 4px 0 var(--space-sm) 0;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }

    .carousel-track::-webkit-scrollbar {
        display: none;
    }

    .tool-card {
        scroll-snap-align: start;
        flex: 0 0 260px;
        background: var(--bg-sub);
        padding: var(--space-md) var(--space-lg) var(--space-md) var(--space-md);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
        min-height: 96px;
        transition:
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            border-color 0.4s ease,
            box-shadow 0.4s ease;
    }

    .tool-card:hover {
        transform: translateY(-4px);
        border-color: color-mix(in srgb, var(--card-accent) 30%, var(--border));
        box-shadow: var(--shadow);
    }

    /* --- BACKGROUND WATERMARK STRATEGY --- */
    .card-watermark {
        position: absolute;
        bottom: -15px;
        right: -15px;
        color: var(--card-accent);
        opacity: 0.04; /* Delicate background footprint */
        pointer-events: none;
        z-index: 1;
        transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .watermark-svg {
        width: 84px;
        height: 84px;
    }

    .tool-card:hover .card-watermark {
        opacity: 0.08;
        transform: scale(1.06) rotate(-4deg);
    }

    .tool-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 2; /* Forces content stacking above background vectors */
        width: 100%;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0 0 4px 0;
        color: var(--text-main);
        letter-spacing: -0.01em;
        line-height: 1.35;
    }

    .card-desc {
        font-size: 0.88rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.4;
        max-width: 92%;
    }

    .cta-wrapper {
        display: flex;
        justify-content: flex-start;
    }

    .mobile-only {
        display: none;
    }

    /* --- GLOBAL LOCALE OPTIMIZATIONS FOR DEVANAGARI --- */
    :lang(hi) .section-title {
        line-height: 1.35;
    }
    :lang(hi) .card-title {
        line-height: 1.45;
        padding-bottom: 1px;
    }
    :lang(hi) .card-desc {
        line-height: 1.5;
    }

    /* --- RESPONSIVE OPTIMIZATIONS FOR SMALL HEIGHT DEVICES --- */
    @media (max-height: 740px) {
        .text-col {
            margin-bottom: var(--space-sm);
        }
        .body-text {
            display: none;
        }
        .carousel-wrapper {
            margin-bottom: var(--space-sm);
        }
        .tool-card {
            padding: var(--space-sm) var(--space-md) var(--space-sm) var(--space-sm);
            flex: 0 0 230px;
            min-height: 80px;
        }
        .watermark-svg {
            width: 72px;
            height: 72px;
        }
    }

    @media (max-width: 768px) {
        .tool-card {
            flex: 0 0 240px;
        }
        .mobile-only {
            display: block;
        }
    }
</style>