---
import SectionCTA from "../SectionCTA.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        badge: "All-in-One Wellness",
        titleTop: "Replace 5 Apps",
        titleBottom: "With One.",
        body: "Simplify your digital wellness. Tulaa brings your essential health tools into one secure, offline-first ecosystem. <strong>No data mining. No subscriptions.</strong>",
        tools: [
            {
                title: "Cycle Tracker",
                desc: "Predict periods & symptoms.",
                icon: "🌸",
                color: "rgba(255, 182, 193, 0.15)",
            },
            {
                title: "Habit Rhythm",
                desc: "Build consistent healthy streaks.",
                icon: "⚡️",
                color: "rgba(255, 215, 0, 0.15)",
            },
            {
                title: "Hydration",
                desc: "Monitor daily water intake.",
                icon: "💧",
                color: "rgba(0, 191, 255, 0.15)",
            },
            {
                title: "Fast Tracker",
                desc: "Track intermittent fasting.",
                icon: "⏳",
                color: "rgba(147, 112, 219, 0.15)",
            },
            {
                title: "Health Tips",
                desc: "Research-backed daily guidance.",
                icon: "💡",
                color: "rgba(255, 165, 0, 0.15)",
            },
            {
                title: "Care Blog",
                desc: "Learn expert care routines.",
                icon: "📚",
                color: "rgba(60, 179, 113, 0.15)",
            },
        ],
    },
    hi: {
        badge: "एक ही ऐप में पूरी सेहत",
        titleTop: "5 अलग ऐप्स की जगह",
        titleBottom: "अब सिर्फ एक।",
        body: "अपने डिजिटल वेलनेस को सरल बनाएं। Tulaa आपके ज़रूरी स्वास्थ्य टूल्स को एक सुरक्षित, ऑफलाइन-फर्स्ट ऐप में लाता है। <strong>कोई डेटा माइनिंग नहीं। कोई सब्सक्रिप्शन नहीं।</strong>",
        tools: [
            {
                title: "पीरियड ट्रैकर",
                desc: "पीरियड्स और लक्षणों का अनुमान।",
                icon: "🌸",
                color: "rgba(255, 182, 193, 0.15)",
            },
            {
                title: "आदत रिदम",
                desc: "स्वस्थ आदतों की निरंतरता।",
                icon: "⚡️",
                color: "rgba(255, 215, 0, 0.15)",
            },
            {
                title: "हाइड्रेशन",
                desc: "पानी पीने पर नज़र रखें।",
                icon: "💧",
                color: "rgba(0, 191, 255, 0.15)",
            },
            {
                title: "फास्टिंग",
                desc: "उपवास का समय ट्रैक करें।",
                icon: "⏳",
                color: "rgba(147, 112, 219, 0.15)",
            },
            {
                title: "हेल्थ टिप्स",
                desc: "रिसर्च आधारित सुझाव।",
                icon: "💡",
                color: "rgba(255, 165, 0, 0.15)",
            },
            {
                title: "थेरेपी ब्लॉग",
                desc: "विशेषज्ञ देखभाल लेख।",
                icon: "📚",
                color: "rgba(60, 179, 113, 0.15)",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section class="scroll-section section-tools">
    <div class="container content-wrapper">
        <!-- Enforced consistent left-alignment utility token -->
        <div class="section-header-left text-col animate-on-scroll">
            <span class="badge-small">{t.badge}</span>
            <h2 class="section-title">
                {t.titleTop}
                <br class="mobile-only" />
                <span class="text-gradient">{t.titleBottom}</span>
            </h2>
            <p class="body-text" set:html={t.body} />
        </div>

        <!-- Horizontal Carousel -->
        <div class="carousel-track animate-on-scroll delay-1">
            {
                t.tools.map((tool) => (
                    <div class="tool-card" style={`--card-bg: ${tool.color}`}>
                        <span class="tool-icon">{tool.icon}</span>
                        <div class="tool-info">
                            <strong>{tool.title}</strong>
                            <p>{tool.desc}</p>
                        </div>
                    </div>
                ))
            }
        </div>

        <div class="cta-wrapper animate-on-scroll delay-2">
            <SectionCTA
                href="/blog"
                labelEn="Read Wellness Blogs"
                labelHi="वेलनेस ब्लॉग पढ़ें"
            />
        </div>
    </div>
</section>

<style>
    .section-tools {
        width: 100%;
        background-color: var(--bg-main);
        display: flex;
        align-items: center;
    }

    .content-wrapper {
        display: flex;
        flex-direction: column;
        width: 100%;
    }

    .text-col {
        margin-bottom: 2.5rem;
        text-align: left; /* FIX: Replaces legacy center text alignments */
        width: 100%;
    }

    .badge-small {
        margin-bottom: 16px;
    }

    .section-title {
        font-size: clamp(2.4rem, 5vw, 3.8rem);
        margin-bottom: 16px;
        text-align: left; /* FIX: Locks the title lines firmly to the left wall */
    }

    .body-text {
        max-width: 650px;
        text-align: left; /* FIX: Prevents description block centering */
    }

    /* --- HORIZONTAL CAROUSEL --- */
    .carousel-track {
        display: flex;
        gap: 20px;
        overflow-x: auto;
        width: 100%;
        padding-bottom: 24px;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }

    .carousel-track::-webkit-scrollbar {
        display: none;
    }

    .tool-card {
        scroll-snap-align: start;
        flex: 0 0 280px;
        background: var(--bg-sub);
        padding: 24px;
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        display: flex;
        align-items: flex-start;
        gap: 16px;
        transition:
            transform 0.3s ease,
            border-color 0.3s ease,
            box-shadow 0.3s ease;
    }

    .tool-card:hover {
        transform: translateY(-5px);
        border-color: var(--primary);
        box-shadow: var(--shadow);
    }

    .tool-icon {
        font-size: 1.5rem;
        background: var(--card-bg);
        padding: 12px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .tool-info strong {
        display: block;
        margin-bottom: 4px;
        color: var(--text-main);
    }

    .tool-info p {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.4;
    }

    .cta-wrapper {
        margin-top: 1.5rem;
        display: flex;
        justify-content: flex-start;
    }

    .mobile-only {
        display: none;
    }

    @media (max-width: 768px) {
        .section-title {
            font-size: 2.2rem;
        }

        .mobile-only {
            display: block;
        }
    }
</style>
