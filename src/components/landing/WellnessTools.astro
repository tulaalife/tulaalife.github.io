---
// src/components/landing/WellnessTools.astro
import SectionCTA from "../SectionCTA.astro";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        titleTop: "Replace 5 Apps",
        titleBottom: "With One.",
        body: "Simplify your digital wellness. Tulaa brings your essential health tools into one secure, offline-first ecosystem. <strong>No data mining. No subscriptions.</strong>",
        tools: [
            {
                title: "Cycle Tracker",
                desc: "Predict periods & symptoms.",
                type: "cycle",
                color: "oklch(65% 0.18 350)",
            },
            {
                title: "Habit Rhythm",
                desc: "Build consistent healthy streaks.",
                type: "habit",
                color: "oklch(75% 0.15 90)",
            },
            {
                title: "Hydration",
                desc: "Monitor daily water intake.",
                type: "water",
                color: "oklch(62% 0.14 220)",
            },
            {
                title: "Fast Tracker",
                desc: "Track intermittent fasting.",
                type: "fast",
                color: "oklch(60% 0.12 280)",
            },
            {
                title: "Health Tips",
                desc: "Research-backed daily guidance.",
                type: "tips",
                color: "oklch(78% 0.13 60)",
            },
            {
                title: "Care Blog",
                desc: "Learn expert care routines.",
                type: "blog",
                color: "oklch(64% 0.12 150)",
            },
        ],
    },
    hi: {
        titleTop: "5 अलग ऐप्स की जगह",
        titleBottom: "अब सिर्फ एक।",
        body: "अपने डिजिटल वेलनेस को सरल बनाएं। Tulaa आपके ज़रूरी स्वास्थ्य टूल्स को एक सुरक्षित, ऑफ़लाइन-फर्स्ट ऐप में लाता है। <strong>कोई डेटा माइनिंग नहीं। कोई सब्सक्रिप्शन नहीं।</strong>",
        tools: [
            {
                title: "पीरियड ट्रैकर",
                desc: "पीरियड्स और लक्षणों का अनुमान।",
                type: "cycle",
                color: "oklch(65% 0.18 350)",
            },
            {
                title: "आदत रिदम",
                desc: "स्वस्थ आदतों की निरंतरता।",
                type: "habit",
                color: "oklch(75% 0.15 90)",
            },
            {
                title: "हाइड्रेशन",
                desc: "पानी पीने पर नज़र रखें।",
                type: "water",
                color: "oklch(62% 0.14 220)",
            },
            {
                title: "फास्टिंग",
                desc: "उपवास का समय ट्रैक करें।",
                type: "fast",
                color: "oklch(60% 0.12 280)",
            },
            {
                title: "हेल्थ टिप्स",
                desc: "रिसर्च आधारित सुझाव।",
                type: "tips",
                color: "oklch(78% 0.13 60)",
            },
            {
                title: "थेरेपी ब्लॉग",
                desc: "विशेषज्ञ देखभाल लेख।",
                type: "blog",
                color: "oklch(64% 0.12 150)",
            },
        ],
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
---

<section class="scroll-section section-tools">
    <div class="content-wrapper">
        <!-- 1. Header Container -->
        <div class="container">
            <div class="section-header-left text-col animate-on-scroll">
                <h2 class="section-title">
                    {t.titleTop}
                    <br />
                    <span class="text-gradient">{t.titleBottom}</span>
                </h2>
                <p class="body-text" set:html={t.body} />
            </div>
        </div>

        <!-- 2. Single Feature Animation Display Frame -->
        <div class="container stack-stage-container animate-on-scroll delay-1">
            <div class="stage-frame" id="animation-stage-frame">
                {
                    t.tools.map((tool, index) => (
                        <div
                            class={`animated-tool-card ${index === 0 ? "active" : ""}`}
                            style={`--card-accent: ${tool.color}`}
                        >
                            <div class="card-watermark">
                                {tool.type === "cycle" && (
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 256 256"
                                        class="watermark-svg"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="14"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <circle cx="128" cy="96" r="56" />
                                        <line
                                            x1="128"
                                            y1="152"
                                            x2="128"
                                            y2="224"
                                        />
                                        <line
                                            x1="96"
                                            y1="192"
                                            x2="160"
                                            y2="192"
                                        />
                                    </svg>
                                )}
                                {tool.type === "habit" && (
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 256 256"
                                        class="watermark-svg"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="14"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <polygon points="136 16 48 136 128 136 120 240 208 120 128 120 136 16" />
                                    </svg>
                                )}
                                {tool.type === "water" && (
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 256 256"
                                        class="watermark-svg"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="14"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="M128,24 C128,24,216,108,216,164 a88,88,0,0,1-176,0 C40,108,128,24,128,24Z" />
                                    </svg>
                                )}
                                {tool.type === "fast" && (
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 256 256"
                                        class="watermark-svg"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="14"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <circle cx="128" cy="128" r="88" />
                                        <polyline points="128 72 128 128 168 152" />
                                    </svg>
                                )}
                                {tool.type === "tips" && (
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 256 256"
                                        class="watermark-svg"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="14"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="M104,224h48M80,112a48,48,0,0,1,96,0c0,26-16,40-24,48v24H104V160C92,152,80,138,80,112Z" />
                                    </svg>
                                )}
                                {tool.type === "blog" && (
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 256 256"
                                        class="watermark-svg"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="14"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="M48,216V40A16,16,0,0,1,64,24H208V200H64A16,16,0,0,0,48,216Z" />
                                        <line
                                            x1="48"
                                            y1="216"
                                            x2="208"
                                            y2="216"
                                        />
                                        <line
                                            x1="96"
                                            y1="72"
                                            x2="160"
                                            y2="72"
                                        />
                                        <line
                                            x1="96"
                                            y1="120"
                                            x2="160"
                                            y2="120"
                                        />
                                    </svg>
                                )}
                            </div>

                            <div class="tool-info">
                                <h3 class="card-title">{tool.title}</h3>
                                <p class="card-desc">{tool.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- 3. Bottom Button Line -->
        <div class="container cta-wrapper animate-on-scroll delay-2">
            <SectionCTA
                href="/blog"
                labelEn="Read Wellness Blogs"
                labelHi="वेलनेस ब्लॉग पढ़ें"
            />
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const stage = document.getElementById("animation-stage-frame");
        if (!stage) return;

        const cards = stage.querySelectorAll(".animated-tool-card");
        if (cards.length === 0) return;

        let activeIndex = 0;

        setInterval(() => {
            cards[activeIndex].classList.remove("active");
            activeIndex = (activeIndex + 1) % cards.length;
            cards[activeIndex].classList.add("active");
        }, 4000); // Transitions smoothly every 4 seconds
    });
</script>

<style>
    .section-tools {
        width: 100%;
        display: flex;
        align-items: center;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .content-wrapper {
        display: flex;
        flex-direction: column;
        width: 100%;
        margin: 0 auto;
    }

    .text-col {
        margin-bottom: var(--space-md);
        text-align: left;
        width: 100%;
    }

    .section-title {
        font-size: clamp(2.2rem, 5.5vw, 3.8rem);
        letter-spacing: -0.035em;
        line-height: 1.1;
        text-align: left;
        color: var(--text-main);
    }

    .body-text {
        font-size: clamp(1.05rem, 2vw, 1.2rem);
        color: var(--text-muted);
        max-width: 600px;
        text-align: left;
        line-height: 1.6;
        margin-top: var(--space-xs);
    }

    .body-text :global(strong) {
        color: var(--text-main);
        font-weight: 700;
    }

    /* --- SEQUENTIAL FADE CONTEXT DISPLAY --- */
    .stack-stage-container {
        width: 100%;
        margin-bottom: var(--space-lg);
    }

    .stage-frame {
        position: relative;
        width: 100%;
        max-width: 480px;
        height: 110px; /* Locked height preserves structural grid layouts */
        display: grid;
        grid-template-columns: 1fr;
    }

    .animated-tool-card {
        grid-area: 1 / 1 / 2 / 2;
        background: var(--bg-sub);
        padding: var(--space-md) var(--space-xl) var(--space-md) var(--space-md);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
        width: 100%;
        height: 100%;

        /* High-fidelity Cinematic Fade transition system */
        opacity: 0;
        transform: scale(0.97) translateY(4px);
        filter: blur(4px);
        pointer-events: none;
        transition:
            opacity 0.6s ease-in-out,
            transform 0.6s ease-in-out,
            filter 0.5s ease-in-out,
            border-color 0.3s ease;
    }

    .animated-tool-card.active {
        opacity: 1;
        transform: scale(1) translateY(0);
        filter: blur(0);
        pointer-events: auto;
        border-color: color-mix(in srgb, var(--card-accent) 40%, var(--border));
        box-shadow: var(--shadow);
    }

    /* --- RE-ARCHITECTED WATERMARK MARKUP --- */
    .card-watermark {
        position: absolute;
        bottom: -10px;
        right: -10px;
        color: var(--card-accent);
        opacity: 0.05;
        pointer-events: none;
        z-index: 1;
        transition:
            opacity 0.4s ease,
            transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .watermark-svg {
        width: 96px;
        height: 96px;
    }

    .animated-tool-card.active .card-watermark {
        opacity: 0.08;
        transform: scale(1.04) rotate(-2deg);
    }

    .tool-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 750;
        margin: 0 0 4px 0;
        color: var(--text-main);
        letter-spacing: -0.015em;
        line-height: 1.3;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.4;
        max-width: 90%;
    }

    .cta-wrapper {
        display: flex;
        justify-content: flex-start;
    }

    .mobile-only {
        display: none;
    }

    /* --- DEVANAGARI ALIGNMENT OPTIMIZATIONS --- */
    :lang(hi) .section-title {
        line-height: 1.35;
    }
    :lang(hi) .card-title {
        line-height: 1.45;
    }
    :lang(hi) .card-desc {
        line-height: 1.5;
    }

    /* --- RESPONSIVE CONTROLS --- */
    @media (max-height: 740px) {
        .text-col {
            margin-bottom: var(--space-sm);
        }
        .body-text {
            display: none;
        }
        .stack-stage-container {
            margin-bottom: var(--space-sm);
        }
        .stage-frame {
            height: 96px;
        }
    }

    @media (max-width: 768px) {
        .mobile-only {
            display: block;
        }
        .stage-frame {
            max-width: 100%;
        }
    }
</style>
