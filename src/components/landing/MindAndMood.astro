---
// src/components/MindSection.astro
import SectionCTA from "../SectionCTA.astro";
import { guidedAudios } from "../../data/generated";

const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        titleTop: "Calm Your Mind.",
        titleBottom: "Understand Your Emotions.",
        body: "From traditional chanting to anxiety relief. Listen to guided audio and journal your thoughts in a private, safe space.",
        ctaEn: "Explore Audio Sessions",
        ctaHi: "ऑडियो सेशन देखें",
        play: "Listen Now",
    },
    hi: {
        titleTop: "अपने मन को शांत करें।",
        titleBottom: "अपनी भावनाओं को समझें।",
        body: "पारंपरिक मंत्रोच्चार से लेकर चिंता से राहत तक। निर्देशित ऑडियो सुनें और एक सुरक्षित, निजी स्थान पर अपने विचार लिखें।",
        ctaEn: "Explore Audio Sessions",
        ctaHi: "ऑडियो सेशन देखें",
        play: "अभी सुनें",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;

const baseAudioHref = currentLang === "hi" ? "/hi/audio" : "/audio";

const displayAudios = guidedAudios
    .filter((a) => a.language === currentLang)
    .slice(0, 8);
---

<section class="scroll-section section-mind">
    <div class="container animate-on-scroll">
        <div class="header-row">
            <!-- Utilized section-header-left class token for structural typography framework alignment -->
            <div class="section-header-left header-text">
                <h2 class="section-title">
                    {t.titleTop}
                    <br />
                    <span class="text-gradient">{t.titleBottom}</span>
                </h2>
                <p class="body-text max-w-md" style="margin-top: 8px;">
                    {t.body}
                </p>
            </div>

            <div class="desktop-cta hidden-mobile">
                <SectionCTA
                    href={baseAudioHref}
                    labelEn={t.ctaEn}
                    labelHi={t.ctaHi}
                />
            </div>
        </div>

        <div class="carousel-wrapper animate-on-scroll delay-1">
            <div class="glow-orb"></div>

            <div class="carousel-track" id="audio-plans-track">
                {
                    displayAudios.map((audio) => (
                        <a
                            href={`${baseAudioHref}/${audio.slug}`}
                            class="carousel-card"
                        >
                            <div class="card-image">
                                <img
                                    src={audio.image}
                                    alt={audio.title}
                                    loading="lazy"
                                    decoding="async"
                                />
                                <div class="play-overlay">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                        class="play-icon"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                </div>
                            </div>
                            <div class="card-content">
                                <h3 class="card-title">{audio.title}</h3>
                                <p class="card-desc">{audio.subtitle}</p>
                                <div class="card-footer">
                                    <span class="view-link">{t.play}</span>
                                    <span class="icon">→</span>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>

        <div class="mobile-cta animate-on-scroll delay-2">
            <SectionCTA
                href={baseAudioHref}
                labelEn={t.ctaEn}
                labelHi={t.ctaHi}
            />
        </div>
    </div>
</section>

<style>
    .section-mind {
        width: 100%;
        background-color: var(--bg-main);
    }

    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 16px;
        position: relative;
        z-index: 2;
    }

    .header-text {
        max-width: 600px;
    }

    .section-title {
        font-size: clamp(2.2rem, 4vw, 3.2rem);
    }

    /* --- HORIZONTAL CAROUSEL --- */
    .carousel-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: 16px;
    }

    .carousel-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 80px;
        height: 100%;
        background: linear-gradient(to right, transparent, var(--bg-main));
        pointer-events: none;
        z-index: 5;
    }

    html[data-theme="light"] .carousel-wrapper::after,
    html[data-theme="dark"] .carousel-wrapper::after {
        background: linear-gradient(
            to left,
            var(--bg-main) 0%,
            transparent 100%
        );
    }

    .carousel-track {
        display: flex;
        gap: 20px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-padding-left: 0;
        padding-bottom: 16px;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
        position: relative;
        z-index: 2;
    }

    .carousel-track::-webkit-scrollbar {
        display: none;
    }

    .carousel-card {
        scroll-snap-align: start;
        flex: 0 0 300px;
        display: flex;
        flex-direction: column;
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        height: 100%;
    }

    .carousel-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
        border-color: var(--primary);
    }

    .card-image {
        position: relative;
        aspect-ratio: 16/10;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
        background-color: #000;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.85;
        transition:
            transform 0.5s ease,
            opacity 0.5s ease;
    }

    .carousel-card:hover .card-image img {
        transform: scale(1.03);
        opacity: 0.7;
    }

    .play-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 44px;
        height: 44px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.4);
    }

    .play-icon {
        width: 20px;
        height: 20px;
        color: white;
        margin-left: 2px;
    }

    .carousel-card:hover .play-overlay {
        background: var(--primary);
        transform: translate(-50%, -50%) scale(1.1);
        border-color: var(--primary);
    }

    .card-content {
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-title {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 4px;
        line-height: 1.3;
    }

    .card-desc {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.4;
        margin-bottom: 12px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex-grow: 1;
    }

    .card-footer {
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
        color: var(--primary);
        font-size: 0.9rem;
    }

    .glow-orb {
        position: absolute;
        top: 50%;
        left: 30%;
        transform: translateY(-50%);
        width: 80%;
        height: 180%;
        background: radial-gradient(
            circle,
            color-mix(in srgb, var(--primary), transparent 90%) 0%,
            transparent 60%
        );
        z-index: 1;
        pointer-events: none;
    }

    .mobile-cta {
        display: none;
    }

    @media (max-width: 768px) {
        .header-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
            margin-bottom: 16px;
        }
        .hidden-mobile {
            display: none;
        }
        .carousel-card {
            flex: 0 0 260px;
        }
        .carousel-wrapper::after {
            width: 40px;
        }
        .mobile-cta {
            display: flex;
            justify-content: center;
            margin-top: 8px;
        }
    }
</style>
