---
const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        author: "Latika Bissa",
        authorLabel: "Yoga Therapist",
        authorTrust: "Rated 5 stars • 5,000+ Happy Students",
        cred1: "🧘‍♀️ 10+ Years of Experience",
        cred2: "🏅 Gold Medalist, M.Sc Yoga Therapy",
    },
    hi: {
        author: "लतिका बिस्सा",
        authorLabel: "योग चिकित्सक",
        authorTrust: "5-स्टार रेटिंग • 5,000+ संतुष्ट साधक",
        cred1: "🧘‍♀️ 10+ वर्षों का अनुभव",
        cred2: "🏅 स्वर्ण पदक विजेता, M.Sc योग थेरेपी",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const authorImg = "/images/latika.png";
---

<section class="scroll-section author-section">
    <div class="container layout-wrapper">
        <div class="author-card">
            <!-- Left Content Pane -->
            <div class="author-content">
                <div class="author-header">
                    <span class="author-label">{t.authorLabel}</span>
                    <h2 class="author-name">{t.author}</h2>
                    <div
                        class="author-trust text-gradient"
                        set:html={t.authorTrust}
                    />
                </div>

                <div class="creds-list">
                    <div class="cred-item">{t.cred1}</div>
                    <div class="cred-item">{t.cred2}</div>
                </div>
            </div>

            <!-- Right Visual Pane -->
            <div class="author-image-pane">
                <img
                    src={authorImg}
                    alt="Latika Bissa"
                    class="author-img"
                    loading="lazy"
                    decoding="async"
                />
            </div>
        </div>
    </div>
</section>

<style>
    .author-section {
        width: 100%;
        display: flex;
        align-items: center;
        background-color: transparent;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .layout-wrapper {
        width: 100%;
        display: flex;
        justify-content: flex-start;
    }

    /* --- MINIMALIST FLAT CONTAINER --- */
    .author-card {
        width: 100%;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        background: transparent;
        border: none;
        border-radius: 0;
        box-shadow: none;
    }

    .author-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
        z-index: 2;
        text-align: left;
        padding: 0;
        padding-right: var(--space-xl);
    }

    .author-header {
        margin-bottom: var(--space-md);
    }

    .author-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--primary);
        font-weight: 700;
        letter-spacing: 0.1em;
        display: block;
        margin-bottom: var(--space-xs);
    }

    .author-name {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
        color: var(--text-main);
        margin: 0 0 6px 0;
        font-weight: var(--fw-bold);
        letter-spacing: -0.035em;
        line-height: 1.1;
    }

    .author-trust {
        font-size: clamp(0.95rem, 1.8vw, 1.1rem);
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text-muted);
        display: inline-block;
        margin-top: 2px;
    }

    /* Polished Line Item Layout for Credentials */
    .creds-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-top: var(--space-xs);
        max-width: 480px;
    }

    .cred-item {
        font-size: 1.05rem;
        color: var(--text-main);
        font-weight: 500;
        line-height: 1.4;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .author-image-pane {
        width: 45%;
        max-width: 400px;
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        background: transparent;
        flex-shrink: 0;
    }

    /* Soft organic directional drop-shadow optimized for light/dark viewports */
    .author-img {
        width: 100%;
        height: auto;
        max-height: 480px;
        object-fit: contain;
        display: block;
        filter: drop-shadow(
            0 16px 24px color-mix(in srgb, var(--text-main) 8%, transparent)
        );
    }

    /* --- GLOBAL LOCALE OPTIMIZATIONS FOR DEVANAGARI --- */
    :lang(hi) .author-name {
        line-height: 1.35;
        padding-bottom: 4px;
    }

    :lang(hi) .author-trust {
        line-height: 1.4;
        padding: 4px 0;
    }

    /* --- RESPONSIVE OPTIMIZATIONS FOR SMALL HEIGHT DEVICES --- */
    @media (max-height: 740px) {
        .author-header {
            margin-bottom: var(--space-sm);
        }
        .author-name {
            font-size: 1.8rem;
        }
        .creds-list {
            gap: var(--space-xs);
        }
        .cred-item {
            font-size: 0.95rem;
        }
        .author-img {
            max-height: 360px;
        }
    }

    @media (max-width: 992px) {
        .author-content {
            padding-right: var(--space-lg);
        }
    }

    @media (max-width: 768px) {
        .author-card {
            flex-direction: column;
            align-items: flex-start;
        }

        .author-content {
            padding-right: 0;
            margin-bottom: var(--space-md);
        }

        .author-name {
            font-size: 2rem;
        }

        .author-trust {
            font-size: 0.95rem;
        }

        .author-image-pane {
            width: 100%;
            max-width: 100%;
            justify-content: center;
        }

        .author-img {
            max-height: 340px;
        }
    }
</style>
