---
const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        author: "Latika Bissa",
        authorLabel: "Yoga Therapist",
        authorTrust: "Rated 5 stars • 5,000+ Happy Students",
        cred1: "🧘‍♀️ 10+ Years of Experience",
        cred2: "🏅 Gold Medalist, M.Sc Yoga Therapy",
    },
    hi: {
        author: "लतिका बिस्सा",
        authorLabel: "योग चिकित्सक",
        authorTrust: "5-स्टार रेटिंग • 5,000+ संतुष्ट साधक",
        cred1: "🧘‍♀️ 10+ वर्षों का अनुभव",
        cred2: "🏅 स्वर्ण पदक विजेता, M.Sc योग थेरेपी",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const authorImg = "/images/latika.png";
---

<section class="scroll-section author-section">
    <div class="container layout-wrapper">
        <div class="author-card">
            <!-- Left Content Pane -->
            <div class="author-content">
                <div class="author-header">
                    <span class="author-label">{t.authorLabel}</span>
                    <h2 class="author-name">{t.author}</h2>
                    <div
                        class="author-trust text-gradient"
                        set:html={t.authorTrust}
                    />
                </div>

                <div class="creds-list">
                    <div class="cred-item">{t.cred1}</div>
                    <div class="cred-item">{t.cred2}</div>
                </div>
            </div>

            <!-- Right Visual Pane -->
            <div class="author-image-pane">
                <img
                    src={authorImg}
                    alt="Latika Bissa"
                    class="author-img"
                    loading="lazy"
                    decoding="async"
                />
            </div>
        </div>
    </div>
</section>

<style>
    .author-section {
        width: 100%;
        display: flex;
        align-items: center;
        background-color: transparent;
    }

    .layout-wrapper {
        width: 100%;
        display: flex;
        justify-content: flex-start;
    }

    .author-card {
        width: 100%;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: stretch;
        overflow: hidden;
        background: var(--bg-sub);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        transition:
            transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
            border-color 0.5s ease;
    }

    .author-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
        z-index: 2;
        text-align: left;
        padding: 54px 64px;
    }

    .author-header {
        margin-bottom: 28px;
    }

    .author-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        color: var(--primary);
        font-weight: 700;
        letter-spacing: 0.08em;
        display: block;
        margin-bottom: 10px;
    }

    .author-name {
        font-size: clamp(2.4rem, 5vw, 3.4rem);
        color: var(--text-main);
        margin: 0 0 6px 0;
        font-weight: var(--fw-bold);
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .author-trust {
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        white-space: normal;
    }

    .creds-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .cred-item {
        font-size: 1.05rem;
        color: var(--text-muted);
        font-weight: 500;
    }

    .author-image-pane {
        width: 45%;
        max-width: 440px;
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        background: transparent;
        flex-shrink: 0;
        padding-right: 40px;

        /* Linear gradient mask to clear away edge pixels cleanly */
        -webkit-mask-image: linear-gradient(
            to bottom,
            black 88%,
            transparent 100%
        );
        mask-image: linear-gradient(to bottom, black 88%, transparent 100%);
    }

    .author-img {
        width: 100%;
        max-height: 95%;
        object-fit: contain;
        object-position: bottom center;
        transform-origin: bottom center;
        display: block;
        filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.06));
    }

    @media (max-width: 992px) {
        .author-content {
            padding: 44px 36px;
        }
        .author-image-pane {
            width: 40%;
            padding-right: 20px;
        }
    }

    @media (max-width: 768px) {
        .author-card {
            flex-direction: column;
        }

        .author-content {
            padding: 40px 24px 0 24px;
        }

        .author-name {
            font-size: 2.2rem;
        }

        .author-trust {
            font-size: 1rem;
        }

        .author-image-pane {
            width: 100%;
            max-width: 100%;
            height: 340px;
            margin-top: 20px;
            padding-right: 0;
        }

        .author-img {
            height: 100%;
        }
    }
</style>
