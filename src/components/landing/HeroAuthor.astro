---
const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        author: "Latika Bissa",
        authorLabel: "Yoga Therapist",
        authorTrust: "Rated 5 stars • 5,000+ Happy Students",
        cred1: "🧘‍♀️ 10+ Years of Experience",
        cred2: "🏅 Gold Medalist, M.Sc Yoga Therapy",
    },
    hi: {
        author: "लतिका बिस्सा",
        authorLabel: "योग चिकित्सक",
        authorTrust: "5-स्टार रेटिंग • 5,000+ संतुष्ट साधक",
        cred1: "🧘‍♀️ 10+ वर्षों का अनुभव",
        cred2: "🏅 स्वर्ण पदक विजेता, M.Sc योग थेरेपी",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const authorImg = "/images/latika.png";
---

<section class="scroll-section author-section">
    <div class="container layout-wrapper">
        <div class="author-card">
            <!-- Left Content: Clean, flat typography -->
            <div class="author-content">
                <div class="author-header">
                    <span class="author-label">{t.authorLabel}</span>
                    <h2 class="author-name">{t.author}</h2>
                    <div class="author-trust text-gradient">
                        {t.authorTrust}
                    </div>
                </div>

                <div class="creds-list">
                    <div class="cred-item">{t.cred1}</div>
                    <div class="cred-item">{t.cred2}</div>
                </div>
            </div>

            <!-- Right Visual: Flat background, drop-shadow on the image itself -->
            <div class="author-image-pane">
                <img
                    src={authorImg}
                    alt="Latika Bissa"
                    class="author-img"
                    loading="lazy"
                    decoding="async"
                />
            </div>
        </div>
    </div>
</section>

<style>
    .author-section {
        width: 100%;
        display: flex;
        align-items: center;
    }

    .layout-wrapper {
        width: 100%;
        display: flex;
        justify-content: flex-start;
    }

    /* Flat, clean card architecture */
    .author-card {
        width: 100%;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: stretch;
        overflow: hidden;
        transition:
            transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
            border-color 0.5s ease,
            box-shadow 0.5s ease;
    }

    .author-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
        z-index: 2;
        text-align: left;
    }

    .author-header {
        margin-bottom: 32px;
    }

    .author-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        color: var(--primary);
        font-weight: 700;
        letter-spacing: 0.08em;
        display: block;
        margin-bottom: 12px;
    }

    .author-name {
        font-size: clamp(2.4rem, 5vw, 3.4rem);
        color: var(--text-main);
        margin: 0 0 8px 0;
        font-weight: var(--fw-bold);
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .author-trust {
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
    }

    .creds-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .cred-item {
        font-size: 1.1rem;
        color: var(--text-muted);
        font-weight: 500;
    }

    /* Removed all gradients, added padding for breathing room */
    .author-image-pane {
        width: 45%;
        max-width: 440px;
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        background: transparent;
        flex-shrink: 0;
        padding-right: 40px;

        /* ADD THESE TWO LINES 👇 */
        -webkit-mask-image: linear-gradient(
            to bottom,
            black 90%,
            transparent 100%
        );
        mask-image: linear-gradient(to bottom, black 90%, transparent 100%);
    }

    .author-img {
        width: 100%;
        max-height: 95%; /* Tiny gap at the top so it doesn't touch the ceiling */
        object-fit: contain;
        object-position: bottom center;
        transform-origin: bottom center;
        display: block;
        /* Drops a soft shadow directly from the transparent pixels of the PNG */
        filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.08));
        transition:
            transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
            filter 0.5s ease;
    }

    /* Responsive Adjustments */
    @media (max-width: 992px) {
        .author-image-pane {
            width: 40%;
            padding-right: 24px;
        }
    }

    @media (max-width: 768px) {
        .author-card {
            flex-direction: column;
        }

        .author-image-pane {
            width: 100%;
            max-width: 100%;
            height: 320px;
            margin-top: 24px;
            padding-right: 0; /* Reset padding for mobile */
            padding-bottom: 0;
        }

        .author-img {
            height: 100%;
            object-position: bottom center;
        }
    }
</style>
