---
const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        sectionLabel: "Meet Your Instructor",
        authorLabel: "Yoga Therapist",
        author: "Latika Bissa",
        authorFounder: "Founder Tulaa, YogaWithLatika",
        cred1: "🧘‍♀️ 12+ Years of Experience",
        cred2: "🏅 Gold Medalist, M.Sc Yoga Therapy",
        cred3: "⭐ 5 Star rating on Google",
        cred4: "👀 50 lakh views on social media",
        cred5: "🔬 Expert in Pain relief, Pregnancy",
    },
    hi: {
        sectionLabel: "अपने इंस्ट्रक्टर से मिलें",
        authorLabel: "योग चिकित्सक",
        author: "लतिका बिस्सा",
        authorFounder: "संस्थापक Tulaa, YogaWithLatika",
        cred1: "🧘‍♀️ 12+ वर्षों का अनुभव",
        cred2: "🏅 स्वर्ण पदक विजेता, M.Sc योग थेरेपी",
        cred3: "⭐ 5-स्टार रेटिंग गूगल पर",
        cred4: "👀 सोशल मीडिया पर 50 लाख व्यूज़",
        cred5: "🔬 दर्द प्रबंधन और गर्भावस्था के विशेषज्ञ",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const authorImg = "/images/latika.png";
---

<section class="scroll-section author-section">
    <div class="container layout-wrapper">
        <div class="instructor-minimal-profile animate-on-scroll">
            <!-- Left Grid: Content and Credentials Meta Blocks -->
            <div class="profile-details-column">
                <div class="profile-header-meta">
                    <span class="section-label-banner">{t.sectionLabel}</span>
                    <span class="author-label">{t.authorLabel}</span>
                    <h2 class="author-name">{t.author}</h2>
                    <p class="author-founder-title">{t.authorFounder}</p>
                </div>

                <div class="compact-creds-box">
                    <div class="cred-line-item trust-highlight">{t.cred1}</div>
                    <div class="cred-line-item">{t.cred2}</div>
                    <div class="cred-line-item">{t.cred3}</div>
                    <div class="cred-line-item">{t.cred4}</div>
                    <div class="cred-line-item">{t.cred5}</div>
                </div>
            </div>

            <!-- Right Grid: Top Centered High-Trust Headshot Avatar -->
            <div class="avatar-container premium-gloss-surface">
                <img
                    src={authorImg}
                    alt="Latika Bissa"
                    class="instructor-headshot"
                    loading="lazy"
                    decoding="async"
                />
            </div>
        </div>
    </div>
</section>

<style>
    .author-section {
        width: 100%;
        display: flex;
        align-items: center;
        background-color: transparent;
        padding-top: var(--section-v-padding);
        padding-bottom: var(--section-v-padding);
    }

    .layout-wrapper {
        width: 100%;
    }

    /* Streamlined Layout Structure */
    .instructor-minimal-profile {
        width: 100%;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-xl);
    }

    .profile-details-column {
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    /* --- 1. HEADSHOT FRAME GRAPHIC WITH PREMIUM GLOSS --- */
    .avatar-container {
        width: 154px;
        height: 154px;
        border-radius: 50%;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        will-change: transform;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .avatar-container:hover {
        transform: scale(1.03);
    }

    .instructor-headshot {
        position: absolute;
        width: 150%;
        height: auto;
        left: 50%;
        top: 20%;
        transform: translateX(-50%);
    }

    /* --- 2. EDITORIAL METADATA HOLDER --- */
    .profile-header-meta {
        display: flex;
        flex-direction: column;
        text-align: left;
    }

    .section-label-banner {
        font-size: 0.72rem;
        text-transform: uppercase;
        color: var(--text-muted);
        font-weight: 700;
        letter-spacing: 0.12em;
        display: block;
        margin-bottom: 4px;
    }

    .author-label {
        font-size: 0.82rem;
        text-transform: uppercase;
        color: var(--primary);
        font-weight: 750;
        letter-spacing: 0.05em;
        display: block;
        margin-bottom: var(--space-xs);
    }

    .author-name {
        font-size: clamp(2.4rem, 5vw, 3.4rem);
        color: var(--text-main);
        margin: 0 0 4px 0;
        font-weight: var(--fw-bold);
        letter-spacing: -0.035em;
        line-height: 1.1;
    }

    .author-founder-title {
        font-size: clamp(1.05rem, 2vw, 1.25rem);
        font-weight: 600;
        color: var(--text-muted);
        margin: 0 0 var(--space-lg) 0;
        line-height: 1.4;
    }

    /* --- 3. HIGH-DENSITY COMPACT CREDENTIALS LIST --- */
    .compact-creds-box {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 12px var(--space-md);
        width: 100%;
        padding-top: var(--space-md);
        border-top: 1px solid var(--border);
    }

    .cred-line-item {
        font-size: 0.98rem;
        color: var(--text-main);
        font-weight: 500;
        line-height: 1.4;
        display: flex;
        align-items: flex-start;
        gap: 10px;
        text-align: left;
    }

    .trust-highlight {
        font-weight: 650;
    }

    /* --- GLOBAL LOCALE OPTIMIZATIONS FOR DEVANAGARI --- */
    :lang(hi) .author-name {
        line-height: 1.35;
    }
    :lang(hi) .author-founder-title {
        line-height: 1.45;
    }
    :lang(hi) .cred-line-item {
        font-size: 1rem;
    }
    :lang(hi) .section-label-banner {
        letter-spacing: normal;
        text-transform: none;
        font-size: 0.82rem;
        margin-bottom: 4px;
    }
    :lang(hi) .author-label {
        letter-spacing: normal;
        text-transform: none;
        font-size: 0.92rem;
    }

    /* --- RESPONSIVE ADAPTATIONS --- */
    @media (max-width: 768px) {
        .instructor-minimal-profile {
            flex-direction: column;
            align-items: flex-start;
            gap: var(--space-md);
        }

        .profile-details-column {
            width: 100%;
        }

        .avatar-container {
            width: 120px;
            height: 120px;
            order: -1; /* Retain headshot positioning at top framework layout on mobiles */
            margin-bottom: var(--space-xs);
        }

        .author-name {
            font-size: 2.2rem;
        }

        .compact-creds-box {
            grid-template-columns: 1fr;
            gap: 10px;
        }
    }

    @media (max-height: 740px) and (min-width: 769px) {
        .avatar-container {
            width: 120px;
            height: 120px;
        }
        .author-name {
            font-size: 2rem;
        }
        .compact-creds-box {
            gap: 8px;
        }
    }
</style>
