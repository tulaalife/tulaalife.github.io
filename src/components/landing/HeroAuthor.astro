---
const currentLang = Astro.currentLocale || "en";

const ui = {
    en: {
        author: "Latika Bissa",
        authorLabel: "Yoga Therapist",
        authorTrust: "Rated 5 stars • 5,000+ Happy Students",
        cred1: "🧘‍♀️ 10+ Years of Experience",
        cred2: "🏅 Gold Medalist, M.Sc Yoga Therapy",
    },
    hi: {
        author: "लतिका बिस्सा",
        authorLabel: "योग चिकित्सक",
        authorTrust: "5-स्टार रेटिंग • 5,000+ संतुष्ट साधक",
        cred1: "🧘‍♀️ 10+ वर्षों का अनुभव",
        cred2: "🏅 स्वर्ण पदक विजेता, M.Sc योग थेरेपी",
    },
};

const t = ui[currentLang as keyof typeof ui] || ui.en;
const authorImg = "/images/latika.png";
---

<section class="scroll-section author-section">
    <!-- Outer container enforces the standard 1120px max-width -->
    <div class="container">
        <a
            href="https://yogawithlatika.com"
            target="_blank"
            class="author-link animate-on-scroll"
            aria-label="Visit Latika Bissa's website"
        >
            <div class="author-card">
                <!-- Left Content: Takes up all available flex space -->
                <div class="author-content">
                    <div class="author-header">
                        <span class="author-label">{t.authorLabel}</span>
                        <h2 class="author-name">{t.author}</h2>
                        <div class="author-trust text-gradient">
                            {t.authorTrust}
                        </div>
                    </div>

                    <div class="creds-list">
                        <div class="cred-item">{t.cred1}</div>
                        <div class="cred-item">{t.cred2}</div>
                    </div>
                </div>

                <!-- Right Visual: Dedicated split pane for the cutout image -->
                <div class="author-image-pane">
                    <img
                        src={authorImg}
                        alt="Latika Bissa"
                        class="author-img"
                        loading="lazy"
                        decoding="async"
                    />
                </div>
            </div>
        </a>
    </div>
</section>

<style>
    .author-section {
        width: 100%;
        display: flex;
        align-items: center;
        background-color: transparent;
    }

    .author-link {
        text-decoration: none;
        display: block;
        width: 100%;
    }

    /* True Split-Pane Card Architecture */
    .author-card {
        background: var(--bg-sub);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        width: 100%;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: stretch; /* Forces both panes to match height */
        overflow: hidden; /* Clips the image perfectly at the bottom corner */
        transition:
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            border-color 0.4s ease,
            box-shadow 0.4s ease;
    }

    .author-link:hover .author-card {
        transform: translateY(-6px);
        border-color: color-mix(in srgb, var(--primary) 40%, var(--border));
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06);
    }

    .author-content {
        padding: 64px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1; /* Expands to fill empty space, pushing image to the right */
        z-index: 2;
        text-align: left;
    }

    .author-header {
        margin-bottom: 32px;
    }

    .author-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        color: var(--primary);
        font-weight: 700;
        letter-spacing: 0.08em;
        display: block;
        margin-bottom: 12px;
    }

    .author-name {
        font-size: clamp(2.4rem, 5vw, 3.4rem);
        color: var(--text-main);
        margin: 0 0 8px 0;
        font-weight: var(--fw-bold);
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .author-trust {
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
    }

    .creds-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .cred-item {
        font-size: 1.1rem;
        color: var(--text-muted);
        font-weight: 500;
    }

    /* Right Pane Background & Image Anchoring */
    .author-image-pane {
        width: 45%;
        max-width: 480px;
        position: relative;
        display: flex;
        align-items: flex-end; /* Grounds Latika to the bottom of the card */
        justify-content: center;
        background: radial-gradient(
            circle at bottom center,
            color-mix(in srgb, var(--primary) 10%, transparent) 0%,
            transparent 70%
        );
        flex-shrink: 0;
    }

    .author-img {
        width: 100%;
        max-height: 100%;
        object-fit: contain;
        object-position: bottom right; /* Locks image to the bottom right corner */
        transform-origin: bottom center;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        display: block; /* Removes baseline gap */
    }

    .author-link:hover .author-img {
        transform: scale(1.03);
    }

    /* Responsive Adjustments */
    @media (max-width: 992px) {
        .author-content {
            padding: 48px 40px;
        }
        .author-image-pane {
            width: 40%;
        }
    }

    @media (max-width: 768px) {
        .author-card {
            flex-direction: column;
        }

        .author-content {
            padding: 40px 24px 0 24px; /* Removes bottom padding so image flows naturally */
        }

        .author-image-pane {
            width: 100%;
            max-width: 100%;
            height: 320px;
            margin-top: 16px;
            background: radial-gradient(
                circle at bottom center,
                color-mix(in srgb, var(--primary) 8%, transparent) 0%,
                transparent 60%
            );
        }

        .author-img {
            object-position: bottom center; /* Centers image on mobile */
            height: 100%;
        }
    }
</style>
