---
import Site from "../layouts/Site.astro";

const title = "Page not found · Tulaa";
const description =
    "This page doesn't exist. Return home or explore our wellness resources.";
---

<Site
    title={title}
    description={description}
    canonicalPath="/404"
    hasTranslation={false}
>
    <main class="error-container">
        <div class="error-content">
            <span class="error-code">404</span>
            <h1 class="error-title">Breathe out. Let's refocus.</h1>
            <p class="error-desc">
                The page you are looking for seems to have wandered off. Don't
                worry, you are still in a safe space.
            </p>

            <div class="action-grid">
                <a href="/" class="btn-primary"> Return Home </a>
            </div>
        </div>
    </main>
</Site>

<style>
    /* Centered Layout */
    .error-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        text-align: center;

        /* Ambient layout glow */
        background: radial-gradient(
            circle at 50% 50%,
            var(--bg-sub) 0%,
            var(--bg-main) 70%
        );
    }

    .error-content {
        max-width: 500px;
        margin-top: -60px;
    }

    /* Typography */
    .error-code {
        font-size: clamp(4rem, 10vw, 6rem);
        color: var(--primary);
        opacity: 0.2;
        line-height: 1;
        display: block;
        margin-bottom: 24px;
    }

    .error-title {
        font-size: clamp(1.8rem, 5vw, 2.5rem);
        color: var(--text-main);
        margin-bottom: 16px;
    }

    /* CLEANED: Extracted individual letter-spacing adjustments to rely gracefully on layouts engine tracking configurations */

    .error-desc {
        font-size: 1.1rem;
        color: var(--text-muted);
        margin-bottom: 40px;
        line-height: 1.6;
    }

    /* Actions */
    .action-grid {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
    }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--text-main);
        color: var(--bg-main);
        padding: 12px 28px;
        border-radius: 99px;
        font-family: var(--font-sans-en);
        font-weight: 600;
        text-decoration: none;
        transition:
            transform 0.3s cubic-bezier(0.165, 0.84, 0.44, 1),
            filter 0.2s ease;
    }

    .btn-primary:hover {
        transform: translateY(-4px);
        filter: brightness(1.08);
    }
</style>
