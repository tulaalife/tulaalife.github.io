---
import Site from "../layouts/Site.astro";
import CTAButton from "../components/CTAButton.astro";

const title = "Page not found · Tulaa";
const description =
    "This page doesn't exist. Return home or explore our wellness resources.";
---

<Site
    title={title}
    description={description}
    canonicalPath="/404"
    hasTranslation={false}
>
    <main class="error-container">
        <!-- Integrated our layout structure center-alignment configuration utility framework -->
        <div class="section-header-center error-content">
            <span class="error-code">404</span>
            <h1 class="error-title hero-title">Breathe out. Let's refocus.</h1>
            <p
                class="error-desc body-text"
                style="margin-top: 16px; margin-bottom: 40px;"
            >
                The page you are looking for seems to have wandered off. Don't
                worry, you are still in a safe space.
            </p>

            <div class="action-grid">
                <CTAButton
                    href="/"
                    label="Return Home"
                    variant="solid"
                    size="lg"
                    icon="→"
                />
            </div>
        </div>
    </main>
</Site>

<style>
    .error-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;

        /* Ambient layout glow */
        background: radial-gradient(
            circle at 50% 50%,
            var(--bg-sub) 0%,
            var(--bg-main) 70%
        );
    }

    .error-content {
        max-width: 500px;
    }

    /* Typography */
    .error-code {
        font-size: clamp(4rem, 10vw, 6rem);
        font-weight: var(--fw-bold);
        color: var(--primary);
        opacity: 0.2;
        line-height: 1;
        display: block;
        margin-bottom: 24px;
    }

    .error-title {
        font-size: clamp(1.8rem, 5vw, 2.5rem);
        color: var(--text-main);
    }

    .error-desc {
        color: var(--text-muted);
    }

    /* Actions Layout Structure */
    .action-grid {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
    }
</style>
