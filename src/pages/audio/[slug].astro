---
import { guidedAudios } from "../../data/generated";
import AudioPageTemplate from "../../components/AudioPageTemplate.astro";

export async function getStaticPaths() {
    // Only generate for English
    return guidedAudios
        .filter((a) => a.language === "en")
        .map((a) => ({
            params: { slug: a.slug },
            props: { audio: a },
        }));
}

const { audio } = Astro.props;
---

<AudioPageTemplate audio={audio} lang="en" />
