---
import AudioListing from "../../components/AudioListing.astro";
import { guidedAudios } from "../../data/generated";

const displayAudios = guidedAudios.filter((a) => a.language === "en");
---

<AudioListing
    title="Guided Audios"
    description="Gentle voice-guided sessions for calm, focus, and rest."
    displayAudios={displayAudios}
    lang="en"
/>
