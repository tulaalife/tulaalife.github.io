---
import YogaListing from "../../../components/YogaListing.astro";
import { yogaPlans } from "../../../data/generated";
import {
    YOGA_UI,
    CATEGORY_MAP,
    type SupportedLang,
} from "../../../utils/ui-strings";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
    const languages = Object.keys(YOGA_UI);
    return languages.flatMap((lang) => {
        const langPlans = yogaPlans.filter((p) => p.language === lang);
        return paginate(langPlans, { params: { lang }, pageSize: 20 });
    });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { lang = "en" } = Astro.params;

const labels = YOGA_UI[lang as SupportedLang] || YOGA_UI.en;

// --- SERVER-SIDE SORTING LOGIC ---
const url = new URL(Astro.request.url);
const currentGoal = url.searchParams.get("goal");

// Use the centralized CATEGORY_MAP for server-side initial sort
if (currentGoal && CATEGORY_MAP[currentGoal]) {
    const targetGoals = CATEGORY_MAP[currentGoal];

    page.data.sort((a, b) => {
        const aMatch = targetGoals.some((g) => a.goals?.includes(g));
        const bMatch = targetGoals.some((g) => b.goals?.includes(g));

        if (aMatch && !bMatch) return -1;
        if (!aMatch && bMatch) return 1;
        return 0;
    });
}
// ---------------------------------

const pageTitle = `${labels.title} · ${labels.metaPage} ${page.currentPage}`;
const canonical =
    page.currentPage === 1
        ? `/${lang}/yoga`
        : `/${lang}/yoga/${page.currentPage}`;
---

<YogaListing
    page={page}
    title={pageTitle}
    description={labels.description}
    canonicalPath={canonical}
    lang={lang}
    labels={labels}
/>
