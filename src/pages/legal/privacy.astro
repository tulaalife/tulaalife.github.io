---
import Site from "../../layouts/Site.astro";
import { marked } from "marked";

// Import the local markdown files as raw text strings
import privacyEn from "../../data/legal/privacy_en.md?raw";
import privacyHi from "../../data/legal/privacy_hi.md?raw";

// 1. Get current language
const currentLang = Astro.currentLocale || "en";

// 2. Dynamic Dictionary
const ui = {
    en: {
        title: "Tulaa — Privacy Policy",
        desc: "Tulaa Privacy Policy — local-only logs, optional anonymous analytics with PostHog, no PII.",
        termsLink: "Terms of Use",
        help: "Need help?",
    },
    hi: {
        title: "तुला — गोपनीयता नीति",
        desc: "तुला गोपनीयता नीति — केवल स्थानीय लॉग, पोस्टहॉग के साथ वैकल्पिक अनाम एनालिटिक्स, कोई व्यक्तिगत डेटा नहीं।",
        termsLink: "उपयोग की शर्तें",
        help: "मदद चाहिए?",
    },
};
const t = ui[currentLang as keyof typeof ui] || ui.en;

// Helper to keep links in the correct language
const getLink = (path: string) => (currentLang === "en" ? path : `/hi${path}`);

// 3. Use the local markdown based on the current language
const rawMarkdown = currentLang === "hi" ? privacyHi : privacyEn;
const contentHtml = await marked.parse(rawMarkdown);
---

<Site
    title={t.title}
    description={t.desc}
    canonicalPath="/legal/privacy"
    hideFooter={true}
>
    <!-- Combined layout tracking under premium left alignment container system rules -->
    <main class="section-header-left legal-wrap">
        <div class="markdown-body" set:html={contentHtml} />

        <p class="legal-meta body-text">
            <a href={getLink("/legal/terms")}>{t.termsLink}</a> · {t.help}
            <a href="mailto:contact@tulaalife.com">contact@tulaalife.com</a>
        </p>

        <script type="application/ld+json" is:inline>
            {
                "@context": "https://schema.org",
                "@type": "WebPage",
                "name": "Tulaa — Privacy Policy",
                "url": "https://tulaalife.com/legal/privacy",
                "datePublished": "2025-09-16"
            }
        </script>
    </main>
</Site>

<style is:global>
    .legal-wrap {
        max-width: 760px; /* Optimized container width for smooth long-form tracking comfort */
        margin: 0 auto;
        padding: 60px 24px 80px;
        font-family: var(--font-sans-en);
        text-align: left;
    }

    :global(:lang(hi)) .legal-wrap {
        font-family: var(--font-sans-hi);
    }

    .legal-title {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 12px 0 24px;
        font-size: clamp(1.8rem, 4vw, 2.2rem);
    }

    .legal-logo {
        vertical-align: middle;
        border-radius: 8px;
    }

    .legal-meta {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin: 40px 0 18px;
        border-top: 1px solid var(--border);
        padding-top: 20px;
        text-align: left;
        width: 100%;
    }

    .markdown-body h1,
    .markdown-body h2,
    .markdown-body h3 {
        font-weight: var(--fw-bold);
        color: var(--text-main);
        text-align: left;
    }

    .markdown-body h2 {
        margin-top: 32px;
        margin-bottom: 12px;
        font-size: 1.4rem;
    }

    .markdown-body p,
    .markdown-body ul,
    .markdown-body li {
        font-size: 1.05rem;
        line-height: 1.65;
        margin-bottom: 14px;
        color: var(--text-main);
        text-align: left;
    }

    :global(:lang(hi)) .markdown-body p,
    :global(:lang(hi)) .markdown-body li {
        line-height: 1.75;
    }

    .markdown-body ul {
        padding-left: 24px;
    }

    .markdown-body li {
        margin-bottom: 6px;
    }

    .markdown-body strong {
        font-weight: var(--fw-bold);
    }

    .markdown-body blockquote {
        background: var(--bg-sub);
        border: 1px solid var(--border);
        padding: 20px;
        border-radius: var(--radius-lg);
        margin: 20px 0;
        margin-inline-start: 0;
        margin-inline-end: 0;
    }

    .markdown-body blockquote p {
        margin-bottom: 0;
    }

    .markdown-body a {
        color: var(--primary);
        text-decoration: underline;
        text-underline-offset: 4px;
        font-weight: 600;
    }
</style>
