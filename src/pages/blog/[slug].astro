---
import { blogPosts } from "../../data/generated";
import BlogDetailTemplate from "../../components/BlogDetailTemplate.astro"; // Create this by extracting your detail UI

export async function getStaticPaths() {
    return blogPosts
        .filter((p) => p.language === "en")
        .map((post) => ({
            params: { slug: post.slug },
            props: { post },
        }));
}
const { post } = Astro.props;
---

<BlogDetailTemplate post={post} lang="en" />
