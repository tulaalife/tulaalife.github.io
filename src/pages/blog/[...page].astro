---
import BlogListing from "../../components/BlogListing.astro";
import { blogPosts } from "../../data/generated";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
    const englishPosts = blogPosts
        .filter((p) => p.language === "en")
        .sort(
            (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
        );
    return paginate(englishPosts, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BlogListing
    page={page}
    lang="en"
    title="Wellness Blog"
    description="Insights on yoga, sleep, and mindful living."
/>
