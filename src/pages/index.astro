---
import Layout from "../layouts/Site.astro";
import StickyNav from "../components/landing/StickyNav.astro";
import Hero from "../components/landing/Hero.astro";
import HeroAuthor from "../components/landing/HeroAuthor.astro";
import YogaFeatures from "../components/landing/YogaFeatures.astro";
import WellnessTools from "../components/landing/WellnessTools.astro";
import MindAndMood from "../components/landing/MindAndMood.astro";
import PrivacyTrust from "../components/landing/PrivacyTrust.astro";
import HeroVideo from "../components/landing/HeroVideo.astro";

const title = "Tulaa — Your Private Sanctuary for Holistic Wellness";
const description =
  "Free, offline, expert-led yoga and wellness tools. No login required. No tracking. Just you and your practice.";
---

<Layout
  title={title}
  description={description}
  canonicalPath="/"
  isLandingPage={true}
>
  <StickyNav />
  <Hero />
  <HeroVideo />
  <HeroAuthor />
  <YogaFeatures />
  <WellnessTools />
  <MindAndMood />
  <PrivacyTrust />
</Layout>
